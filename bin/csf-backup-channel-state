#!/usr/bin/env python3
"""Create a timestamped backup of the active yt-is channel-state DB."""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from csf.batch_status import backup_batch_status_db, _get_default_db_path


def main() -> int:
    backup_path = backup_batch_status_db()
    if backup_path is None:
        print(f"[backup] no batch-status DB found at {_get_default_db_path()}")
        return 0
    print(f"[backup] wrote {backup_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
