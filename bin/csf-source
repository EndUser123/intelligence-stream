def _take_industrial_dispatch_groups(
    batch_queue: list[list[str]],
    worker_slots: int,
    batches_per_worker: int = 4,
) -> list[list[list[str]]]:
    """Take up to a bounded bundle of batches per available worker slot."""
    if worker_slots < 1:
        raise ValueError("worker_slots must be >= 1")
    if batches_per_worker < 1:
        raise ValueError("batches_per_worker must be >= 1")
    if not batch_queue:
        return []
    dispatch_count = min(worker_slots, len(batch_queue))
    groups: list[list[list[str]]] = [[] for _ in range(dispatch_count)]
    while batch_queue and any(len(group) < batches_per_worker for group in groups):
        for group in groups:
            if not batch_queue:
                break
            if len(group) >= batches_per_worker:
                continue
            group.append(batch_queue.pop(0))
    return [group for group in groups if group]


def _load_worker_summary(result_path: Path | None, stdout_text: str) -> dict[str, object]:
    """Load a worker result from disk, falling back to stdout JSON."""
    summary: dict[str, object] = {}
    if result_path is not None and result_path.exists():
        try:
            summary = json.loads(result_path.read_text(encoding="utf-8"))
        except Exception:
            summary = {}
    if not summary and stdout_text:
        lines = stdout_text.rstrip().splitlines()
        if lines:
            try:
                summary = json.loads(lines[-1])
            except Exception:
                summary = {}
    return summary


def _build_industrial_worker_launch(
    *,
    worker_id: int,
    worker_batches: list[list[str]],
) -> dict[str, object]:
    """Build per-worker subprocess settings without mutating process-wide env."""
    state_root = Path(
        os.getenv(
            "YTIS_INDUSTRIAL_WORKER_STATE_ROOT",
            "P:/.data/yt-is/industrial-worker-states",
        )
    )
    notebook_prefix = os.getenv(
        "YTIS_INDUSTRIAL_WORKER_NOTEBOOK_PREFIX",
        "yt-is-worker",
    )
    profile_prefix = os.getenv(
        "YTIS_INDUSTRIAL_WORKER_NOTEBOOKLM_PROFILE_PREFIX",
        "ytis-worker",
    )
    explicit_profiles = [
        item.strip()
        for item in os.getenv("YTIS_INDUSTRIAL_WORKER_NOTEBOOKLM_PROFILES", "").split(",")
        if item.strip()
    ]
    state_root.mkdir(parents=True, exist_ok=True)
    state_path = state_root / f"worker-{worker_id:02d}.json"
    notebook_title = f"{notebook_prefix}-{worker_id:02d}"
    if explicit_profiles:
        if worker_id > len(explicit_profiles):
            raise ValueError(
                "YTIS_INDUSTRIAL_WORKER_NOTEBOOKLM_PROFILES must include "
                f"a profile for worker {worker_id:02d}"
            )
        notebooklm_profile = explicit_profiles[worker_id - 1]
    else:
        notebooklm_profile = f"{profile_prefix}-{worker_id:02d}"
    worker_env = os.environ.copy()
    worker_env["YTIS_NLM_OWNER_STATE_PATH"] = str(state_path)
    worker_env["YTIS_NLM_OWNER_NOTEBOOK_TITLE"] = notebook_title
    worker_env["YTIS_NLM_REUSABLE_STATE_PATH"] = str(state_path)
    worker_env["YTIS_NLM_REUSABLE_NOTEBOOK_TITLE"] = notebook_title
    worker_env["NOTEBOOKLM_PROFILE"] = notebooklm_profile
    return {
        "worker_label": f"worker-{worker_id:02d}",
        "state_path": str(state_path),
        "notebook_title": notebook_title,
        "notebooklm_profile": notebooklm_profile,
        "batch_count": len(worker_batches),
        "video_count": sum(len(batch) for batch in worker_batches),
        "env": worker_env,
    }


def _build_fetch_completed_payload(
    *,
    source_filter: str | None,
    strategy: str,
    backend: str,
    backlog_threshold: int,
    batch_size: int,
    workers: int,
    channels_tracked_total: int,
    channels_blocked_total: int,
    channels_active_total: int,
    pending_total: int,
    cached_total: int,
    cached_hit_rate: float,
    cached_sample: list[dict[str, object]],
    industrial_batches_processed: int,
    transcript_fallback_processed_count: int,
    terminal_count: int,
    negative_cache_count: int,
    worker_cleanup_deleted: int,
    worker_cleanup_failed: int,
    success_count: int,
    fail_count: int,
    skip_count: int,
    processed_count: int,
    elapsed_s: float,
    status: str,
    max_items: int | None = None,
    worker_stage_totals: dict[str, float] | None = None,
    worker_source_profile_totals: dict[str, object] | None = None,
    notebooklm_pending_count: int = 0,
    transcript_fallback_queued_count: int = 0,
    terminal_reason_counts: dict[str, int] | None = None,
    negative_cache_reason_counts: dict[str, int] | None = None,
    negative_cache_sample: list[dict[str, object]] | None = None,
    route_no_captions_to_fallback: bool = False,
) -> dict[str, object]:
    return {
        "source_filter": source_filter,
        "strategy": strategy,
        "backend": backend,
        "backlog_threshold": backlog_threshold,
        "batch_size": batch_size,
        "max_items": max_items,
        "workers": workers,
        "channels_tracked_total": channels_tracked_total,
        "channels_blocked_total": channels_blocked_total,
        "channels_active_total": channels_active_total,
        "pending_total": pending_total,
        "cached_total": cached_total,
        "cached_hit_rate": cached_hit_rate,
        "cached_sample": cached_sample,
        "industrial_batches_processed": industrial_batches_processed,
        "notebooklm_pending_count": notebooklm_pending_count,
        "transcript_fallback_processed_count": transcript_fallback_processed_count,
        "transcript_fallback_queued_count": transcript_fallback_queued_count,
        "terminal_count": terminal_count,
        "negative_cache_count": negative_cache_count,
        "terminal_reason_counts": terminal_reason_counts or {},
        "negative_cache_reason_counts": negative_cache_reason_counts or {},
        "negative_cache_sample": negative_cache_sample or [],
        "worker_cleanup_deleted": worker_cleanup_deleted,
        "worker_cleanup_failed": worker_cleanup_failed,
        "worker_stage_totals": worker_stage_totals or {},
        "worker_source_profile_totals": worker_source_profile_totals or {},
        "route_no_captions_to_fallback": route_no_captions_to_fallback,
        "success_count": success_count,
        "fail_count": fail_count,
        "skip_count": skip_count,
        "processed_count": processed_count,
        "elapsed_s": elapsed_s,
        "success_per_min": round(success_count / elapsed_s * 60, 2) if elapsed_s > 0 else None,
        "processed_per_min": round(processed_count / elapsed_s * 60, 2) if elapsed_s > 0 else None,
        "status": status,
    }


def _empty_source_profile_totals() -> dict[str, object]:
    return {
        "total": 0,
        "matched": 0,
        "missing": 0,
        "source_class_counts": {},
        "status_counts": {},
        "privacy_status_counts": {},
        "upload_status_counts": {},
        "unavailable_reason_counts": {},
        "failure_reason_counts": {},
    }


def _merge_source_profile_totals(
    target: dict[str, object],
    source: dict[str, object] | None,
) -> dict[str, object]:
    if not source:
        return target
    for key in ("total", "matched", "missing"):
        target[key] = int(target.get(key, 0) or 0) + int(source.get(key, 0) or 0)
    for key in (
        "source_class_counts",
        "status_counts",
        "privacy_status_counts",
        "upload_status_counts",
        "unavailable_reason_counts",
        "failure_reason_counts",
    ):
        merged = Counter(target.get(key, {}) or {})
        merged.update(source.get(key, {}) or {})
        target[key] = dict(merged)
    return target


def _log_fetch_completed(
    *,
    source_filter: str | None,
    strategy: str,
    backend: str,
    backlog_threshold: int,
    batch_size: int,
    workers: int,
    channels_tracked_total: int,
    channels_blocked_total: int,
    channels_active_total: int,
    pending_total: int,
    cached_total: int,
    cached_hit_rate: float,
    cached_sample: list[dict[str, object]],
    industrial_batches_processed: int,
    transcript_fallback_processed_count: int,
    terminal_count: int,
    negative_cache_count: int,
    worker_cleanup_deleted: int,
    worker_cleanup_failed: int,
    success_count: int,
    fail_count: int,
    skip_count: int,
    elapsed_s: float,
    status: str,
    max_items: int | None = None,
    worker_stage_totals: dict[str, float] | None = None,
    worker_source_profile_totals: dict[str, object] | None = None,
    notebooklm_pending_count: int = 0,
    transcript_fallback_queued_count: int = 0,
    terminal_reason_counts: dict[str, int] | None = None,
    negative_cache_reason_counts: dict[str, int] | None = None,
    negative_cache_sample: list[dict[str, object]] | None = None,
    route_no_captions_to_fallback: bool = False,
) -> None:
    processed_count = success_count + fail_count + skip_count
    log_action(
        "fetch_completed",
        _build_fetch_completed_payload(
            source_filter=source_filter,
            strategy=strategy,
            backend=backend,
            backlog_threshold=backlog_threshold,
            batch_size=batch_size,
            max_items=max_items,
            workers=workers,
            channels_tracked_total=channels_tracked_total,
            channels_blocked_total=channels_blocked_total,
            channels_active_total=channels_active_total,
            pending_total=pending_total,
            cached_total=cached_total,
            cached_hit_rate=cached_hit_rate,
            cached_sample=cached_sample,
            industrial_batches_processed=industrial_batches_processed,
            transcript_fallback_processed_count=transcript_fallback_processed_count,
            terminal_count=terminal_count,
            negative_cache_count=negative_cache_count,
            worker_cleanup_deleted=worker_cleanup_deleted,
            worker_cleanup_failed=worker_cleanup_failed,
            worker_stage_totals=worker_stage_totals,
            worker_source_profile_totals=worker_source_profile_totals,
            route_no_captions_to_fallback=route_no_captions_to_fallback,
            notebooklm_pending_count=notebooklm_pending_count,
            transcript_fallback_queued_count=transcript_fallback_queued_count,
            terminal_reason_counts=terminal_reason_counts,
            negative_cache_reason_counts=negative_cache_reason_counts,
            negative_cache_sample=negative_cache_sample,
            success_count=success_count,
            fail_count=fail_count,
            skip_count=skip_count,
            processed_count=processed_count,
            elapsed_s=elapsed_s,
            status=status,
        ),
    )


def _build_worker_health_warning(
    *,
    reason: str,
    elapsed_s: float,
    active_workers: int,
    queued_batches: int,
    available_slots: int,
    first_worker_finished_at: float | None,
    last_worker_finished_at: float | None = None,
    worker_id: str | None = None,
    batch_count: int | None = None,
    video_count: int | None = None,
    batch_size: int | None = None,
) -> dict[str, object]:
    payload: dict[str, object] = {
        "reason": reason,
        "elapsed_s": round(elapsed_s, 3),
        "active_workers": active_workers,
        "queued_batches": queued_batches,
        "available_slots": available_slots,
        "first_worker_finished": first_worker_finished_at is not None,
    }
    if first_worker_finished_at is not None:
        payload["first_worker_finished_at"] = round(first_worker_finished_at, 3)
    payload["last_worker_finished"] = last_worker_finished_at is not None
    if last_worker_finished_at is not None:
        payload["last_worker_finished_at"] = round(last_worker_finished_at, 3)
    if worker_id is not None:
        payload["worker_id"] = worker_id
    if batch_count is not None:
        payload["batch_count"] = batch_count
    if video_count is not None:
        payload["video_count"] = video_count
    if batch_size is not None:
        payload["batch_size"] = batch_size
    return payload


def _print_block_signals(info, channel_id: str, canonical_url: str) -> bool:
    """Evaluate and print blocklist signals for a channel.

    Args:
        info: ChannelInfo namedtuple from get_upload_playlist_id()
        channel_id: the parsed channel ID (e.g. "@MarquesBrownlee" or "UC...")
        canonical_url: the canonical YouTube URL for this channel

    Returns:
        True if the user chose to block the channel (caller should exit),
        False otherwise.
    """
    signals = analyze_channel_filter_signals(
        channel_title=info.title,
        description=info.description,
        keywords=info.keywords,
        custom_url=info.custom_url,
        video_count=info.video_count,
    )

    print()
    if (
        not signals.learnable
        and not signals.story
        and not signals.performance
        and not signals.entertainment
        and not signals.podcast
        and not signals.institutional_core
        and not signals.institutional_light
        and not signals.caution
    ):
        print("[signals] No channel filtering signals detected.")
        return False

    print(f"[signals] POLICY READ: {signals.recommendation.upper()}")
    if signals.learnable:
        print("[signals] Learnable cues:")
        for s in signals.learnable:
            print(f"  • {s}")
    if signals.story:
        print("[signals] Story / lore cues:")
        for s in signals.story:
            print(f"  • {s}")
    if signals.performance:
        print("[signals] Music / dance / performance cues:")
        for s in signals.performance:
            print(f"  • {s}")
    if signals.entertainment:
        print("[signals] Entertainment cues:")
        for s in signals.entertainment:
            print(f"  • {s}")
    if signals.podcast:
        print("[signals] Podcast / discussion cues:")
        for s in signals.podcast:
            print(f"  • {s}")
    if signals.institutional_core:
        print("[signals] Institutional / broadcaster cues:")
        for s in signals.institutional_core:
            print(f"  • {s}")
    if signals.institutional_light:
        print("[signals] Light institutional cues:")
        for s in signals.institutional_light:
            print(f"  • {s}")
    if signals.caution:
        print("[signals] Caution cues:")
        for s in signals.caution:
            print(f"  • {s}")

    print()
    response = input("[signals] Block this channel? [y/N] ").strip().lower()
    if response == "y":
        block_channel(canonical_url)
        print(f"[source] Blocked: {canonical_url}")
        print("[source] Exiting — use 'unblock' to remove from blocklist later.")
        return True

    print()
    return False


def _mark_videos_pending(
    canonical_url: str, videos: list[dict]
) -> int:
    """Mark videos as pending, filtering out already-complete ones.

    Returns the number of newly marked videos.
    """
    video_ids = [v["video_id"] for v in videos]
    status_map = get_status_batch(video_ids)
    complete_ids = {vid for vid, status in status_map.items() if status == "complete"}
    entries = [
        BatchEntry(
            video_id=video["video_id"],
            status="pending",
            source=canonical_url,
            published_at=video.get("published_at"),
            has_captions=video.get("has_captions"),
            title=video.get("title"),
            description=video.get("description"),
            channel_id=video.get("channel_id"),
            thumbnail=video.get("thumbnail"),
            duration=video.get("duration"),
            privacy_status=video.get("privacy_status"),
            upload_status=video.get("upload_status"),
            is_live_content=video.get("is_live_content"),
            unavailable_reason=video.get("unavailable_reason"),
        )
        for video in videos
        if video["video_id"] not in complete_ids
    ]
    if entries:
        set_status_batch(entries)
    return len(entries)


def cmd_add(url: str) -> None:
    """Add a new channel or playlist source with full enumeration."""
    print(f"[source] Adding source: {url}")

    # Check quota state before making API calls
    quota = get_quota_status()
    total_units = sum(v["units_consumed"] for v in quota.values())
    total_calls = sum(v["calls_made"] for v in quota.values())
    exhausted_count = sum(1 for v in quota.values() if v.get("exhausted", False))
    print(f"[source] Quota state: {total_calls} calls, ~{total_units} units consumed, {exhausted_count}/{len(quota)} keys exhausted")

    if not can_proceed(units_needed=500):
        print(f"[source] Warning: Quota may be insufficient. YouTube API may reject calls.")
        print(f"[source] Consider waiting for quota to reset (daily limit is 10,000 units/key).")
        print(f"[source] Current state:")
        for idx, state in quota.items():
            print(f"  Key {idx}: {state['calls_made']} calls, ~{state['units_consumed']} units, exhausted={state['exhausted']}")

    # Check if this is a channel or playlist
    channel_id = parse_channel_url(url)
    playlist_id = parse_playlist_url(url)

    if channel_id:
        print(f"[source] Detected channel: {channel_id}")

        # Get uploads playlist ID and full metadata from API (two-tier: snippet=1 unit, full=5 units)
        channel_info = get_upload_playlist_id(channel_id)
        if not channel_info:
            print(f"[source] Error: Could not resolve uploads playlist for {channel_id}", file=sys.stderr)
            print(f"[source] The channel handle does not exist on YouTube (forHandle returned 0 items).", file=sys.stderr)
            print(f"[source] The handle in history.jsonl may be a mention/reference, not a valid @username.", file=sys.stderr)
            sys.exit(1)

        uploads_playlist_id = channel_info.playlist_id
        real_video_count = channel_info.video_count
        channel_title = channel_info.channel_title
        thumbnail_url = channel_info.thumbnail_url
        subscriber_count = channel_info.subscriber_count
        view_count = channel_info.view_count

        print(f"[source] Uploads playlist: {uploads_playlist_id}")
        if real_video_count:
            print(f"[source] Channel has {real_video_count} total videos (from YouTube API)")
            if channel_title:
                print(f"[source] Title: {channel_title}")
        playlist_id = uploads_playlist_id
        # Construct canonical URL: prefer API-resolved @handle (custom_url) over input format.
        # This prevents duplicates when user adds via /channel/UCxxx URL — API returns
        # the channel's actual @handle (e.g. /@MarquesBrownlee) which we store instead.
        if channel_info.custom_url:
            canonical_url = f"https://www.youtube.com{channel_info.custom_url}"
        elif channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"

    elif playlist_id:
        print(f"[source] Detected playlist: {playlist_id}")
        canonical_url = f"https://www.youtube.com/playlist?list={playlist_id}"

    else:
        # Try video URL
        video_id = parse_video_url(url)
        if video_id:
            print(f"[source] Detected video: {video_id}")
            # Single-video entry: use watch URL as the source identifier
            canonical_url = url
            # Check blocklist for videos too
            if is_channel_blocked(canonical_url):
                print(f"[source] Blocked: {canonical_url} is on the blocklist.")
                print(f"[source] Use 'unblock {url}' to remove from blocklist first.")
                sys.exit(1)
            new_count = _mark_videos_pending(canonical_url, [
                {"video_id": video_id, "title": None, "published_at": None}
            ])
            # Register/update source in channel_metadata (no playlist_id for single video)
            now = datetime.now(timezone.utc).isoformat()
            upsert_channel(canonical_url, last_checked=now)
            print(f"[source] Done. 1 video, {new_count} new pending.")
            return

        print(f"[source] Error: Could not parse {url} as channel, playlist, or video URL", file=sys.stderr)
        sys.exit(1)

    # Check blocklist before any API calls or enumeration
    if is_channel_blocked(canonical_url):
        print(f"[source] Blocked: {canonical_url} is on the blocklist.")
        print(f"[source] Use 'unblock {url}' to remove from blocklist first.")
        sys.exit(1)

    # Check if already tracked
    existing = get_channel_metadata(canonical_url)
    if existing:
        print(f"[source] Warning: {canonical_url} is already tracked.")
        print(f"[source] Use 'check' to update, or remove and re-add for full re-enumeration.")

    # Block signal analysis — runs after channel_info is populated but before enumeration
    if channel_id:
        # canonical_url is set above in the if/elif/else branches
        if _print_block_signals(channel_info, channel_id, canonical_url):
            sys.exit(0)

    # Full enumeration
    print(f"[source] Enumerating all videos...")
    videos = enumerate_full(playlist_id)
    print(f"[source] Found {len(videos)} videos")

    if len(videos) <= 1:
        print(f"[source] Warning: Channel has {len(videos)} video(s) — rejecting channels with fewer than 2 videos")
        sys.exit(1)

    new_count = _mark_videos_pending(canonical_url, videos)
    print(f"[source] Marked {new_count} new videos as pending")

    # Update channel metadata with real video count and full API metadata
    now = datetime.now(timezone.utc).isoformat()
    video_count_to_store = real_video_count if real_video_count else len(videos)
    set_channel_metadata(
        canonical_url,
        playlist_id=playlist_id,
        last_checked=now,
        last_full_enumeration=now,
        video_count_estimate=video_count_to_store,
        channel_title=channel_title or None,
        thumbnail_url=thumbnail_url or None,
        subscriber_count=subscriber_count or None,
        view_count=view_count or None,
        description=channel_info.description or None,
        published_at=channel_info.published_at or None,
        country=channel_info.country or None,
        topic_categories=channel_info.topic_categories or None,
        keywords=channel_info.keywords or None,
        custom_url=channel_info.custom_url or None,
    )

    print(f"[source] Done. {len(videos)} total videos, {new_count} new pending.")


def cmd_list() -> None:
    """List all tracked sources with comprehensive statistics."""
    from csf.batch_status import _get_batch_status_storage
    from csf.cache import _SHARED_DB_PATH
    from csf.display import ChannelStats, format_channel_list, format_sync_results
    import sqlite3

    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    cursor = conn.execute(
        """SELECT channel_url, playlist_id, video_count_estimate, last_checked, last_full_enumeration, category
           FROM channel_metadata
           WHERE channel_url NOT IN (SELECT channel_url FROM channel_blocklist)
           ORDER BY CASE WHEN category IS NULL THEN 1 ELSE 0 END, category, last_checked DESC"""
    )
    rows = cursor.fetchall()
    conn.close()

    if not rows:
        print("[source] No sources tracked. Use 'add' to add a channel or playlist.")
        return

    # Build video_id sets per channel for accurate counting
    batch_conn = storage._get_conn()
    batch_cursor = batch_conn.execute(
        "SELECT video_id, source, status, has_captions FROM analysis_status WHERE source IS NOT NULL"
    )

    # Structure: channel_url -> {pending: set(), complete: set(), failed: set(), has_subs: set(), no_subs: set()}
    channel_videos: dict[str, dict[str, set[str]]] = {}
    for vid, src, status, has_captions in batch_cursor.fetchall():
        if src not in channel_videos:
            channel_videos[src] = {
                "pending": set(),
                "complete": set(),
                "failed": set(),
                "has_subs": set(),
                "no_subs": set(),
            }

        # Add to status set
        if status in ("pending", "complete", "failed"):
            channel_videos[src][status].add(vid)

        # Add to captions set
        if has_captions == 1:
            channel_videos[src]["has_subs"].add(vid)
        elif has_captions == 0:
            channel_videos[src]["no_subs"].add(vid)

    batch_conn.close()

    # Query transcript cache for detailed metrics per channel
    transcript_stats: dict[str, dict] = {}
    try:
        _SHARED_DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        cache_conn = sqlite3.connect(_SHARED_DB_PATH)
        cache_conn.execute("PRAGMA journal_mode=WAL")

        for channel_url, status_sets in channel_videos.items():
            # Flatten all status sets into one combined set of video_ids for this channel
            all_video_ids = status_sets["pending"] | status_sets["complete"] | status_sets["failed"]
            if not all_video_ids:
                continue

            video_ids = list(all_video_ids)
            placeholders = ",".join("?" * len(video_ids))
            # Count cached transcripts
            count_cursor = cache_conn.execute(
                f"SELECT COUNT(DISTINCT video_id) FROM transcript_cache WHERE video_id IN ({placeholders})",
                video_ids
            )
            cached_count = count_cursor.fetchone()[0]

            # Last download timestamp
            last_dl_cursor = cache_conn.execute(
                f"SELECT MAX(cached_at) FROM transcript_cache WHERE video_id IN ({placeholders})",
                video_ids
            )
            last_download = last_dl_cursor.fetchone()[0]

            # Languages available
            lang_cursor = cache_conn.execute(
                f"SELECT DISTINCT lang FROM transcript_cache WHERE video_id IN ({placeholders}) ORDER BY lang",
                video_ids
            )
            langs = [row[0] for row in lang_cursor.fetchall()]
            languages_str = ",".join(langs[:3]) + ("..." if len(langs) > 3 else "") if langs else ""

            # Storage size (total characters in transcripts)
            size_cursor = cache_conn.execute(
                f"SELECT SUM(LENGTH(transcript)) FROM transcript_cache WHERE video_id IN ({placeholders})",
                video_ids
            )
            total_chars = size_cursor.fetchone()[0] or 0
            size_mb = total_chars / (1024 * 1024)  # Convert to MB

            transcript_stats[channel_url] = {
                "cached": cached_count,
                "last_download": last_download,
                "languages": languages_str,
                "size_mb": size_mb,
            }

        cache_conn.close()
    except Exception:
        # If transcript query fails, use defaults
        pass

    # Build ChannelStats objects with all metrics in the new summary format
    channels = []
    for row in rows:
        channel_url = row[0]

        # Get video sets for this channel
        video_sets = channel_videos.get(channel_url, {
            "pending": set(), "complete": set(), "failed": set(),
            "has_subs": set(), "no_subs": set(),
        })

        pending_set = video_sets["pending"]
        complete_set = video_sets["complete"]
        failed_set = video_sets["failed"]
        has_subs_set = video_sets["has_subs"]
        no_subs_set = video_sets["no_subs"]

        # Calculate actual total from database (not stale estimate)
        total = len(pending_set | complete_set | failed_set)

        # Counts
        pending = len(pending_set)
        complete = len(complete_set)
        failed = len(failed_set)
        has_subs = len(has_subs_set)
        no_subs = len(no_subs_set)

        # Transcript stats from cache
        cache_data = transcript_stats.get(channel_url, {})
        downloaded = cache_data.get("cached", 0)  # dt - actually cached
        last_download = cache_data.get("last_download", None)
        languages = cache_data.get("languages", "")
        size_mb = cache_data.get("size_mb", 0.0)

        # Calculate derived metrics using set operations to avoid double-counting
        # available (vt) = pending videos that have subs (not tried yet, known to have subs)
        available = len(pending_set & has_subs_set)
        # unavailable (nt) = no_subs (known to not have subs) + failed (tried and failed)
        unavailable = no_subs + failed
        # main_trackable (mt) = total - unavailable (assuming no shorts data)
        main_trackable = max(0, total - unavailable)
        # shorts = 0 (no duration data available)
        shorts = 0
        # playlists/subscribers = not available
        playlists = 0
        subscribers = None

        # Calculate success rate using complete/failed counts from sets
        total_attempted = complete + failed
        if total_attempted > 0:
            if complete > 0:
                success_rate = f"{int(complete / total_attempted * 100)}%"
            else:
                success_rate = "0%"
        else:
            success_rate = "-"

        channels.append(
            ChannelStats(
                channel_url=channel_url,
                total=total,
                main_trackable=main_trackable,
                downloaded=downloaded,
                available=available,
                unavailable=unavailable,
                shorts=shorts,
                playlists=playlists,
                subscribers=subscribers,
                last_checked=row[3],
                last_full_enumeration=row[4],
                last_download=last_download,
                success_rate=success_rate,
                languages=languages,
                storage_size_mb=size_mb,
                category=row[5],
                subcategory=None,
            )
        )

    print(format_channel_list(channels))


def cmd_check(source_id_or_url: str) -> None:
    """Run daily check for a source: RSS + gap detection + API resolution."""
    # Try to find the source
    channel_url = None

    # Check if it's a tracked channel URL
    existing = get_channel_metadata(source_id_or_url)
    if existing:
        channel_url = source_id_or_url
    else:
        # Try to parse as channel URL
        parsed = parse_channel_url(source_id_or_url)
        if parsed and parsed.startswith("UC"):
            channel_url = f"https://www.youtube.com/channel/{parsed}"
            existing = get_channel_metadata(channel_url)

    if not existing:
        print(f"[source] Error: {source_id_or_url} is not a tracked source.", file=sys.stderr)
        print(f"[source] Use 'add' to add it first.", file=sys.stderr)
        sys.exit(1)

    playlist_id = existing.get("playlist_id")
    if not playlist_id:
        print(f"[source] Error: No playlist_id found for {channel_url}", file=sys.stderr)
        sys.exit(1)

    print(f"[source] Checking {channel_url}")

    # Step 1: Resolve to UC channel ID if needed
    channel_id = parse_channel_url(channel_url)
    if not channel_id:
        print(f"[source] Error: Could not parse channel ID from {channel_url}", file=sys.stderr)
        sys.exit(1)

    # Resolve @handle, c/custom, user/ URLs to UC channel ID
    if not channel_id.startswith("UC"):
        uc_channel_id = resolve_to_uc_channel_id(channel_id)
        if not uc_channel_id:
            print(f"[source] Error: Could not resolve {channel_id} to UC channel ID", file=sys.stderr)
            sys.exit(1)
        channel_id = uc_channel_id

    # Step 2: RSS check (now with UC channel ID)
    rss_ids = check_rss(channel_id)
    print(f"[source] RSS returned {len(rss_ids)} recent videos")

    if not rss_ids:
        print(f"[source] Warning: RSS returned no videos. Channel may be invalid or RSS disabled.")
        # Still try API
        rss_ids = []

    # Get ALL existing videos for this source (pending, complete, failed)
    all_entries = get_entries_for_source(channel_url)
    all_video_ids = {vid for vid, _, _ in all_entries}
    print(f"[source] {len(all_video_ids)} total videos in database")

    # Step 2: Gap detection
    last_enum = existing.get("last_full_enumeration")

    # Gap detection: if RSS shows videos that don't exist in our database
    gap_detected = False
    if rss_ids:
        gap_detected = detect_gap(rss_ids, all_video_ids)
        # Log gap detection result
        log_action("gap_detection", {
            "channel_url": channel_url,
            "rss_count": len(rss_ids),
            "db_count": len(all_video_ids),
            "gap_detected": gap_detected,
        })

    if gap_detected:
        log_user_message(f"Gap detected. Running API gap resolution...")
        # Use publishedAfter = last_full_enumeration or epoch
        published_after = last_enum if last_enum else "1970-01-01T00:00:00Z"
        gap_videos = enumerate_recent(playlist_id, published_after=published_after)
        log_action("api_gap_resolution", {
            "channel_url": channel_url,
            "videos_found": len(gap_videos),
            "published_after": published_after,
        })
        print(f"[source] API gap resolution found {len(gap_videos)} videos")

        # Fetch real video count from API since we're making API calls anyway
        real_video_count = get_video_count(channel_id)
        if real_video_count:
            log_action("api_video_count", {
                "channel_url": channel_url,
                "real_count": real_video_count,
            })
            print(f"[source] Real video count from API: {real_video_count}")

        # O(1) batch insert + O(1) batch pre-filter (avoids N individual is_complete calls)
        gap_video_ids = [v["video_id"] for v in gap_videos]
        gap_status_map = get_status_batch(gap_video_ids)
        complete_ids = {vid for vid, status in gap_status_map.items() if status == "complete"}
        entries = [
            BatchEntry(
                video_id=video["video_id"],
                status="pending",
                source=channel_url,
                published_at=video.get("published_at"),
                has_captions=video.get("has_captions"),
                title=video.get("title"),
                description=video.get("description"),
                channel_id=video.get("channel_id"),
                thumbnail=video.get("thumbnail"),
                duration=video.get("duration"),
                privacy_status=video.get("privacy_status"),
                upload_status=video.get("upload_status"),
                is_live_content=video.get("is_live_content"),
                unavailable_reason=video.get("unavailable_reason"),
            )
            for video in gap_videos
            if video["video_id"] not in complete_ids
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

        log_action("gap_resolution_complete", {
            "channel_url": channel_url,
            "new_videos": new_count,
            "real_video_count": real_video_count,
        })
        print(f"[source] Marked {new_count} new videos as pending")

    elif rss_ids:
        # Normal RSS processing - only add videos that aren't in database at all
        rss_ids_set = set(rss_ids)
        new_videos = rss_ids_set - all_video_ids  # Only truly new videos
        entries = [
            BatchEntry(
                video_id=vid,
                status="pending",
                source=channel_url,
                published_at=None,
                has_captions=None,
            )
            for vid in new_videos
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

        log_action("rss_processing", {
            "channel_url": channel_url,
            "rss_returned": len(rss_ids),
            "db_videos": len(all_video_ids),
            "new_videos": new_count,
        })
        print(f"[source] Marked {new_count} new RSS videos as pending")

        # Increment video_count_estimate by the number of new videos found
        current_count = existing.get("video_count_estimate", 0)
        if new_count > 0 and current_count is not None:
            upsert_channel(channel_url, video_count_estimate=current_count + new_count)

    # Update last_checked and optionally real video count from API
    now = datetime.now(timezone.utc).isoformat()
    if 'real_video_count' in locals() and real_video_count:
        upsert_channel(channel_url, last_checked=now, video_count_estimate=real_video_count)
    else:
        upsert_channel(channel_url, last_checked=now)

    print(f"[source] Check complete.")


def _process_channel_check(
    channel_url: str,
    playlist_id: str | None,
    video_count: int | None,
    last_checked: str | None,
    verbose: bool = False,
) -> tuple[int, int]:
    """Helper for parallel channel checks. Returns (new_videos_count, total_videos_count)."""
    if not playlist_id:
        if verbose:
            print(f"[source] Skipping {channel_url} — no playlist_id")
        return 0, 0

    # Step 1: Resolve to UC channel ID if needed
    channel_id = parse_channel_url(channel_url)
    if not channel_id:
        if verbose:
            print(f"[source] Skipping {channel_url} — could not parse channel ID")
        return 0, 0

    # Resolve @handle, c/custom, user/ URLs to UC channel ID
    if not channel_id.startswith("UC"):
        uc_channel_id = resolve_to_uc_channel_id(channel_id)
        if not uc_channel_id:
            if verbose:
                print(f"[source] Skipping {channel_url} — could not resolve to UC channel ID")
            return 0, 0
        channel_id = uc_channel_id

    # Step 2: RSS check
    rss_ids = check_rss(channel_id)
    if verbose:
        print(f"[source] RSS for {channel_url} returned {len(rss_ids)} recent videos")

    # Get ALL existing videos for this source
    all_entries = get_entries_for_source(channel_url)
    all_video_ids = {vid for vid, _, _ in all_entries}

    # Step 3: Gap detection
    gap_detected = False
    if rss_ids:
        gap_detected = detect_gap(rss_ids, all_video_ids)
    else:
        # If RSS is empty, trigger a "Deep Discovery" check via playlistItems API
        # as a safety fallback. This prevents missing videos when RSS is disabled/broken.
        gap_detected = True
        if verbose:
            print(f"[source] RSS empty for {channel_url} — triggering Deep Discovery fallback")

    new_count = 0
    real_video_count = None
    if gap_detected:
        if verbose:
            print(f"[source] Gap detected for {channel_url}. Running API gap resolution...")

        published_after = last_checked if last_checked else "1970-01-01T00:00:00Z"
        # Phase 2 Optimization: Use enumerate_full_playlist for "Deep Discovery"
        # if the last check was more than 7 days ago, ensuring no "Deep Gaps".
        is_deep_check = False
        if last_checked:
            last_dt = datetime.fromisoformat(last_checked.replace("Z", "+00:00"))
            if (datetime.now(timezone.utc) - last_dt).days > 7:
                is_deep_check = True

        if is_deep_check:
            if verbose:
                print(f"[source] Deep check (>7 days) — enumerating full playlist for {channel_url}")
            gap_videos = enumerate_full_playlist(playlist_id)
        else:
            gap_videos = enumerate_recent(playlist_id, published_after=published_after)

        # Fetch real video count from API
        channel_id_for_count = parse_channel_url(channel_url)
        if channel_id_for_count:
            real_video_count = get_video_count(channel_id_for_count)

        gap_video_ids = [v["video_id"] for v in gap_videos]
        gap_status_map = get_status_batch(gap_video_ids)
        complete_ids = {vid for vid, status in gap_status_map.items() if status == "complete"}
        entries = [
            BatchEntry(
                video_id=video["video_id"],
                status="pending",
                source=channel_url,
                published_at=video.get("published_at"),
                has_captions=video.get("has_captions"),
                title=video.get("title"),
                description=video.get("description"),
                channel_id=video.get("channel_id"),
                thumbnail=video.get("thumbnail"),
                duration=video.get("duration"),
                privacy_status=video.get("privacy_status"),
                upload_status=video.get("upload_status"),
                is_live_content=video.get("is_live_content"),
                unavailable_reason=video.get("unavailable_reason"),
            )
            for video in gap_videos
            if video["video_id"] not in complete_ids
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

    elif rss_ids:
        # Normal RSS processing
        rss_ids_set = set(rss_ids)
        new_videos = rss_ids_set - all_video_ids
        entries = [
            BatchEntry(
                video_id=vid,
                status="pending",
                source=channel_url,
                published_at=None,
                has_captions=None,
            )
            for vid in new_videos
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

    # Update last_checked
    now = datetime.now(timezone.utc).isoformat()
    if real_video_count:
        upsert_channel(channel_url, last_checked=now, video_count_estimate=real_video_count)
    else:
        upsert_channel(channel_url, last_checked=now)

    total_current = len(all_video_ids) + new_count
    return new_count, total_current


def cmd_check_all(verbose: bool = False) -> None:
    """Run RSS + gap detection check on ALL tracked channels in parallel.

    Iterates through all channels in channel_metadata table, runs check
    on each one in parallel using ThreadPoolExecutor.
    """
    from concurrent.futures import FIRST_COMPLETED, ThreadPoolExecutor, as_completed, wait
    from csf.batch_status import _get_batch_status_storage

    scan_started_at = time.monotonic()
    scan_last_status_at = scan_started_at
    scan_status_interval_s = float(os.getenv("YTIS_SCAN_STATUS_INTERVAL_S") or os.getenv("YTIS_FETCH_STATUS_INTERVAL_S") or 30.0)

    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    cursor = conn.execute(
        "SELECT channel_url, playlist_id, video_count_estimate, last_checked FROM channel_metadata ORDER BY last_checked ASC"
    )
    rows = cursor.fetchall()
    conn.close()

    if not rows:
        print("[source] No tracked channels. Use 'add' to add channels first.")
        return

    print(f"[source] Checking {len(rows)} tracked channels (Parallel Discovery)...")

    total_new_videos = 0
    total_videos_all = 0
    completed_channels = 0

    def _emit_check_status(trigger: str) -> None:
        nonlocal scan_last_status_at
        elapsed_s = round(time.monotonic() - scan_started_at, 3)
        scan_last_status_at = time.monotonic()
        print(
            "[source] Sync status: "
            f"{completed_channels}/{len(rows)} channels complete, "
            f"new={total_new_videos}, total={total_videos_all}, "
            f"elapsed={elapsed_s}s, trigger={trigger}"
        )
        log_action(
            "sync_scan_progress",
            {
                "channels_total": len(rows),
                "channels_completed": completed_channels,
                "new_videos": total_new_videos,
                "total_videos": total_videos_all,
                "elapsed_s": elapsed_s,
                "trigger": trigger,
            },
        )

    # Parallel discovery using 5 workers (conservative to avoid YouTube API thundering herd)
    with ThreadPoolExecutor(max_workers=5) as executor:
        futures = {
            executor.submit(_process_channel_check, url, pl, count, last, verbose): url
            for url, pl, count, last in rows
        }

        for future in as_completed(futures):
            try:
                new_vids, total_vids = future.result()
                total_new_videos += new_vids
                total_videos_all += total_vids
            except Exception as e:
                url = futures[future]
                print(f"[source] Error checking {url}: {e}")
            completed_channels += 1
            elapsed_since_status = time.monotonic() - scan_last_status_at
            if completed_channels == len(rows):
                _emit_check_status("final_channel")
            elif completed_channels == 1:
                _emit_check_status("first_channel")
            elif elapsed_since_status >= scan_status_interval_s:
                _emit_check_status("elapsed_interval")
            elif completed_channels % max(1, len(rows) // 10) == 0:
                _emit_check_status("channel_checkpoint")

    # Print summary and stats
    print(f"\n[source] Discovery complete. Found {total_new_videos} new videos across {len(rows)} channels.")

    # Print summary stats
    print("")  # blank line before results

    # Print legend
    print("Legend:")
    print("  total  = all videos tracked")
    print("  valid  = videos with captions (downloadable)")
    print("  mt     = main trackable (could have transcripts)")
    print("  dt     = downloaded (cached transcripts)")
    print("  vt     = available for download (has captions, not cached)")
    print("  na     = unavailable (no captions or failed)")
    print("")

    # Re-query to get updated statistics
    conn = storage._get_conn()
    cursor = conn.execute(
        "SELECT channel_url, video_count_estimate, category FROM channel_metadata ORDER BY CASE WHEN category IS NULL THEN 1 ELSE 0 END, category, last_checked ASC"
    )
    channels_meta = cursor.fetchall()
    conn.close()

    total_videos_all = 0
    current_category = None

    # Query transcript cache
    try:
        from csf.cache import has_cached_transcript

        for channel_url, video_count, category in channels_meta:
            # Print category header when group changes
            if category != current_category:
                current_category = category
                cat_display = category or "(uncategorized)"
                print(f"\n### {cat_display}")
                print("")
            batch_conn = storage._get_conn()
            batch_cursor = batch_conn.execute(
                """SELECT status, has_captions, unavailable_reason, COUNT(*)
                   FROM analysis_status WHERE source=?
                   GROUP BY status, has_captions, unavailable_reason""",
                (channel_url,)
            )
            status_counts = batch_cursor.fetchall()
            batch_conn.close()

            complete = sum(count for status, has_capt, _, count in status_counts if status == "complete")
            pending = sum(count for status, has_capt, _, count in status_counts if status == "pending")
            failed = sum(count for status, has_capt, _, count in status_counts if status == "failed")
            # has_subs = videos where has_captions is set (1 or True), regardless of value
            has_subs = sum(count for status, has_capt, _, count in status_counts if has_capt is not None)
            no_subs = sum(count for status, has_capt, _, count in status_counts if has_capt is None)

            # Count cached transcripts using has_cached_transcript
            all_video_ids = [vid for vid, _, _ in get_entries_for_source(channel_url)]
            cached = sum(1 for vid in all_video_ids if has_cached_transcript(vid))

            # Use actual database count instead of stale estimate
            total = len(all_video_ids)
            total_videos_all += total
            dt = cached  # downloaded transcripts

            # valid = potentially downloadable (total - unavailable - pending)
            # Use set-based total to avoid double-counting from GROUP BY
            # (a video with has_capt=0 AND unavailable_reason='member_only' would
            # appear in multiple groups, inflating the count if summed directly)
            unavailable = failed
            valid = max(0, total - unavailable)

            # vt = videos available on YouTube (has subs) but not yet downloaded
            # Include: pending with known subs (has_capt=1) + never checked (has_capt=NULL)
            pending_with_subs = sum(count for status, has_capt, _, count in status_counts if status == "pending" and has_capt == 1)
            pending_unknown = sum(count for status, has_capt, _, count in status_counts if status == "pending" and has_capt is None)
            vt = pending_with_subs + pending_unknown  # available to try

            # na = unavailable = failed videos (attempted and no captions)
            na = failed

            # mt = main trackable = total - unavailable
            mt = valid

            stats_line = f"{total:>4} total, {valid:>4} valid, {mt:>4} mt, {dt:>3} dt | +{vt:>3} vt, +{na:>3} na"

            # Fix URL format for @handles (remove /channel/ if present)
            display_url = channel_url
            if "/channel/@" in display_url:
                display_url = display_url.replace("/channel/@", "/@")

            # Print channel URL and stats on same line
            print(f"{display_url}  {stats_line}")
            print("")

    except Exception as e:
        # If transcript cache query fails, show simpler format
        print(f"[source] Error querying transcript cache: {e}")
        for channel_url, video_count in channels_meta:
            print(f"Channel: {channel_url}")
            print(f"  {video_count or 0} total")
            print("")

    # Print summary (total_videos_all is calculated above from actual database counts)
    print(f"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print(f"Summary: {len(channels_meta)} channels | {total_new_videos} new | {total_videos_all} total videos")


def cmd_categorize(workers: int = 1) -> None:
    """Categorize all channels using Gemini CLI (idempotent — skips if already categorized)."""
    from concurrent.futures import FIRST_COMPLETED, ThreadPoolExecutor, as_completed, wait
    from csf.batch_status import _get_batch_status_storage
    from csf.categorize import categorize_channel

    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    cursor = conn.execute(
        "SELECT channel_url, channel_title, description FROM channel_metadata WHERE category IS NULL"
    )
    rows = cursor.fetchall()
    conn.close()

    if not rows:
        print("[source] All channels already categorized.")
        return

    print(f"[source] Categorizing {len(rows)} uncategorized channels (workers={workers})...")

    def _categorize_one(url: str, title: str, desc: str) -> tuple[str, str | None]:
        cat = categorize_channel(title or "", desc or "")
        if cat:
            upsert_channel(url, category=cat)
        return url, cat

    total = 0
    with ThreadPoolExecutor(max_workers=workers) as executor:
        futures = {executor.submit(_categorize_one, url, title, desc): url for url, title, desc in rows}
        for future in as_completed(futures):
            url, cat = future.result()
            total += 1
            if total % 50 == 0:
                print(f"[source] ... categorized {total}/{len(rows)}")

    categorized = sum(1 for _, c in [(f.result()) for f in futures] if c)
    print(f"[source] Done. Categorized {categorized}/{len(rows)} channels.")


def cmd_sync(source_id_or_url: str) -> None:
    """Process all pending videos for a source via batch."""
    # Find the source
    existing = get_channel_metadata(source_id_or_url)
    if existing:
        channel_url = source_id_or_url
    else:
        parsed = parse_channel_url(source_id_or_url)
        if parsed and parsed.startswith("UC"):
            channel_url = f"https://www.youtube.com/channel/{parsed}"
            existing = get_channel_metadata(channel_url)
        else:
            channel_url = None

    if not existing:
        print(f"[source] Error: {source_id_or_url} is not a tracked source.", file=sys.stderr)
        sys.exit(1)

    # Inter-process lock to prevent concurrent sync on same source
    # acquire() with timeout=60 prevents indefinite blocking if process crashes while holding lock
    lock_name = channel_url.replace("https://www.youtube.com/", "").replace("/", "_")
    lock = fasteners.InterProcessLock(_LOCK_DIR / f"{lock_name}.lock")

    acquired = lock.acquire(blocking=True, timeout=60)
    if not acquired:
        print(f"[source] Error: Could not acquire lock for {channel_url} within 60s", file=sys.stderr)
        print(f"[source] Another sync may be running. Try again later.", file=sys.stderr)
        sys.exit(1)
    try:
        pending_ids = get_pending_by_source(channel_url)
        if not pending_ids:
            print(f"[source] No pending videos for {channel_url}")
            return

        print(f"[source] Processing {len(pending_ids)} pending videos for {channel_url}...")

        successful, failed = batch.analyze_videos_round_robin(
            pending_ids, channel_url=channel_url
        )
    finally:
        lock.release()

    print(f"[source] Sync complete: {len(successful)} successful, {len(failed)} failed")
    if failed:
        print(f"[source] Failed video IDs: {', '.join(failed)}")


def cmd_fetch(
    source_filter: str | None = None,
    dry_run: bool = False,
    workers: int = 1,
    max_items: int | None = None,
) -> None:
    """Fetch transcripts for pending videos using escalation chain (yt-dlp → Selenium).

    This is the ESCALATION BATCH PROCESS - tries fastest methods first, falls back
    to slower but more reliable methods.

    Args:
        source_filter: Optional channel URL to process only that source.
        dry_run: If True, show what would be fetched without actually fetching.
        workers: Number of parallel workers (default: 1).
        max_items: Optional cap on pending items to process in this run.
    """
    from concurrent.futures import FIRST_COMPLETED, ThreadPoolExecutor, as_completed, wait
    from csf.transcript import fetch_transcript_chain, LanguageConfig

    fetch_started_at = time.monotonic()
    industrial_first_worker_finished_at: float | None = None
    industrial_last_worker_finished_at: float | None = None
    industrial_completion_stall_alert_logged = False
    industrial_oversized_dispatch_alert_logged = False
    def _env_int(primary: str, fallback: str, default: int) -> int:
        value = os.getenv(primary)
        if value is None or not value.strip():
            value = os.getenv(fallback)
        return int(value or default)

    def _env_float(primary: str, fallback: str, default: float) -> float:
        value = os.getenv(primary)
        if value is None or not value.strip():
            value = os.getenv(fallback)
        return float(value or default)

    def _env_bool(primary: str, fallback: str | None, default: bool) -> bool:
        value = os.getenv(primary)
        if value is None or not value.strip():
            value = os.getenv(fallback) if fallback else None
        if value is None or not str(value).strip():
            return default
        return str(value).strip().lower() in {"1", "true", "yes", "on"}

    route_no_captions_to_fallback = _env_bool(
        "YTIS_ROUTE_NO_CAPTIONS_TO_FALLBACK",
        "YTIS_TRANSCRIPT_ROUTE_NO_CAPTIONS_TO_FALLBACK",
        False,
    )

    log_action(
        "fetch_invoked",
        {
            "source_filter": source_filter,
            "dry_run": dry_run,
            "workers": workers,
            "max_items": max_items,
            "transcript_fallback_workers": max(
                1,
                min(
                    workers,
                    _env_int("YTIS_TRANSCRIPT_FALLBACK_WORKERS", "YTIS_AUDIO_FALLBACK_WORKERS", workers),
                ),
            ),
            "transcript_fallback_min_start_interval_s": _env_float(
                "YTIS_TRANSCRIPT_FALLBACK_MIN_START_INTERVAL_S",
                "YTIS_AUDIO_FALLBACK_MIN_START_INTERVAL_S",
                2.5,
            ),
            "industrial_batches_per_worker": max(
                1,
                _env_int("YTIS_INDUSTRIAL_BATCHES_PER_WORKER", "YTIS_INDUSTRIAL_BATCHES_PER_LAUNCH", 4),
            ),
            "route_no_captions_to_fallback": route_no_captions_to_fallback,
        },
    )
    first_download_logged = False

    def _log_first_download_started(kind: str, **details) -> None:
        nonlocal first_download_logged
        if first_download_logged:
            return
        first_download_logged = True
        payload = {
            "kind": kind,
            "elapsed_s": round(time.monotonic() - fetch_started_at, 3),
        }
        payload.update(details)
        log_action("first_download_started", payload)

    def _log_worker_health_warning(reason: str, **details) -> None:
        log_action(
            "fetch_worker_health_warning",
            _build_worker_health_warning(
                reason=reason,
                elapsed_s=time.monotonic() - fetch_started_at,
                active_workers=len(industrial_worker_futures),
                queued_batches=len(industrial_batch_queue),
                available_slots=max(0, workers - len(industrial_worker_futures)),
                first_worker_finished_at=industrial_first_worker_finished_at,
                last_worker_finished_at=industrial_last_worker_finished_at,
                **details,
            ),
        )

    storage = _get_batch_status_storage()

    # Get all channels or specific channel
    if source_filter:
        existing = get_channel_metadata(source_filter)
        if not existing:
            print(f"[source] Error: {source_filter} is not a tracked source.", file=sys.stderr)
            sys.exit(1)
        tracked_channels = [(source_filter, existing.get("playlist_id"))]
    else:
        conn = storage._get_conn()
        cursor = conn.execute("SELECT channel_url, playlist_id FROM channel_metadata")
        tracked_channels = cursor.fetchall()
        conn.close()

    if not tracked_channels:
        print("[source] No tracked channels found.")
        return

    channels: list[tuple[str, str]] = []
    blocked_count = 0
    for channel_url, playlist_id in tracked_channels:
        if is_channel_blocked(channel_url):
            blocked_count += 1
            continue
        if not playlist_id:
            continue
        channels.append((channel_url, playlist_id))

    if not channels:
        print("[source] No unblocked tracked channels found.")
        return

    # Collect pending videos across channels. We stream the active backlog into
    # a queue so industrial batches can start as soon as there is enough work.
    pending_buffer: deque[tuple[str, str]] = deque()  # (video_id, source_url)
    cached_count = 0
    cached_sample = []
    pending_discovered_total = 0
    scan_started_at = time.monotonic()
    tracked_count = len(tracked_channels)
    channel_count = len(channels)
    scan_progress_interval = max(1, channel_count // 10)
    scan_status_interval_s = float(_env_float("YTIS_SCAN_STATUS_INTERVAL_S", "YTIS_FETCH_STATUS_INTERVAL_S", 30.0))
    scan_last_status_at = scan_started_at
    batch_size = DEFAULT_NOTEBOOKLM_BATCH_SIZE
    backlog_threshold = max(
        1,
        _env_int("YTIS_INDUSTRIAL_BACKLOG_THRESHOLD", "YTIS_FETCH_BACKLOG_THRESHOLD", 50),
    )
    if max_items is not None and max_items < 0:
        raise ValueError("max_items must be >= 0")
    industrial_selected = False
    max_items_reached = False
    industrial_scraper = None
    industrial_batches_processed = 0
    industrial_batch_queue: list[list[str]] = []
    industrial_worker_executor: ThreadPoolExecutor | None = None
    industrial_worker_futures: set = set()
    industrial_worker_slots_in_use: dict[object, int] = {}
    transcript_fallback_queue: deque[tuple[str, str, bool]] = deque()
    transcript_fallback_worker_executor: ThreadPoolExecutor | None = None
    transcript_fallback_worker_futures: set = set()
    transcript_fallback_worker_seq = 0
    transcript_fallback_workers = max(
        0,
        min(
            workers,
            _env_int("YTIS_TRANSCRIPT_FALLBACK_WORKERS", "YTIS_AUDIO_FALLBACK_WORKERS", workers),
        ),
    )
    os.environ.setdefault("YTIS_OEMBED_ENABLED", "1")
    transcript_fallback_min_start_interval_s = float(
        _env_float(
            "YTIS_TRANSCRIPT_FALLBACK_MIN_START_INTERVAL_S",
            "YTIS_AUDIO_FALLBACK_MIN_START_INTERVAL_S",
            2.5,
        )
    )
    industrial_batches_per_worker = max(
        1,
        _env_int("YTIS_INDUSTRIAL_BATCHES_PER_WORKER", "YTIS_INDUSTRIAL_BATCHES_PER_LAUNCH", 4),
    )
    transcript_fallback_start_lock = threading.Lock()
    transcript_fallback_last_start_at = 0.0
    industrial_parallel_enabled = workers > 1 and os.getenv(
        "YTIS_DISABLE_INDUSTRIAL_PARALLEL", ""
    ).strip().lower() not in {"1", "true", "yes", "on"}
    success_count = 0
    fail_count = 0
    skip_count = 0
    transcript_fallback_processed_count = 0
    terminal_count = 0
    negative_cache_count = 0
    notebooklm_pending_count = 0
    transcript_fallback_queued_count = 0
    startup_retire_elapsed_s_total = 0.0
    startup_notebook_check_elapsed_s_total = 0.0
    startup_notebook_create_elapsed_s_total = 0.0
    startup_prepare_cleanup_elapsed_s_total = 0.0
    startup_prepare_total_elapsed_s_total = 0.0
    setup_elapsed_s_total = 0.0
    notebook_check_elapsed_s_total = 0.0
    notebook_create_elapsed_s_total = 0.0
    notebook_retire_elapsed_s_total = 0.0
    add_sources_elapsed_s_total = 0.0
    content_fetch_status_counts_total: Counter[str] = Counter()
    source_ready_age_s_total = 0.0
    source_ready_age_s_max = 0.0
    source_ready_age_s_avg = 0.0
    youtube_ytdlp_elapsed_s_total = 0.0
    youtube_ytdlp_elapsed_s_max = 0.0
    youtube_ytdlp_elapsed_s_count = 0
    youtube_ytdlp_elapsed_s_avg = 0.0
    youtube_page_elapsed_s_total = 0.0
    youtube_page_elapsed_s_max = 0.0
    youtube_page_elapsed_s_count = 0
    youtube_page_elapsed_s_avg = 0.0
    extract_elapsed_s_total = 0.0
    cleanup_elapsed_s_total = 0.0
    batch_elapsed_s_total = 0.0
    shared_retry_deferred_count_total = 0.0
    shared_retry_recovered_count_total = 0.0
    shared_retry_final_failed_count_total = 0.0
    shared_retry_processed_count_total = 0.0
    industrial_source_profile_totals = _empty_source_profile_totals()
    terminal_entries: list[BatchEntry] = []
    terminal_sample: list[dict[str, object]] = []
    terminal_reason_counts: Counter[str] = Counter()
    negative_cache_reason_counts: Counter[str] = Counter()
    negative_cache_sample: list[dict[str, object]] = []

    def _terminal_failure_reason(entry: dict[str, object | None]) -> str | None:
        unavailable_reason = str(entry.get("unavailable_reason") or "").strip().lower()
        privacy_status = str(entry.get("privacy_status") or "").strip().lower()
        upload_status = str(entry.get("upload_status") or "").strip().lower()

        if unavailable_reason in {"deleted", "removed", "private"}:
            return unavailable_reason
        if privacy_status == "private":
            return "private"
        if upload_status in {"deleted", "failed"}:
            return upload_status
        return None

    def _classify_pending_entry(entry: dict[str, object | None]) -> tuple[str, str | None]:
        terminal_reason = _terminal_failure_reason(entry)
        if terminal_reason:
            return "terminal", terminal_reason
        is_live_content = bool(entry.get("is_live_content"))
        upload_status = str(entry.get("upload_status") or "").strip().lower()
        if is_live_content or upload_status in {"live", "live_stream", "premiere"}:
            return "transcript_fallback", "live"
        has_captions = entry.get("has_captions")
        if has_captions in (True, 1):
            return "notebooklm", "captioned"
        if has_captions in (False, 0):
            if route_no_captions_to_fallback:
                return "transcript_fallback", "no_captions"
            return "notebooklm", "no_captions"
        return "notebooklm", "unknown"

    log_action(
        "fetch_scan_started",
        {
            "source_filter": source_filter,
            "channels_tracked_total": tracked_count,
            "channels_blocked_total": blocked_count,
            "channels_active_total": channel_count,
            "progress_interval": scan_progress_interval,
        },
    )
    print(
        f"[source] Preflight scan: checking {channel_count} active channels "
        f"({blocked_count} blocked skipped) for pending videos..."
    )

    def _emit_scan_status(channel_index: int, trigger: str) -> None:
        nonlocal scan_last_status_at
        elapsed_s = round(time.monotonic() - scan_started_at, 3)
        scan_last_status_at = time.monotonic()
        print(
            "[source] Scan status: "
            f"{channel_index}/{channel_count} channels, "
            f"pending={pending_discovered_total}, cached={cached_count}, "
            f"neg_cache={negative_cache_count}, terminal={terminal_count}, "
            f"notebooklm={notebooklm_pending_count}, fallback={transcript_fallback_queued_count}, "
            f"elapsed={elapsed_s}s, trigger={trigger}"
        )
        log_action(
            "fetch_scan_progress",
            {
                "source_filter": source_filter,
                "channel_index": channel_index,
                "channels_active_total": channel_count,
                "pending_so_far": pending_discovered_total,
                "cached_total": cached_count,
                "negative_cache_count": negative_cache_count,
                "negative_cache_reason_counts": dict(negative_cache_reason_counts),
                "negative_cache_sample": negative_cache_sample,
                "terminal_count": terminal_count,
                "terminal_reason_counts": dict(terminal_reason_counts),
                "elapsed_s": elapsed_s,
                "trigger": trigger,
            },
        )

    def _ensure_industrial_scraper():
        nonlocal industrial_scraper
        if industrial_scraper is None:
            print("[source] Starting Industrial Ingest (NLM Selenium scraper)...")
            from csf.nlm_config import get_nlm_config
            from csf.nlm_scraper import NLMIndustrialScraper

            industrial_scraper = NLMIndustrialScraper(headless=False, browser_cfg=get_nlm_config())
            browser_cleanup = getattr(industrial_scraper, "preflight_browser_cleanup", None)
            if callable(browser_cleanup):
                browser_deleted, browser_failed = browser_cleanup()
                print(
                    f"[source] Pre-flight browser cleanup: {browser_deleted} terminated, "
                    f"{browser_failed} failed"
                )
            deleted, failed = industrial_scraper.preflight_cleanup()
            print(
                f"[source] Pre-flight: {deleted} orphaned notebooks cleared, {failed} unreachable"
            )
        return industrial_scraper

    def _split_batches_for_workers(batch_queue: list[list[str]], worker_count: int) -> list[list[list[str]]]:
        if worker_count < 1:
            raise ValueError("worker_count must be >= 1")
        if not batch_queue:
            return []
        effective_worker_count = min(worker_count, len(batch_queue))
        groups: list[list[list[str]]] = [[] for _ in range(effective_worker_count)]
        for idx, batch in enumerate(batch_queue):
            groups[idx % effective_worker_count].append(batch)
        return groups

    def _load_worker_summary(result_path: Path | None, stdout_text: str) -> dict[str, object]:
        summary: dict[str, object] = {}
        if result_path is not None and result_path.exists():
            try:
                summary = json.loads(result_path.read_text(encoding="utf-8"))
            except Exception:
                summary = {}
        if not summary and stdout_text:
            lines = stdout_text.rstrip().splitlines()
            if lines:
                try:
                    summary = json.loads(lines[-1])
                except Exception:
                    summary = {}
        return summary

    def _worker_stage_totals_from_summary(summary: dict[str, object]) -> dict[str, object]:
        return {
            "startup_retire_elapsed_s_total": float(summary.get("startup_retire_elapsed_s", 0) or 0.0),
            "startup_notebook_check_elapsed_s_total": float(summary.get("startup_notebook_check_elapsed_s", 0) or 0.0),
            "startup_notebook_create_elapsed_s_total": float(summary.get("startup_notebook_create_elapsed_s", 0) or 0.0),
            "startup_prepare_cleanup_elapsed_s_total": float(summary.get("startup_prepare_cleanup_elapsed_s", 0) or 0.0),
            "startup_prepare_total_elapsed_s_total": float(summary.get("startup_prepare_total_elapsed_s", 0) or 0.0),
            "setup_elapsed_s_total": float(summary.get("setup_elapsed_s_total", 0) or 0.0),
            "notebook_check_elapsed_s_total": float(summary.get("notebook_check_elapsed_s_total", 0) or 0.0),
            "notebook_create_elapsed_s_total": float(summary.get("notebook_create_elapsed_s_total", 0) or 0.0),
            "notebook_retire_elapsed_s_total": float(summary.get("notebook_retire_elapsed_s_total", 0) or 0.0),
            "add_sources_elapsed_s_total": float(summary.get("add_sources_elapsed_s_total", 0) or 0.0),
            "add_cmd_elapsed_s_total": float(summary.get("add_cmd_elapsed_s_total", 0) or 0.0),
            "materialization_wait_elapsed_s_total": float(summary.get("materialization_wait_elapsed_s_total", 0) or 0.0),
            "extract_elapsed_s_total": float(summary.get("extract_elapsed_s_total", 0) or 0.0),
            "cleanup_elapsed_s_total": float(summary.get("cleanup_elapsed_s_total", 0) or 0.0),
            "batch_elapsed_s_total": float(summary.get("batch_elapsed_s_total", 0) or 0.0),
            "content_fetch_status_counts_total": dict(summary.get("content_fetch_status_counts_total", {}) or {}),
            "source_ready_age_s_total": float(summary.get("source_ready_age_s_total", 0) or 0.0),
            "source_ready_age_s_max": float(summary.get("source_ready_age_s_max", 0) or 0.0),
            "source_ready_age_s_avg": float(summary.get("source_ready_age_s_avg", 0) or 0.0),
            "youtube_ytdlp_elapsed_s_total": float(summary.get("youtube_ytdlp_elapsed_s_total", 0) or 0.0),
            "youtube_ytdlp_elapsed_s_max": float(summary.get("youtube_ytdlp_elapsed_s_max", 0) or 0.0),
            "youtube_ytdlp_elapsed_s_count": int(summary.get("youtube_ytdlp_elapsed_s_count", 0) or 0),
            "youtube_ytdlp_elapsed_s_avg": float(summary.get("youtube_ytdlp_elapsed_s_avg", 0) or 0.0),
            "youtube_page_elapsed_s_total": float(summary.get("youtube_page_elapsed_s_total", 0) or 0.0),
            "youtube_page_elapsed_s_max": float(summary.get("youtube_page_elapsed_s_max", 0) or 0.0),
            "youtube_page_elapsed_s_count": int(summary.get("youtube_page_elapsed_s_count", 0) or 0),
            "youtube_page_elapsed_s_avg": float(summary.get("youtube_page_elapsed_s_avg", 0) or 0.0),
            "shared_retry_deferred_count_total": float(summary.get("shared_retry_deferred_count", 0) or 0.0),
            "shared_retry_recovered_count_total": float(summary.get("shared_retry_recovered_count", 0) or 0.0),
            "shared_retry_final_failed_count_total": float(summary.get("shared_retry_final_failed_count", 0) or 0.0),
            "shared_retry_processed_count_total": float(summary.get("shared_retry_processed_count", 0) or 0.0),
        }

    def _add_worker_stage_totals(summary: dict[str, object]) -> None:
        nonlocal startup_retire_elapsed_s_total
        nonlocal startup_notebook_check_elapsed_s_total
        nonlocal startup_notebook_create_elapsed_s_total
        nonlocal startup_prepare_cleanup_elapsed_s_total
        nonlocal startup_prepare_total_elapsed_s_total
        nonlocal setup_elapsed_s_total
        nonlocal notebook_check_elapsed_s_total
        nonlocal notebook_create_elapsed_s_total
        nonlocal notebook_retire_elapsed_s_total
        nonlocal add_sources_elapsed_s_total
        nonlocal content_fetch_status_counts_total
        nonlocal source_ready_age_s_total
        nonlocal source_ready_age_s_max
        nonlocal source_ready_age_s_avg
        nonlocal youtube_ytdlp_elapsed_s_total
        nonlocal youtube_ytdlp_elapsed_s_max
        nonlocal youtube_ytdlp_elapsed_s_count
        nonlocal youtube_ytdlp_elapsed_s_avg
        nonlocal youtube_page_elapsed_s_total
        nonlocal youtube_page_elapsed_s_max
        nonlocal youtube_page_elapsed_s_count
        nonlocal youtube_page_elapsed_s_avg
        nonlocal extract_elapsed_s_total
        nonlocal cleanup_elapsed_s_total
        nonlocal batch_elapsed_s_total
        nonlocal shared_retry_deferred_count_total
        nonlocal shared_retry_recovered_count_total
        nonlocal shared_retry_final_failed_count_total
        nonlocal shared_retry_processed_count_total
        nonlocal industrial_source_profile_totals
        startup_retire_elapsed_s_total += float(summary.get("startup_retire_elapsed_s", 0) or 0.0)
        startup_notebook_check_elapsed_s_total += float(summary.get("startup_notebook_check_elapsed_s", 0) or 0.0)
        startup_notebook_create_elapsed_s_total += float(summary.get("startup_notebook_create_elapsed_s", 0) or 0.0)
        startup_prepare_cleanup_elapsed_s_total += float(summary.get("startup_prepare_cleanup_elapsed_s", 0) or 0.0)
        startup_prepare_total_elapsed_s_total += float(summary.get("startup_prepare_total_elapsed_s", 0) or 0.0)
        setup_elapsed_s_total += float(summary.get("setup_elapsed_s_total", 0) or 0.0)
        notebook_check_elapsed_s_total += float(summary.get("notebook_check_elapsed_s_total", 0) or 0.0)
        notebook_create_elapsed_s_total += float(summary.get("notebook_create_elapsed_s_total", 0) or 0.0)
        notebook_retire_elapsed_s_total += float(summary.get("notebook_retire_elapsed_s_total", 0) or 0.0)
        add_sources_elapsed_s_total += float(summary.get("add_sources_elapsed_s_total", 0) or 0.0)
        # Split add timing is informative, but the aggregate add bucket remains the
        # primary accounting field for now.
        content_fetch_status_counts_total.update(summary.get("content_fetch_status_counts_total", {}) or {})
        source_ready_age_s_total += float(summary.get("source_ready_age_s_total", 0) or 0.0)
        source_ready_age_s_max = max(source_ready_age_s_max, float(summary.get("source_ready_age_s_max", 0) or 0.0))
        source_ready_age_s_avg = max(source_ready_age_s_avg, float(summary.get("source_ready_age_s_avg", 0) or 0.0))
        youtube_ytdlp_elapsed_s_total += float(summary.get("youtube_ytdlp_elapsed_s_total", 0) or 0.0)
        youtube_ytdlp_elapsed_s_max = max(youtube_ytdlp_elapsed_s_max, float(summary.get("youtube_ytdlp_elapsed_s_max", 0) or 0.0))
        youtube_ytdlp_elapsed_s_count += int(summary.get("youtube_ytdlp_elapsed_s_count", 0) or 0)
        youtube_ytdlp_elapsed_s_avg = max(youtube_ytdlp_elapsed_s_avg, float(summary.get("youtube_ytdlp_elapsed_s_avg", 0) or 0.0))
        youtube_page_elapsed_s_total += float(summary.get("youtube_page_elapsed_s_total", 0) or 0.0)
        youtube_page_elapsed_s_max = max(youtube_page_elapsed_s_max, float(summary.get("youtube_page_elapsed_s_max", 0) or 0.0))
        youtube_page_elapsed_s_count += int(summary.get("youtube_page_elapsed_s_count", 0) or 0)
        youtube_page_elapsed_s_avg = max(youtube_page_elapsed_s_avg, float(summary.get("youtube_page_elapsed_s_avg", 0) or 0.0))
        extract_elapsed_s_total += float(summary.get("extract_elapsed_s_total", 0) or 0.0)
        cleanup_elapsed_s_total += float(summary.get("cleanup_elapsed_s_total", 0) or 0.0)
        batch_elapsed_s_total += float(summary.get("batch_elapsed_s_total", 0) or 0.0)
        shared_retry_deferred_count_total += float(summary.get("shared_retry_deferred_count", 0) or 0.0)
        shared_retry_recovered_count_total += float(summary.get("shared_retry_recovered_count", 0) or 0.0)
        shared_retry_final_failed_count_total += float(summary.get("shared_retry_final_failed_count", 0) or 0.0)
        shared_retry_processed_count_total += float(summary.get("shared_retry_processed_count", 0) or 0.0)
        _merge_source_profile_totals(industrial_source_profile_totals, summary.get("source_profile"))

    def _build_worker_stage_totals_payload() -> dict[str, object]:
        return {
            "startup_retire_elapsed_s_total": startup_retire_elapsed_s_total,
            "startup_notebook_check_elapsed_s_total": startup_notebook_check_elapsed_s_total,
            "startup_notebook_create_elapsed_s_total": startup_notebook_create_elapsed_s_total,
