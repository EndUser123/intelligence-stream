1	#!/usr/bin/env python3
2	"""Quick alias for csf-transcript-fetch — download transcripts from YouTube.
3	
4	Usage:
5	    yt-batch-fetch                  # Dry run: show missing counts
6	    yt-batch-fetch --run            # Actually download transcripts
7	    yt-batch-fetch --channel <url>  # Process specific channel only
8	    yt-batch-fetch --workers N      # Parallel workers (default: 1)
9	"""
10	
11	import subprocess
12	import sys
13	from pathlib import Path
14	
15	# Run csf-transcript-fetch with same arguments
16	script_path = Path(__file__).parent / "csf-transcript-fetch"
17	result = subprocess.run([sys.executable, str(script_path)] + sys.argv[1:])
18	sys.exit(result.returncode)
19	