#!/usr/bin/env python3
"""Download missing transcripts for all tracked channels.

Uses the batch DB (populated by csf-source add/check) to get video list
and has_captions data, then parallel-fetches missing transcripts using the
youtube-transcript-api.

Usage:
    csf-transcript-fetch                  # Dry run: show missing counts
    csf-transcript-fetch --run            # Actually download transcripts
    csf-transcript-fetch --channel <url>  # Process specific channel only
    csf-transcript-fetch --workers N      # Parallel workers (default: 4)
"""

import argparse
import sys
import time
import random
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

# Add csf to path
sys.path.insert(0, str(Path(__file__).parent.parent))

from csf.batch_status import _get_batch_status_storage, get_entries_for_source
from csf.cache import has_cached_transcript, set_cached_transcript
from csf.transcript import fetch_transcript_chain, LanguageConfig


def _fetch_one_transcript(
    video_id: str, lang: str = "en"
) -> tuple[str, bool, str, str]:
    """Fetch transcript for a single video, cache it, return (video_id, success, source, error).

    Returns:
        video_id: The video ID
        ok: True if transcript was fetched, False otherwise
        source: Which source provided the transcript ('ytdlp', 'youtube_transcript_api',
                'youtubei', 'sdk', 'cli', 'whisper', 'none')
        error: Error message if failed, empty string if succeeded
    """
    config = LanguageConfig(prefer_lang=lang, allow_translation=False)
    result = fetch_transcript_chain(video_id, config)

    if result.transcript:
        # Cache the transcript
        set_cached_transcript(video_id, result.lang, result.source, result.transcript)
        return (video_id, True, result.source, "")
    else:
        error_msg = result.error or f"no transcript (source: {result.source or 'none'})"
        return (video_id, False, result.source or "none", error_msg)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Download missing transcripts for tracked YouTube channels."
    )
    parser.add_argument(
        "--run",
        action="store_true",
        help="Actually download transcripts (default is dry-run).",
    )
    parser.add_argument("--channel", help="Process only this channel URL.")
    parser.add_argument(
        "--workers",
        type=int,
        default=4,
        help="Number of parallel workers (default: 4).",
    )
    parser.add_argument(
        "--lang", default="en", help="Preferred language code (default: en)."
    )
    args = parser.parse_args()

    # Load .env for potential API keys
    from dotenv import load_dotenv

    load_dotenv("P:/.env")

    storage = _get_batch_status_storage()
    conn = storage._get_conn()
    cursor = conn.execute("SELECT channel_url, playlist_id FROM channel_metadata")
    channels = cursor.fetchall()
    conn.close()

    if args.channel:
        channels = [(u, p) for u, p in channels if args.channel in u]
        if not channels:
            print(f"Channel '{args.channel}' not found in tracked sources.")
            sys.exit(1)

    print("=== Transcript Fetcher ===")
    print(f"Channels: {len(channels)}")
    print(f"Mode: {'DRY RUN (use --run to download)' if not args.run else 'LIVE'}")
    print(f"Workers: {args.workers}")
    print()

    grand_total = 0
    grand_missing = 0

    for channel_url, playlist_id in channels:
        if not playlist_id:
            print(f"  [SKIP] {channel_url} — no playlist_id")
            continue

        print(f"Channel: {channel_url}")

        # Use batch DB for has_captions from YouTube Data API.
        #
        # IMPORTANT: contentDetails.caption=false from YouTube API only means no MANUAL
        # captions — auto-generated captions exist independently and youtube-transcript-api
        # can fetch them. So we attempt ALL pending videos regardless of has_captions.
        # The has_captions field is stored for visibility/analytics only.
        entries = get_entries_for_source(channel_url)

        if not args.run:
            # Dry run: count missing from DB
            missing = sum(1 for vid, _, _ in entries if not has_cached_transcript(vid))
            print(
                f"  Videos: {len(entries)}, Attempt fetch: {len(entries)}, "
                f"Already cached: {len(entries)-missing}, Missing: {missing}"
            )
            grand_total += len(entries)
            grand_missing += missing
        else:
            # Live run: download missing transcripts for all pending videos
            missing_ids = [vid for vid, _, _ in entries if not has_cached_transcript(vid)]
            print(
                f"  Videos: {len(entries)}, Has captions: {len(downloadable)}, "
                f"No captions (skipped): {captionless}, Already cached: {len(downloadable)-len(missing_ids)}, Missing: {len(missing_ids)}"
            )

            if not missing_ids:
                print("  All transcripts already cached.")
                grand_total += len(entries)
                grand_missing += 0
                continue

            print(
                f"  Downloading {len(missing_ids)} transcripts with {args.workers} workers..."
            )

            # Jitter to avoid thundering herd
            time.sleep(random.uniform(1.0, 3.0))

            success_count = 0
            fail_count = 0

            def progress(done: int, ok: int, fail: int) -> None:
                print(
                    f"    progress: done={done}/{len(missing_ids)}, ok={ok}, fail={fail}",
                    flush=True,
                )

            with ThreadPoolExecutor(max_workers=args.workers) as executor:
                futures = {
                    executor.submit(_fetch_one_transcript, vid, args.lang): vid
                    for vid in missing_ids
                }
                done = 0
                for future in as_completed(futures):
                    vid, ok, src, err = future.result()
                    done += 1
                    if ok:
                        success_count += 1
                    else:
                        fail_count += 1
                        print(f"    [FAIL] {vid}: {err}")
                    if done % 20 == 0 or done == len(missing_ids):
                        progress(done, success_count, fail_count)

            print(f"  Downloaded: {success_count} ok, {fail_count} failed")
            grand_total += len(entries)
            grand_missing += len(missing_ids)

    print()
    print("=== Summary ===")
    print(f"Total videos: {grand_total}")
    print(f"Missing transcripts: {grand_missing}")
    if args.run:
        print("(Transcripts are cached; re-running will show 0 missing)")


if __name__ == "__main__":
    main()
