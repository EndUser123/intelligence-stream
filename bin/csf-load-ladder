#!/usr/bin/env python3
"""Run a NotebookLM load ladder across the next benchmark scenarios."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

sys.path.insert(0, str(Path(__file__).parent.parent))

from csf.load_ladder import (
    build_fallback_benchmark_command,
    default_load_ladder_scenarios,
    scenario_by_name,
)


REPO_ROOT = Path(__file__).resolve().parents[1]
FALLBACK_BENCHMARK_SCRIPT = REPO_ROOT / "bin" / "csf-fallback-crossover-benchmark"
DEFAULT_OUTPUT_ROOT = REPO_ROOT / ".logs" / "load_ladder_benchmark"
DEFAULT_TRACE_ROOT = REPO_ROOT / ".logs" / "worker_count_trials"
DEFAULT_SOURCE_URL = "https://www.youtube.com/channel/UCYTISFALLBACKBMK"
DEFAULT_POLICY = "notebooklm_only_30s"


def _parse_scenario_list(value: str) -> list[str]:
    names = [item.strip() for item in value.split(",") if item.strip()]
    if not names:
        raise ValueError("at least one scenario is required")
    known = {scenario.name for scenario in default_load_ladder_scenarios()}
    unknown = [name for name in names if name not in known]
    if unknown:
        raise ValueError(f"unknown scenario name(s): {', '.join(sorted(unknown))}")
    return names


def _read_summary(path: Path) -> dict[str, Any]:
    if not path.exists():
        raise RuntimeError(f"missing benchmark summary: {path}")
    return json.loads(path.read_text(encoding="utf-8"))


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Run the NotebookLM benchmark load ladder")
    parser.add_argument(
        "--trace-root",
        type=Path,
        default=DEFAULT_TRACE_ROOT,
        help=f"Trace root to freeze the cohort from (default: {DEFAULT_TRACE_ROOT})",
    )
    parser.add_argument(
        "--cohort-json",
        type=Path,
        default=DEFAULT_OUTPUT_ROOT / "cohort.json",
        help="Path to the frozen cohort manifest",
    )
    parser.add_argument(
        "--output-root",
        type=Path,
        default=DEFAULT_OUTPUT_ROOT,
        help=f"Root directory for benchmark artifacts (default: {DEFAULT_OUTPUT_ROOT})",
    )
    parser.add_argument(
        "--source-url",
        default=DEFAULT_SOURCE_URL,
        help=f"Synthetic source URL used to seed the frozen cohort (default: {DEFAULT_SOURCE_URL})",
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=2,
        help="Worker count for each scenario run (default: 2)",
    )
    parser.add_argument(
        "--limit",
        type=int,
        default=10,
        help="Max items to include from the frozen cohort (default: 10)",
    )
    parser.add_argument(
        "--batch-size",
        type=int,
        default=10,
        help="Batch size for each benchmark slice (default: 10)",
    )
    parser.add_argument(
        "--policy",
        default=DEFAULT_POLICY,
        help=f"Fallback benchmark policy to run for each scenario (default: {DEFAULT_POLICY})",
    )
    parser.add_argument(
        "--cohort-shape",
        choices=("trace", "captioned", "mixed"),
        default="trace",
        help="Frozen cohort shape to benchmark (default: trace)",
    )
    parser.add_argument(
        "--sample-label",
        default=None,
        help="Optional sample label to stamp into the worker-count sweep summaries",
    )
    parser.add_argument(
        "--python",
        default=None,
        help="Python executable to use for csf-source (default: current interpreter)",
    )
    parser.add_argument(
        "--scenarios",
        default="baseline,fullness_25,fresh_state,reuse_state,staggered_off,staggered_on,rotation_75,route_no_captions_to_fallback",
        help="Comma-separated scenario names to run in order",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the commands that would run without executing them",
    )
    args = parser.parse_args(argv)

    scenario_names = _parse_scenario_list(args.scenarios)
    scenarios = [scenario_by_name(name) for name in scenario_names]

    args.output_root.mkdir(parents=True, exist_ok=True)
    shared_worker_state_root = args.output_root / "worker_states"

    combined: dict[str, Any] = {
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "trace_root": str(args.trace_root),
        "cohort_json": str(args.cohort_json),
        "source_url": args.source_url,
        "policy": args.policy,
        "cohort_shape": args.cohort_shape,
        "sample_label": args.sample_label or args.cohort_shape,
        "workers": args.workers,
        "limit": args.limit,
        "batch_size": args.batch_size,
        "scenario_names": scenario_names,
        "shared_worker_state_root": str(shared_worker_state_root),
        "scenarios": [],
    }

    for scenario in scenarios:
        scenario_output_root = args.output_root / scenario.name
        if not scenario.preserve_worker_state_root:
            shutil.rmtree(shared_worker_state_root, ignore_errors=True)

        command = build_fallback_benchmark_command(
            python_executable=args.python or sys.executable,
            fallback_benchmark_script=FALLBACK_BENCHMARK_SCRIPT,
            trace_root=args.trace_root,
            cohort_json=args.cohort_json,
            output_root=scenario_output_root,
            source_url=args.source_url,
            workers=args.workers,
            limit=args.limit,
            batch_size=args.batch_size,
            policy=args.policy,
            cohort_shape=args.cohort_shape,
            sample_label=args.sample_label or args.cohort_shape,
            worker_state_root=shared_worker_state_root,
            preserve_worker_state_root=scenario.preserve_worker_state_root,
        )
        scenario_env = os.environ.copy()
        scenario_env.update(scenario.env_overrides)

        if args.dry_run:
            print(f"[ladder] scenario={scenario.name}")
            print(" ".join(command))
            combined["scenarios"].append(
                {
                    "name": scenario.name,
                    "description": scenario.description,
                    "env_overrides": scenario.env_overrides,
                    "preserve_worker_state_root": scenario.preserve_worker_state_root,
                    "command": command,
                    "dry_run": True,
                }
            )
            continue

        scenario_output_root.mkdir(parents=True, exist_ok=True)
        proc = subprocess.run(
            command,
            cwd=str(REPO_ROOT),
            env=scenario_env,
            check=False,
        )
        summary_path = scenario_output_root / "benchmark_summary.json"
        summary = _read_summary(summary_path)
        combined["scenarios"].append(
            {
                "name": scenario.name,
                "description": scenario.description,
                "env_overrides": scenario.env_overrides,
                "preserve_worker_state_root": scenario.preserve_worker_state_root,
                "returncode": proc.returncode,
                "scenario_output_root": str(scenario_output_root),
                "benchmark_summary_path": str(summary_path),
                "benchmark_summary": summary,
            }
        )

    report_path = args.output_root / "benchmark_summary.json"
    report_path.write_text(json.dumps(combined, indent=2), encoding="utf-8")
    print(f"[ladder] Wrote summary: {report_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
