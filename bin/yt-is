#!/usr/bin/env python3
"""YouTube channel management — check for new videos and manage tracked channels.

Usage:
    yt-is sync              # Check all tracked channels for new videos
    yt-is list              # List all tracked channels
    yt-is add <url>         # Add a new channel to track
    yt-is history           # Import channels from watch history
    yt-is watchlater        # Import channels from Watch Later
    yt-is fetch             # Download pending transcripts (yt-dlp → Selenium)
    yt-is fetch --dry-run   # Preview what would be fetched
"""

import argparse
import subprocess
import sys
from pathlib import Path

CSF_SOURCE = Path(__file__).parent / "csf-source"
sys.path.insert(0, str(Path(__file__).parent.parent))

from csf.csf_logging import log_action


def main() -> None:
    parser = argparse.ArgumentParser(
        description="YouTube channel management — check for new videos and manage tracked channels."
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # sync command: check all channels for new videos
    sync_parser = subparsers.add_parser("sync", help="Check all tracked channels for new videos")
    sync_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Show detailed output"
    )

    # list command: list all tracked channels
    list_parser = subparsers.add_parser("list", help="List all tracked channels")

    # add command: add a new channel
    add_parser = subparsers.add_parser("add", help="Add a new channel to track")
    add_parser.add_argument("url", help="Channel URL or playlist URL")

    # history command: import tracked channels from watch history
    history_parser = subparsers.add_parser(
        "history",
        help="Extract channels from YouTube watch history and add new ones",
    )
    history_parser.add_argument("--dry-run", action="store_true", help="Preview channels without adding them")
    history_parser.add_argument(
        "--min-history-videos",
        type=int,
        default=2,
        help="Minimum videos watched from a channel to qualify (default: 2)",
    )

    # watchlater command: import tracked channels from Watch Later
    watchlater_parser = subparsers.add_parser(
        "watchlater",
        help="Extract channels from YouTube Watch Later and add new ones",
    )
    watchlater_parser.add_argument("--dry-run", action="store_true", help="Preview channels without adding them")
    watchlater_parser.add_argument(
        "--min-watchlater-videos",
        type=int,
        default=2,
        help="Minimum videos in Watch Later from a channel to qualify (default: 2)",
    )

    # fetch command: download pending transcripts via escalation chain
    fetch_parser = subparsers.add_parser("fetch", help="Download pending transcripts via escalation chain (yt-dlp → Selenium)")
    fetch_parser.add_argument("--dry-run", action="store_true", help="Preview what would be fetched")
    fetch_parser.add_argument("--source", type=str, help="Process only one channel (by URL)")
    fetch_parser.add_argument("--workers", type=int, default=1, help="Number of parallel workers (default: 1)")

    args = parser.parse_args()

    # Default to sync if no command provided
    if args.command is None:
        args.command = "sync"
        args.verbose = False

    if args.command == "sync":
        # Check all channels for new videos
        result = subprocess.run(
            [sys.executable, str(CSF_SOURCE), "check-all"] + (["--verbose"] if args.verbose else [])
        )
        sys.exit(result.returncode)

    elif args.command == "list":
        # List all tracked channels
        result = subprocess.run([sys.executable, str(CSF_SOURCE), "list"])
        sys.exit(result.returncode)

    elif args.command == "add":
        # Add a new channel
        result = subprocess.run([sys.executable, str(CSF_SOURCE), "add", args.url])
        sys.exit(result.returncode)

    elif args.command == "history":
        fetch_cmd = [sys.executable, str(CSF_SOURCE), "history"]
        if args.dry_run:
            fetch_cmd.append("--dry-run")
        if args.min_history_videos != 2:
            fetch_cmd.extend(["--min-history-videos", str(args.min_history_videos)])
        log_action(
            "yt_is_dispatch_started",
            {
                "command": "history",
                "cwd": str(Path.cwd()),
                "backend": str(CSF_SOURCE),
                "argv": fetch_cmd,
            },
        )
        result = subprocess.run(fetch_cmd)
        log_action(
            "yt_is_dispatch_finished",
            {
                "command": "history",
                "backend": str(CSF_SOURCE),
                "returncode": result.returncode,
            },
        )
        sys.exit(result.returncode)

    elif args.command == "watchlater":
        fetch_cmd = [sys.executable, str(CSF_SOURCE), "watchlater"]
        if args.dry_run:
            fetch_cmd.append("--dry-run")
        if args.min_watchlater_videos != 2:
            fetch_cmd.extend(["--min-watchlater-videos", str(args.min_watchlater_videos)])
        log_action(
            "yt_is_dispatch_started",
            {
                "command": "watchlater",
                "cwd": str(Path.cwd()),
                "backend": str(CSF_SOURCE),
                "argv": fetch_cmd,
            },
        )
        result = subprocess.run(fetch_cmd)
        log_action(
            "yt_is_dispatch_finished",
            {
                "command": "watchlater",
                "backend": str(CSF_SOURCE),
                "returncode": result.returncode,
            },
        )
        sys.exit(result.returncode)

    elif args.command == "fetch":
        # Download pending transcripts via escalation chain
        fetch_cmd = [sys.executable, str(CSF_SOURCE), "fetch"]
        if args.dry_run:
            fetch_cmd.append("--dry-run")
        if args.source:
            fetch_cmd.extend(["--source", args.source])
        if args.workers != 1:
            fetch_cmd.extend(["--workers", str(args.workers)])
        log_action(
            "yt_is_dispatch_started",
            {
                "command": "fetch",
                "cwd": str(Path.cwd()),
                "backend": str(CSF_SOURCE),
                "argv": fetch_cmd,
            },
        )
        result = subprocess.run(fetch_cmd)
        log_action(
            "yt_is_dispatch_finished",
            {
                "command": "fetch",
                "backend": str(CSF_SOURCE),
                "returncode": result.returncode,
            },
        )
        sys.exit(result.returncode)

    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
