def _print_block_signals(info, channel_id: str, canonical_url: str) -> bool:
    """Evaluate and print blocklist signals for a channel.

    Args:
        info: ChannelInfo namedtuple from get_upload_playlist_id()
        channel_id: the parsed channel ID (e.g. "@MarquesBrownlee" or "UC...")
        canonical_url: the canonical YouTube URL for this channel

    Returns:
        True if the user chose to block the channel (caller should exit),
        False otherwise.
    """
    desc_lower = (info.description or "").lower()
    kw_lower = (info.keywords or "").lower()
    custom = info.custom_url or ""

    high: list[str] = []
    med: list[str] = []

    # High-confidence signals
    if info.video_count and info.video_count >= 30_000:
        high.append(f"video_count={info.video_count:,} (≥30K → 100%)")
    elif info.video_count and info.video_count >= 5_000:
        high.append(f"video_count={info.video_count:,} (≥5K → 91%)")

    if "sports" in kw_lower:
        high.append("keywords contains 'sports' (19.4x)")
    if "breaking" in kw_lower:
        high.append("keywords contains 'breaking' (17.8x)")
    if "official" in kw_lower:
        high.append("keywords contains 'official' (9.7x)")
    if "breaking" in desc_lower:
        high.append("description contains 'breaking' (6.1x)")
    if "news" in desc_lower:
        high.append("description contains 'news' (5.8x)")
    if "network" in desc_lower:
        high.append("description contains 'network' (9.2x)")

    # Medium-confidence signals
    if info.video_count and info.video_count >= 2_000:
        med.append(f"video_count={info.video_count:,} (≥2K → 64%)")
    if "sports" in desc_lower:
        med.append("description contains 'sports' (8.2x)")
    if custom and custom.startswith("/@"):
        med.append(f"custom_url={custom} (personal/creator style)")
    elif not custom:
        med.append("no custom_url (may be older institutional channel)")

    print()
    if not high and not med:
        print("[signals] No blocklist signals detected.")
        return False

    if high:
        print("[signals] HIGH confidence (institutional broadcaster indicators):")
        for s in high:
            print(f"  • {s}")
    if med:
        print("[signals] MED confidence (secondary indicators):")
        for s in med:
            print(f"  • {s}")

    print()
    response = input("[signals] Block this channel? [y/N] ").strip().lower()
    if response == "y":
        block_channel(canonical_url)
        print(f"[source] Blocked: {canonical_url}")
        print("[source] Exiting — use 'unblock' to remove from blocklist later.")
        return True

    print()
    return False


def _mark_videos_pending(
    canonical_url: str, videos: list[dict]
) -> int:
    """Mark videos as pending, filtering out already-complete ones.

    Returns the number of newly marked videos.
    """
    video_ids = [v["video_id"] for v in videos]
    status_map = get_status_batch(video_ids)
    complete_ids = {vid for vid, status in status_map.items() if status == "complete"}
    entries = [
        BatchEntry(
            video_id=video["video_id"],
            status="pending",
            source=canonical_url,
            published_at=video.get("published_at"),
            has_captions=video.get("has_captions"),
            title=video.get("title"),
            description=video.get("description"),
            channel_id=video.get("channel_id"),
            thumbnail=video.get("thumbnail"),
            duration=video.get("duration"),
            privacy_status=video.get("privacy_status"),
            upload_status=video.get("upload_status"),
            is_live_content=video.get("is_live_content"),
            unavailable_reason=video.get("unavailable_reason"),
        )
        for video in videos
        if video["video_id"] not in complete_ids
    ]
    if entries:
        set_status_batch(entries)
    return len(entries)


def cmd_add(url: str) -> None:
    """Add a new channel or playlist source with full enumeration."""
    print(f"[source] Adding source: {url}")

    # Check quota state before making API calls
    quota = get_quota_status()
    total_units = sum(v["units_consumed"] for v in quota.values())
    total_calls = sum(v["calls_made"] for v in quota.values())
    exhausted_count = sum(1 for v in quota.values() if v.get("exhausted", False))
    print(f"[source] Quota state: {total_calls} calls, ~{total_units} units consumed, {exhausted_count}/{len(quota)} keys exhausted")

    if not can_proceed(units_needed=500):
        print(f"[source] Warning: Quota may be insufficient. YouTube API may reject calls.")
        print(f"[source] Consider waiting for quota to reset (daily limit is 10,000 units/key).")
        print(f"[source] Current state:")
        for idx, state in quota.items():
            print(f"  Key {idx}: {state['calls_made']} calls, ~{state['units_consumed']} units, exhausted={state['exhausted']}")

    # Check if this is a channel or playlist
    channel_id = parse_channel_url(url)
    playlist_id = parse_playlist_url(url)

    if channel_id:
        print(f"[source] Detected channel: {channel_id}")

        # Get uploads playlist ID and full metadata from API (two-tier: snippet=1 unit, full=5 units)
        channel_info = get_upload_playlist_id(channel_id)
        if not channel_info:
            print(f"[source] Error: Could not resolve uploads playlist for {channel_id}", file=sys.stderr)
            print(f"[source] The channel handle does not exist on YouTube (forHandle returned 0 items).", file=sys.stderr)
            print(f"[source] The handle in history.jsonl may be a mention/reference, not a valid @username.", file=sys.stderr)
            sys.exit(1)

        uploads_playlist_id = channel_info.playlist_id
        real_video_count = channel_info.video_count
        channel_title = channel_info.channel_title
        thumbnail_url = channel_info.thumbnail_url
        subscriber_count = channel_info.subscriber_count
        view_count = channel_info.view_count

        print(f"[source] Uploads playlist: {uploads_playlist_id}")
        if real_video_count:
            print(f"[source] Channel has {real_video_count} total videos (from YouTube API)")
            if channel_title:
                print(f"[source] Title: {channel_title}")
        playlist_id = uploads_playlist_id
        # Construct correct URL based on channel ID type
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"

    elif playlist_id:
        print(f"[source] Detected playlist: {playlist_id}")
        canonical_url = f"https://www.youtube.com/playlist?list={playlist_id}"

    else:
        # Try video URL
        video_id = parse_video_url(url)
        if video_id:
            print(f"[source] Detected video: {video_id}")
            # Single-video entry: use watch URL as the source identifier
            canonical_url = url
            # Check blocklist for videos too
            if is_channel_blocked(canonical_url):
                print(f"[source] Blocked: {canonical_url} is on the blocklist.")
                print(f"[source] Use 'unblock {url}' to remove from blocklist first.")
                sys.exit(1)
            new_count = _mark_videos_pending(canonical_url, [
                {"video_id": video_id, "title": None, "published_at": None}
            ])
            # Register/update source in channel_metadata (no playlist_id for single video)
            now = datetime.now(timezone.utc).isoformat()
            upsert_channel(canonical_url, last_checked=now)
            print(f"[source] Done. 1 video, {new_count} new pending.")
            return

        print(f"[source] Error: Could not parse {url} as channel, playlist, or video URL", file=sys.stderr)
        sys.exit(1)

    # Check blocklist before any API calls or enumeration
    if is_channel_blocked(canonical_url):
        print(f"[source] Blocked: {canonical_url} is on the blocklist.")
        print(f"[source] Use 'unblock {url}' to remove from blocklist first.")
        sys.exit(1)

    # Check if already tracked
    existing = get_channel_metadata(canonical_url)
    if existing:
        print(f"[source] Warning: {canonical_url} is already tracked.")
        print(f"[source] Use 'check' to update, or remove and re-add for full re-enumeration.")

    # Block signal analysis — runs after channel_info is populated but before enumeration
    if channel_id:
        # canonical_url is set above in the if/elif/else branches
        if _print_block_signals(channel_info, channel_id, canonical_url):
            sys.exit(0)

    # Full enumeration
    print(f"[source] Enumerating all videos...")
    videos = enumerate_full(playlist_id)
    print(f"[source] Found {len(videos)} videos")

    if len(videos) <= 1:
        print(f"[source] Warning: Channel has {len(videos)} video(s) — rejecting channels with fewer than 2 videos")
        sys.exit(1)

    new_count = _mark_videos_pending(canonical_url, videos)
    print(f"[source] Marked {new_count} new videos as pending")

    # Update channel metadata with real video count and full API metadata
    now = datetime.now(timezone.utc).isoformat()
    video_count_to_store = real_video_count if real_video_count else len(videos)
    set_channel_metadata(
        canonical_url,
        playlist_id=playlist_id,
        last_checked=now,
        last_full_enumeration=now,
        video_count_estimate=video_count_to_store,
        channel_title=channel_title or None,
        thumbnail_url=thumbnail_url or None,
        subscriber_count=subscriber_count or None,
        view_count=view_count or None,
    )

    print(f"[source] Done. {len(videos)} total videos, {new_count} new pending.")


def cmd_list() -> None:
    """List all tracked sources with comprehensive statistics."""
    from csf.batch_status import _get_batch_status_storage
    from csf.cache import _SHARED_DB_PATH
    from csf.display import ChannelStats, format_channel_list, format_sync_results
    import sqlite3

    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    cursor = conn.execute(
        """SELECT channel_url, playlist_id, video_count_estimate, last_checked, last_full_enumeration
           FROM channel_metadata
           WHERE channel_url NOT IN (SELECT channel_url FROM channel_blocklist)
           ORDER BY last_checked DESC"""
    )
    rows = cursor.fetchall()
    conn.close()

    if not rows:
        print("[source] No sources tracked. Use 'add' to add a channel or playlist.")
        return

    # Build video_id sets per channel for accurate counting
    batch_conn = storage._get_conn()
    batch_cursor = batch_conn.execute(
        "SELECT video_id, source, status, has_captions FROM analysis_status WHERE source IS NOT NULL"
    )

    # Structure: channel_url -> {pending: set(), complete: set(), failed: set(), has_subs: set(), no_subs: set()}
    channel_videos: dict[str, dict[str, set[str]]] = {}
    for vid, src, status, has_captions in batch_cursor.fetchall():
        if src not in channel_videos:
            channel_videos[src] = {
                "pending": set(),
                "complete": set(),
                "failed": set(),
                "has_subs": set(),
                "no_subs": set(),
            }

        # Add to status set
        if status in ("pending", "complete", "failed"):
            channel_videos[src][status].add(vid)

        # Add to captions set
        if has_captions == 1:
            channel_videos[src]["has_subs"].add(vid)
        elif has_captions == 0:
            channel_videos[src]["no_subs"].add(vid)

    batch_conn.close()

    # Query transcript cache for detailed metrics per channel
    transcript_stats: dict[str, dict] = {}
    try:
        _SHARED_DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        cache_conn = sqlite3.connect(_SHARED_DB_PATH)
        cache_conn.execute("PRAGMA journal_mode=WAL")

        for channel_url, status_sets in channel_videos.items():
            # Flatten all status sets into one combined set of video_ids for this channel
            all_video_ids = status_sets["pending"] | status_sets["complete"] | status_sets["failed"]
            if not all_video_ids:
                continue

            video_ids = list(all_video_ids)
            placeholders = ",".join("?" * len(video_ids))
            # Count cached transcripts
            count_cursor = cache_conn.execute(
                f"SELECT COUNT(DISTINCT video_id) FROM transcript_cache WHERE video_id IN ({placeholders})",
                video_ids
            )
            cached_count = count_cursor.fetchone()[0]

            # Last download timestamp
            last_dl_cursor = cache_conn.execute(
                f"SELECT MAX(cached_at) FROM transcript_cache WHERE video_id IN ({placeholders})",
                video_ids
            )
            last_download = last_dl_cursor.fetchone()[0]

            # Languages available
            lang_cursor = cache_conn.execute(
                f"SELECT DISTINCT lang FROM transcript_cache WHERE video_id IN ({placeholders}) ORDER BY lang",
                video_ids
            )
            langs = [row[0] for row in lang_cursor.fetchall()]
            languages_str = ",".join(langs[:3]) + ("..." if len(langs) > 3 else "") if langs else ""

            # Storage size (total characters in transcripts)
            size_cursor = cache_conn.execute(
                f"SELECT SUM(LENGTH(transcript)) FROM transcript_cache WHERE video_id IN ({placeholders})",
                video_ids
            )
            total_chars = size_cursor.fetchone()[0] or 0
            size_mb = total_chars / (1024 * 1024)  # Convert to MB

            transcript_stats[channel_url] = {
                "cached": cached_count,
                "last_download": last_download,
                "languages": languages_str,
                "size_mb": size_mb,
            }

        cache_conn.close()
    except Exception:
        # If transcript query fails, use defaults
        pass

    # Build ChannelStats objects with all metrics in the new summary format
    channels = []
    for row in rows:
        channel_url = row[0]

        # Get video sets for this channel
        video_sets = channel_videos.get(channel_url, {
            "pending": set(), "complete": set(), "failed": set(),
            "has_subs": set(), "no_subs": set(),
        })

        pending_set = video_sets["pending"]
        complete_set = video_sets["complete"]
        failed_set = video_sets["failed"]
        has_subs_set = video_sets["has_subs"]
        no_subs_set = video_sets["no_subs"]

        # Calculate actual total from database (not stale estimate)
        total = len(pending_set | complete_set | failed_set)

        # Counts
        pending = len(pending_set)
        complete = len(complete_set)
        failed = len(failed_set)
        has_subs = len(has_subs_set)
        no_subs = len(no_subs_set)

        # Transcript stats from cache
        cache_data = transcript_stats.get(channel_url, {})
        downloaded = cache_data.get("cached", 0)  # dt - actually cached
        last_download = cache_data.get("last_download", None)
        languages = cache_data.get("languages", "")
        size_mb = cache_data.get("size_mb", 0.0)

        # Calculate derived metrics using set operations to avoid double-counting
        # available (vt) = pending videos that have subs (not tried yet, known to have subs)
        available = len(pending_set & has_subs_set)
        # unavailable (nt) = no_subs (known to not have subs) + failed (tried and failed)
        unavailable = no_subs + failed
        # main_trackable (mt) = total - unavailable (assuming no shorts data)
        main_trackable = max(0, total - unavailable)
        # shorts = 0 (no duration data available)
        shorts = 0
        # playlists/subscribers = not available
        playlists = 0
        subscribers = None

        # Calculate success rate using complete/failed counts from sets
        total_attempted = complete + failed
        if total_attempted > 0:
            if complete > 0:
                success_rate = f"{int(complete / total_attempted * 100)}%"
            else:
                success_rate = "0%"
        else:
            success_rate = "-"

        channels.append(
            ChannelStats(
                channel_url=channel_url,
                total=total,
                main_trackable=main_trackable,
                downloaded=downloaded,
                available=available,
                unavailable=unavailable,
                shorts=shorts,
                playlists=playlists,
                subscribers=subscribers,
                last_checked=row[3],
                last_full_enumeration=row[4],
                last_download=last_download,
                success_rate=success_rate,
                languages=languages,
                storage_size_mb=size_mb,
            )
        )

    print(format_channel_list(channels))


def cmd_check(source_id_or_url: str) -> None:
    """Run daily check for a source: RSS + gap detection + API resolution."""
    # Try to find the source
    channel_url = None

    # Check if it's a tracked channel URL
    existing = get_channel_metadata(source_id_or_url)
    if existing:
        channel_url = source_id_or_url
    else:
        # Try to parse as channel URL
        parsed = parse_channel_url(source_id_or_url)
        if parsed and parsed.startswith("UC"):
            channel_url = f"https://www.youtube.com/channel/{parsed}"
            existing = get_channel_metadata(channel_url)

    if not existing:
        print(f"[source] Error: {source_id_or_url} is not a tracked source.", file=sys.stderr)
        print(f"[source] Use 'add' to add it first.", file=sys.stderr)
        sys.exit(1)

    playlist_id = existing.get("playlist_id")
    if not playlist_id:
        print(f"[source] Error: No playlist_id found for {channel_url}", file=sys.stderr)
        sys.exit(1)

    print(f"[source] Checking {channel_url}")

    # Step 1: Resolve to UC channel ID if needed
    channel_id = parse_channel_url(channel_url)
    if not channel_id:
        print(f"[source] Error: Could not parse channel ID from {channel_url}", file=sys.stderr)
        sys.exit(1)

    # Resolve @handle, c/custom, user/ URLs to UC channel ID
    if not channel_id.startswith("UC"):
        uc_channel_id = resolve_to_uc_channel_id(channel_id)
        if not uc_channel_id:
            print(f"[source] Error: Could not resolve {channel_id} to UC channel ID", file=sys.stderr)
            sys.exit(1)
        channel_id = uc_channel_id

    # Step 2: RSS check (now with UC channel ID)
    rss_ids = check_rss(channel_id)
    print(f"[source] RSS returned {len(rss_ids)} recent videos")

    if not rss_ids:
        print(f"[source] Warning: RSS returned no videos. Channel may be invalid or RSS disabled.")
        # Still try API
        rss_ids = []

    # Get ALL existing videos for this source (pending, complete, failed)
    all_entries = get_entries_for_source(channel_url)
    all_video_ids = {vid for vid, _, _ in all_entries}
    print(f"[source] {len(all_video_ids)} total videos in database")

    # Step 2: Gap detection
    last_enum = existing.get("last_full_enumeration")

    # Gap detection: if RSS shows videos that don't exist in our database
    gap_detected = False
    if rss_ids:
        gap_detected = detect_gap(rss_ids, all_video_ids)
        # Log gap detection result
        log_action("gap_detection", {
            "channel_url": channel_url,
            "rss_count": len(rss_ids),
            "db_count": len(all_video_ids),
            "gap_detected": gap_detected,
        })

    if gap_detected:
        log_user_message(f"Gap detected. Running API gap resolution...")
        # Use publishedAfter = last_full_enumeration or epoch
        published_after = last_enum if last_enum else "1970-01-01T00:00:00Z"
        gap_videos = enumerate_recent(playlist_id, published_after=published_after)
        log_action("api_gap_resolution", {
            "channel_url": channel_url,
            "videos_found": len(gap_videos),
            "published_after": published_after,
        })
        print(f"[source] API gap resolution found {len(gap_videos)} videos")

        # Fetch real video count from API since we're making API calls anyway
        real_video_count = get_video_count(channel_id)
        if real_video_count:
            log_action("api_video_count", {
                "channel_url": channel_url,
                "real_count": real_video_count,
            })
            print(f"[source] Real video count from API: {real_video_count}")

        # O(1) batch insert + O(1) batch pre-filter (avoids N individual is_complete calls)
        gap_video_ids = [v["video_id"] for v in gap_videos]
        gap_status_map = get_status_batch(gap_video_ids)
        complete_ids = {vid for vid, status in gap_status_map.items() if status == "complete"}
        entries = [
            BatchEntry(
                video_id=video["video_id"],
                status="pending",
                source=channel_url,
                published_at=video.get("published_at"),
                has_captions=video.get("has_captions"),
                title=video.get("title"),
                description=video.get("description"),
                channel_id=video.get("channel_id"),
                thumbnail=video.get("thumbnail"),
                duration=video.get("duration"),
                privacy_status=video.get("privacy_status"),
                upload_status=video.get("upload_status"),
                is_live_content=video.get("is_live_content"),
                unavailable_reason=video.get("unavailable_reason"),
            )
            for video in gap_videos
            if video["video_id"] not in complete_ids
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

        log_action("gap_resolution_complete", {
            "channel_url": channel_url,
            "new_videos": new_count,
            "real_video_count": real_video_count,
        })
        print(f"[source] Marked {new_count} new videos as pending")

    elif rss_ids:
        # Normal RSS processing - only add videos that aren't in database at all
        rss_ids_set = set(rss_ids)
        new_videos = rss_ids_set - all_video_ids  # Only truly new videos
        entries = [
            BatchEntry(
                video_id=vid,
                status="pending",
                source=channel_url,
                published_at=None,
                has_captions=None,
            )
            for vid in new_videos
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

        log_action("rss_processing", {
            "channel_url": channel_url,
            "rss_returned": len(rss_ids),
            "db_videos": len(all_video_ids),
            "new_videos": new_count,
        })
        print(f"[source] Marked {new_count} new RSS videos as pending")

        # Increment video_count_estimate by the number of new videos found
        current_count = existing.get("video_count_estimate", 0)
        if new_count > 0 and current_count is not None:
            upsert_channel(channel_url, video_count_estimate=current_count + new_count)

    # Update last_checked and optionally real video count from API
    now = datetime.now(timezone.utc).isoformat()
    if 'real_video_count' in locals() and real_video_count:
        upsert_channel(channel_url, last_checked=now, video_count_estimate=real_video_count)
    else:
        upsert_channel(channel_url, last_checked=now)

    print(f"[source] Check complete.")


def _process_channel_check(
    channel_url: str,
    playlist_id: str | None,
    video_count: int | None,
    last_checked: str | None,
    verbose: bool = False,
) -> tuple[int, int]:
    """Helper for parallel channel checks. Returns (new_videos_count, total_videos_count)."""
    if not playlist_id:
        if verbose:
            print(f"[source] Skipping {channel_url} — no playlist_id")
        return 0, 0

    # Step 1: Resolve to UC channel ID if needed
    channel_id = parse_channel_url(channel_url)
    if not channel_id:
        if verbose:
            print(f"[source] Skipping {channel_url} — could not parse channel ID")
        return 0, 0

    # Resolve @handle, c/custom, user/ URLs to UC channel ID
    if not channel_id.startswith("UC"):
        uc_channel_id = resolve_to_uc_channel_id(channel_id)
        if not uc_channel_id:
            if verbose:
                print(f"[source] Skipping {channel_url} — could not resolve to UC channel ID")
            return 0, 0
        channel_id = uc_channel_id

    # Step 2: RSS check
    rss_ids = check_rss(channel_id)
    if verbose:
        print(f"[source] RSS for {channel_url} returned {len(rss_ids)} recent videos")

    # Get ALL existing videos for this source
    all_entries = get_entries_for_source(channel_url)
    all_video_ids = {vid for vid, _, _ in all_entries}

    # Step 3: Gap detection
    gap_detected = False
    if rss_ids:
        gap_detected = detect_gap(rss_ids, all_video_ids)
    else:
        # If RSS is empty, trigger a "Deep Discovery" check via playlistItems API
        # as a safety fallback. This prevents missing videos when RSS is disabled/broken.
        gap_detected = True
        if verbose:
            print(f"[source] RSS empty for {channel_url} — triggering Deep Discovery fallback")

    new_count = 0
    real_video_count = None
    if gap_detected:
        if verbose:
            print(f"[source] Gap detected for {channel_url}. Running API gap resolution...")

        published_after = last_checked if last_checked else "1970-01-01T00:00:00Z"
        # Phase 2 Optimization: Use enumerate_full_playlist for "Deep Discovery"
        # if the last check was more than 7 days ago, ensuring no "Deep Gaps".
        is_deep_check = False
        if last_checked:
            last_dt = datetime.fromisoformat(last_checked.replace("Z", "+00:00"))
            if (datetime.now(timezone.utc) - last_dt).days > 7:
                is_deep_check = True

        if is_deep_check:
            if verbose:
                print(f"[source] Deep check (>7 days) — enumerating full playlist for {channel_url}")
            gap_videos = enumerate_full_playlist(playlist_id)
        else:
            gap_videos = enumerate_recent(playlist_id, published_after=published_after)

        # Fetch real video count from API
        channel_id_for_count = parse_channel_url(channel_url)
        if channel_id_for_count:
            real_video_count = get_video_count(channel_id_for_count)

        gap_video_ids = [v["video_id"] for v in gap_videos]
        gap_status_map = get_status_batch(gap_video_ids)
        complete_ids = {vid for vid, status in gap_status_map.items() if status == "complete"}
        entries = [
            BatchEntry(
                video_id=video["video_id"],
                status="pending",
                source=channel_url,
                published_at=video.get("published_at"),
                has_captions=video.get("has_captions"),
                title=video.get("title"),
                description=video.get("description"),
                channel_id=video.get("channel_id"),
                thumbnail=video.get("thumbnail"),
                duration=video.get("duration"),
                privacy_status=video.get("privacy_status"),
                upload_status=video.get("upload_status"),
                is_live_content=video.get("is_live_content"),
                unavailable_reason=video.get("unavailable_reason"),
            )
            for video in gap_videos
            if video["video_id"] not in complete_ids
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

    elif rss_ids:
        # Normal RSS processing
        rss_ids_set = set(rss_ids)
        new_videos = rss_ids_set - all_video_ids
        entries = [
            BatchEntry(
                video_id=vid,
                status="pending",
                source=channel_url,
                published_at=None,
                has_captions=None,
            )
            for vid in new_videos
        ]
        if entries:
            set_status_batch(entries)
        new_count = len(entries)

    # Update last_checked
    now = datetime.now(timezone.utc).isoformat()
    if real_video_count:
        upsert_channel(channel_url, last_checked=now, video_count_estimate=real_video_count)
    else:
        upsert_channel(channel_url, last_checked=now)

    total_current = len(all_video_ids) + new_count
    return new_count, total_current


def cmd_check_all(verbose: bool = False) -> None:
    """Run RSS + gap detection check on ALL tracked channels in parallel.

    Iterates through all channels in channel_metadata table, runs check
    on each one in parallel using ThreadPoolExecutor.
    """
    from concurrent.futures import ThreadPoolExecutor, as_completed
    from csf.batch_status import _get_batch_status_storage

    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    cursor = conn.execute(
        "SELECT channel_url, playlist_id, video_count_estimate, last_checked FROM channel_metadata ORDER BY last_checked ASC"
    )
    rows = cursor.fetchall()
    conn.close()

    if not rows:
        print("[source] No tracked channels. Use 'add' to add channels first.")
        return

    print(f"[source] Checking {len(rows)} tracked channels (Parallel Discovery)...")

    total_new_videos = 0
    total_videos_all = 0

    # Parallel discovery using 5 workers (conservative to avoid YouTube API thundering herd)
    with ThreadPoolExecutor(max_workers=5) as executor:
        futures = {
            executor.submit(_process_channel_check, url, pl, count, last, verbose): url
            for url, pl, count, last in rows
        }

        for future in as_completed(futures):
            try:
                new_vids, total_vids = future.result()
                total_new_videos += new_vids
                total_videos_all += total_vids
            except Exception as e:
                url = futures[future]
                print(f"[source] Error checking {url}: {e}")

    # Print summary and stats
    print(f"\n[source] Discovery complete. Found {total_new_videos} new videos across {len(rows)} channels.")

    # Print summary stats
    print("")  # blank line before results

    # Print legend
    print("Legend:")
    print("  total  = all videos tracked")
    print("  valid  = videos with captions (downloadable)")
    print("  mt     = main trackable (could have transcripts)")
    print("  dt     = downloaded (cached transcripts)")
    print("  vt     = available for download (has captions, not cached)")
    print("  na     = unavailable (no captions or failed)")
    print("")

    # Re-query to get updated statistics
    conn = storage._get_conn()
    cursor = conn.execute(
        "SELECT channel_url, video_count_estimate FROM channel_metadata ORDER BY last_checked ASC"
    )
    channels_meta = cursor.fetchall()
    conn.close()

    total_videos_all = 0

    # Query transcript cache
    try:
        from csf.cache import has_cached_transcript

        for channel_url, video_count in channels_meta:
            # Get video status counts including unavailable_reason
            batch_conn = storage._get_conn()
            batch_cursor = batch_conn.execute(
                """SELECT status, has_captions, unavailable_reason, COUNT(*)
                   FROM analysis_status WHERE source=?
                   GROUP BY status, has_captions, unavailable_reason""",
                (channel_url,)
            )
            status_counts = batch_cursor.fetchall()
            batch_conn.close()

            complete = sum(count for status, has_capt, _, count in status_counts if status == "complete")
            pending = sum(count for status, has_capt, _, count in status_counts if status == "pending")
            failed = sum(count for status, has_capt, _, count in status_counts if status == "failed")
            # has_subs = videos where has_captions is set (1 or True), regardless of value
            has_subs = sum(count for status, has_capt, _, count in status_counts if has_capt is not None)
            no_subs = sum(count for status, has_capt, _, count in status_counts if has_capt is None)

            # Count cached transcripts using has_cached_transcript
            all_video_ids = [vid for vid, _, _ in get_entries_for_source(channel_url)]
            cached = sum(1 for vid in all_video_ids if has_cached_transcript(vid))

            # Use actual database count instead of stale estimate
            total = len(all_video_ids)
            total_videos_all += total
            dt = cached  # downloaded transcripts

            # valid = potentially downloadable (total - unavailable - pending)
            # Use set-based total to avoid double-counting from GROUP BY
            # (a video with has_capt=0 AND unavailable_reason='member_only' would
            # appear in multiple groups, inflating the count if summed directly)
            unavailable = failed
            valid = max(0, total - unavailable)

            # vt = videos available on YouTube (has subs) but not yet downloaded
            # Include: pending with known subs (has_capt=1) + never checked (has_capt=NULL)
            pending_with_subs = sum(count for status, has_capt, _, count in status_counts if status == "pending" and has_capt == 1)
            pending_unknown = sum(count for status, has_capt, _, count in status_counts if status == "pending" and has_capt is None)
            vt = pending_with_subs + pending_unknown  # available to try

            # na = unavailable = failed videos (attempted and no captions)
            na = failed

            # mt = main trackable = total - unavailable
            mt = valid

            stats_line = f"{total:>4} total, {valid:>4} valid, {mt:>4} mt, {dt:>3} dt | +{vt:>3} vt, +{na:>3} na"

            # Fix URL format for @handles (remove /channel/ if present)
            display_url = channel_url
            if "/channel/@" in display_url:
                display_url = display_url.replace("/channel/@", "/@")

            # Print channel URL and stats on same line
            print(f"{display_url}  {stats_line}")
            print("")

    except Exception as e:
        # If transcript cache query fails, show simpler format
        print(f"[source] Error querying transcript cache: {e}")
        for channel_url, video_count in channels_meta:
            print(f"Channel: {channel_url}")
            print(f"  {video_count or 0} total")
            print("")

    # Print summary (total_videos_all is calculated above from actual database counts)
    print(f"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print(f"Summary: {len(channels_meta)} channels | {total_new_videos} new | {total_videos_all} total videos")


def cmd_sync(source_id_or_url: str) -> None:
    """Process all pending videos for a source via batch."""
    # Find the source
    existing = get_channel_metadata(source_id_or_url)
    if existing:
        channel_url = source_id_or_url
    else:
        parsed = parse_channel_url(source_id_or_url)
        if parsed and parsed.startswith("UC"):
            channel_url = f"https://www.youtube.com/channel/{parsed}"
            existing = get_channel_metadata(channel_url)
        else:
            channel_url = None

    if not existing:
        print(f"[source] Error: {source_id_or_url} is not a tracked source.", file=sys.stderr)
        sys.exit(1)

    # Inter-process lock to prevent concurrent sync on same source
    # acquire() with timeout=60 prevents indefinite blocking if process crashes while holding lock
    lock_name = channel_url.replace("https://www.youtube.com/", "").replace("/", "_")
    lock = fasteners.InterProcessLock(_LOCK_DIR / f"{lock_name}.lock")

    acquired = lock.acquire(blocking=True, timeout=60)
    if not acquired:
        print(f"[source] Error: Could not acquire lock for {channel_url} within 60s", file=sys.stderr)
        print(f"[source] Another sync may be running. Try again later.", file=sys.stderr)
        sys.exit(1)
    try:
        pending_ids = get_pending_by_source(channel_url)
        if not pending_ids:
            print(f"[source] No pending videos for {channel_url}")
            return

        print(f"[source] Processing {len(pending_ids)} pending videos for {channel_url}...")

        successful, failed = batch.analyze_videos_round_robin(
            pending_ids, channel_url=channel_url
        )
    finally:
        lock.release()

    print(f"[source] Sync complete: {len(successful)} successful, {len(failed)} failed")
    if failed:
        print(f"[source] Failed video IDs: {', '.join(failed)}")


def cmd_fetch(source_filter: str | None = None, dry_run: bool = False, workers: int = 1) -> None:
    """Fetch transcripts for pending videos using escalation chain (yt-dlp → Selenium).

    This is the ESCALATION BATCH PROCESS - tries fastest methods first, falls back
    to slower but more reliable methods.

    Args:
        source_filter: Optional channel URL to process only that source.
        dry_run: If True, show what would be fetched without actually fetching.
        workers: Number of parallel workers (default: 1).
    """
    from concurrent.futures import ThreadPoolExecutor, as_completed
    from csf.transcript import fetch_transcript_chain, LanguageConfig

    storage = _get_batch_status_storage()

    # Get all channels or specific channel
    if source_filter:
        existing = get_channel_metadata(source_filter)
        if not existing:
            print(f"[source] Error: {source_filter} is not a tracked source.", file=sys.stderr)
            sys.exit(1)
        channels = [(source_filter, existing.get("playlist_id"))]
    else:
        conn = storage._get_conn()
        cursor = conn.execute("SELECT channel_url, playlist_id FROM channel_metadata")
        channels = cursor.fetchall()
        conn.close()

    if not channels:
        print("[source] No tracked channels found.")
        return

    # Collect all pending videos across channels
    all_pending: list[tuple[str, str]] = []  # (video_id, source_url)
    cached_count = 0

    for channel_url, playlist_id in channels:
        if is_channel_blocked(channel_url):
            continue
        if not playlist_id:
            continue

        entries = get_entries_for_source(channel_url)
        for entry in entries:
            video_id, status, has_captions = entry
            if status != "pending":
                continue

            if has_cached_transcript(video_id):
                cached_count += 1
            else:
                all_pending.append((video_id, channel_url))

    total_pending = len(all_pending)
    # Automated Triage Decision
    # If backlog >= 50, use Industrial (Batch NLM) path to maximize throughput.
    # Otherwise use Surgical (Escalation Chain) for immediate results.
    BACKLOG_THRESHOLD = 50
    use_industrial = total_pending >= BACKLOG_THRESHOLD

    print(f"[source] Escalation Batch Process")
    print(f"[source] Channels: {len(channels)}")
    print(f"[source] Already cached: {cached_count}")
    print(f"[source] Pending extraction: {total_pending}")
    print(f"[source] Mode: {'DRY RUN' if dry_run else 'LIVE'}")
    print(f"[source] Strategy: {'Industrial (Batch NLM)' if use_industrial else 'Surgical (Chain)'}")
    if use_industrial:
        print("[source] Method: NotebookLM batch transcript extraction")
    else:
        print("[source] Method: yt-dlp → cookies → Selenium escalation chain")
    print(f"[source] Workers: {workers}")
    print()

    if not all_pending:
        print("[source] All transcripts already cached. Nothing to do.")
        return

    if dry_run:
        print("[source] Dry run complete. Use without --dry-run to fetch transcripts.")
        return

    # Process videos
    success_count = 0
    fail_count = 0
    skip_count = 0

    if use_industrial:
        # --- INDUSTRIAL PATH: Group into batches of 300 for NLM ---
        print(f"[source] Starting Industrial Ingest (300 v/batch)...")
        from csf.nlm_batch import NLMReusableIngestor

        reusable = NLMReusableIngestor()
        batch_size = 300
        try:
            for i in range(0, len(all_pending), batch_size):
                batch = [vid for vid, src in all_pending[i : i + batch_size]]
                print(f"[source] Processing batch {i//batch_size + 1} ({len(batch)} videos)...")

                # Batch call directly to NotebookLM (skips local yt-dlp/Selenium)
                results = reusable.process_batch(batch)

                for vid, (success, transcript, error) in results.items():
                    if success and transcript:
                        set_cached_transcript(vid, "en", "notebooklm", transcript)
                        mark_complete(vid)
                        success_count += 1
                        print(f"  ✓ {vid} (notebooklm)")
                    else:
                        fail_count += 1
                        print(f"  ✗ {vid}: {error[:80]}")
        finally:
            reusable.close()

    else:
        # --- SURGICAL PATH: Sequential Escalation Chain ---
        def _process_video(video_id: str, source_url: str) -> tuple[str, bool, str, str]:
            """Process a single video using the escalation chain."""
            if has_cached_transcript(video_id):
                return (video_id, True, "cache", "")

            config = LanguageConfig(prefer_lang="en", allow_translation=False)
            result = fetch_transcript_chain(video_id, config)

            if result.transcript:
                set_cached_transcript(video_id, result.lang or "en", result.source, result.transcript)
                mark_complete(video_id)
                return (video_id, True, result.source, "")
            else:
                set_status(video_id, "failed")
                return (video_id, False, "", result.error or "No transcript available")

        print(f"[source] Starting Surgical Ingest (Sequential Escalation)...")
        with ThreadPoolExecutor(max_workers=workers) as executor:
            futures = {
                executor.submit(_process_video, vid, src): (idx, vid)
                for idx, (vid, src) in enumerate(all_pending, 1)
            }
            for future in as_completed(futures):
                idx, video_id = futures[future]
                try:
                    video_id, success, source_used, error = future.result()
                    if success:
                        if source_used == "cache":
                            skip_count += 1
                        else:
                            success_count += 1
                            print(f"[{idx}/{total_pending}] ✓ {video_id} ({source_used})")
                    else:
                        fail_count += 1
                        print(f"[{idx}/{total_pending}] ✗ {video_id}: {error[:80]}")
                except Exception as e:
                    fail_count += 1
                    print(f"[{idx}/{total_pending}] ✗ Error: {e}")

    # Summary
    print()
    print("[source] === Escalation Batch Complete ===")
    print(f"[source] Successfully extracted: {success_count}")
    print(f"[source] Failed: {fail_count}")
    print(f"[source] Skipped (cached): {skip_count}")
    print(f"[source] Total processed: {total_pending}")


def cmd_quota() -> None:
    """Print current per-key quota state and recommend workers."""
    quota = get_quota_status()
    if not quota:
        print("[source] No API keys configured.")
        return

    keys = _get_api_keys()
    print(f"API Keys: {len(keys)}")
    print(f"{'Key':<8} {'Calls':>6} {'Units':>8} {'Exhausted':>10} {'Since':<30}")
    print("-" * 70)
    for idx in sorted(quota.keys()):
        state = quota[idx]
        exhausted = "YES" if state["exhausted"] else "no"
        since = state.get("exhausted_at", "-")
        print(f"Key {idx:<3} {state['calls_made']:>6} {state['units_consumed']:>8} {exhausted:>10} {since or '-'}")

    total_exhausted = sum(1 for v in quota.values() if v.get("exhausted", False))
    total_units = sum(v["units_consumed"] for v in quota.values())
    remaining_per_key = 10000 - total_units // max(len(keys), 1)
    available = sum(10000 - v["units_consumed"] for v in quota.values() if not v.get("exhausted", False))

    # Recommend workers based on remaining non-exhausted keys
    non_exhausted = len(keys) - total_exhausted
    if total_exhausted >= len(keys):
        recommended_workers = 0
    elif non_exhausted == 1:
        recommended_workers = 1  # only one key alive, serial to avoid contention
    else:
        recommended_workers = min(non_exhausted, 8)

    print()
    print(f"Total consumed: ~{total_units} units across {len(keys)} keys")
    print(f"Non-exhausted keys: {non_exhausted}")
    print(f"Recommended max workers: {recommended_workers}")
    print(f"[source] Can proceed for ~{available // 5} more channel additions")


def cmd_block(url: str) -> None:
    """Add a channel to the blocklist."""
    # Normalize the URL
    channel_id = parse_channel_url(url)
    if channel_id:
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"
    else:
        canonical_url = url

    block_channel(canonical_url)
    print(f"[source] Blocked: {canonical_url}")


def cmd_unblock(url: str) -> None:
    """Remove a channel from the blocklist."""
    channel_id = parse_channel_url(url)
    if channel_id:
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"
    else:
        canonical_url = url

    was_blocked = unblock_channel(canonical_url)
    if was_blocked:
        print(f"[source] Unblocked: {canonical_url}")
    else:
        print(f"[source] Not on blocklist: {canonical_url}")


def cmd_list_blocked() -> None:
    """List all blocked channels."""
    blocked = get_all_blocked_channels()
    if not blocked:
        print("[source] No blocked channels.")
        return
    print("[source] Blocked channels:")
    for channel_url, blocked_at in blocked:
        print(f"  {channel_url}  (blocked {blocked_at[:19].replace('T', ' ')})")


def cmd_remove(url: str) -> None:
    """Remove a channel and all its video entries from the database."""
    channel_id = parse_channel_url(url)
    if channel_id:
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"
    else:
        canonical_url = url

    deleted = delete_channel(canonical_url)
    if deleted:
        print(f"[source] Removed: {canonical_url}")
    else:
        print(f"[source] Not found in database: {canonical_url}")


def cmd_history(min_history_videos: int = 2, dry_run: bool = False) -> None:
    """Extract channels from YouTube watch history and add new ones.

    Three filters applied:
    - subscriber_count > 100  (skip tiny/brand-new channels)
    - video_count > 2        (skip barely-active channels)
    - most recent video within 3 months (skip dormant/abandoned channels)

    Requires: YOUTUBE_API_KEY
    """
    import os
    from datetime import datetime, timezone, timedelta
    from urllib.request import urlopen
    from xml.etree import ElementTree as ET

    print(f"[source] Step 1: Fetching watch history video IDs (yt-dlp Python API, no API quota)...")

    # Find cookies file: prefer exported file, fall back to browser extraction
    cookie_file = os.path.expanduser("~/youtube_cookies.txt")
    if not os.path.exists(cookie_file):
        # Fall back to browser cookies
        cookie_file = None

    try:
        import yt_dlp
        ydl_opts = {
            "quiet": True,
            "cookiefile": cookie_file,
            "extract_flat": "in_playlist",
            "skip_download": True,
            "socket_timeout": 60,
        }
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            result = ydl.extract_info(
                "https://www.youtube.com/feed/history",
                download=False,
            )
            entries = result.get("entries", []) or []
    except Exception as e:
        print(f"[source] Error fetching history: {e}", file=sys.stderr)
        sys.exit(1)

    video_ids = [e["id"] for e in entries if e and e.get("id")]
    video_ids = [e["id"] for e in entries]
    print(f"[source] Found {len(video_ids)} video IDs in history")

    if not video_ids:
        print("[source] No videos found in history.", file=sys.stderr)
        sys.exit(1)

    print(f"[source] Step 2: Resolving {len(video_ids)} video IDs → channel IDs (API, ~{len(video_ids)} units)...")

    from csf.source_enumerator import _api_request

    channel_video_map: dict[str, list[str]] = {}
    for i in range(0, len(video_ids), 50):
        batch = video_ids[i : i + 50]
        params = {"part": "snippet", "id": ",".join(batch)}
        resp = _api_request("videos", params, unit_cost=1)
        if resp is None:
            continue

        for item in resp.get("items", []):
            vid = item.get("id")
            snippet = item.get("snippet", {})
            ch_id = snippet.get("channelId", "")
            if vid and ch_id:
                channel_video_map.setdefault(ch_id, []).append(vid)

        if (i + 50) % 500 == 0 or i + 50 >= len(video_ids):
            print(f"  ... resolved {min(i + 50, len(video_ids))}/{len(video_ids)}")

    channel_history_counts = {cid: len(vids) for cid, vids in channel_video_map.items()}
    qualified = {cid: vids for cid, vids in channel_video_map.items() if len(vids) >= min_history_videos}
    print(f"[source] Channels with ≥{min_history_videos} history videos: {len(qualified)}/{len(channel_video_map)}")

    if not qualified:
        print("[source] No channels passed the history-video threshold.")
        sys.exit(1)

    # Get already-tracked UC IDs
    existing_uc_ids: set[str] = set()
    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    for row in conn.execute("SELECT channel_url FROM channel_metadata").fetchall():
        cu = row[0]
        m = re.search(r"/channel/(UC[a-zA-Z0-9_-]+)", cu)
        if m:
            existing_uc_ids.add(m.group(1))
        elif cu.startswith("UC"):
            existing_uc_ids.add(cu)

    new_qualified = [cid for cid in qualified if cid not in existing_uc_ids]
    print(f"[source] Already tracked: {len(qualified) - len(new_qualified)}")
    print(f"[source] New to add (before filters): {len(new_qualified)}")

    if dry_run:
        print(f"\n[source] DRY RUN — would add {len(new_qualified)} channels (filters not yet applied):")
        for cid in sorted(new_qualified)[:50]:
            print(f"  [{channel_history_counts[cid]} videos] https://www.youtube.com/channel/{cid}")
        if len(new_qualified) > 50:
            print(f"  ... and {len(new_qualified) - 50} more")
        print(f"\n[source] Filters (applied on real run):")
        print(f"  subscriber_count > 100")
        print(f"  video_count > 2")
        print(f"  most recent video within 3 months")
        print(f"\n[source] Run without --dry-run to apply filters and add.")
        return

    if not new_qualified:
        print("[source] All qualified history channels already tracked.")
        return

    # Step 3: Apply filters and add
    print(f"[source] Step 3: Applying filters to {len(new_qualified)} channels...")
    print(f"[source] Filters: subscriber_count>100, video_count>2, newest_video≤3mo")

    # Batch-fetch channel metadata: 50 channels per channels.list call (5 units each)
    # vs per-channel get_upload_playlist_id which makes 2 calls each (1+5 units)
    # For 699 channels: ~14 batch calls (70 units) vs ~1398 individual calls (4194 units)
    print(f"[source] Fetching channel metadata in batch (~{len(new_qualified)//50 + 1} API calls, ~5 units/call)...")
    channel_meta: dict[str, dict] = {}
    for i in range(0, len(new_qualified), 50):
        batch = new_qualified[i:i + 50]
        params = {"id": ",".join(batch), "part": "contentDetails,statistics,snippet"}
        resp = _api_request("channels", params, unit_cost=5)
        if not resp or "items" not in resp:
            for uc_id in batch:
                channel_meta[uc_id] = None
            continue

        for item in resp["items"]:
            cid = item.get("id", "")
            if not cid:
                continue
            snippet = item.get("snippet", {})
            content_details = item.get("contentDetails", {})
            statistics = item.get("statistics", {})
            uploads_playlist = content_details.get("relatedPlaylists", {}).get("uploads", "")

            channel_meta[cid] = {
                "title": snippet.get("title", ""),
                "subs": int(statistics.get("subscriberCount", 0) or 0),
                "videos": int(statistics.get("videoCount", 0) or 0),
                "playlist_id": uploads_playlist,
            }
        fetched = min(i + 50, len(new_qualified))
        if (i + 50) % 500 == 0 or fetched >= len(new_qualified):
            print(f"  ... fetched {fetched}/{len(new_qualified)}")

    # Check recency via RSS (free, no quota) for each channel
    cutoff = datetime.now(timezone.utc) - timedelta(days=90)
    three_months_ago = cutoff.strftime("%Y-%m-%d")

    print(f"[source] Checking recency via RSS feed (free, no quota)...")

    def get_latest_video_date(uc_id: str) -> str | None:
        """Fetch most recent video date via RSS. Returns ISO date or None."""
        ATOM_NS = "http://www.w3.org/2005/Atom"
        try:
            rss_url = f"https://www.youtube.com/feeds/videos.xml?channel_id={uc_id}"
            with urlopen(rss_url, timeout=10) as resp:
                tree = ET.parse(resp)
                root = tree.getroot()
                entries = root.findall(f"{{{ATOM_NS}}}entry")
                if not entries:
                    return None
                pub = entries[0].find(f"{{{ATOM_NS}}}published")
                if pub is None:
                    pub = entries[0].find("published")
                return pub.text if pub is not None else None
        except Exception:
            return None

    passed_filters = []
    skipped_filters: dict[str, list[str]] = {
        "subs≤100": [],
        "videos≤2": [],
        "stale>3mo": [],
        "no_meta": [],
    }

    # Pre-fetch RSS recency for all channels in parallel (20 workers)
    # Each RSS call is ~1-3s; 726 channels sequentially = ~30 min; in parallel ~= ~2 min
    print(f"[source] Checking recency via RSS feed ({len(new_qualified)} channels, 20 workers)...")
    from concurrent.futures import ThreadPoolExecutor, as_completed
    rss_dates: dict[str, str | None] = {}
    with ThreadPoolExecutor(max_workers=20) as executor:
        futures = {executor.submit(get_latest_video_date, cid): cid for cid in new_qualified}
        done = 0
        for future in as_completed(futures):
            cid = futures[future]
            rss_dates[cid] = future.result()
            done += 1
            if done % 100 == 0 or done == len(new_qualified):
                print(f"  ... RSS checked {done}/{len(new_qualified)}")

    print(f"[source] Applying filters to {len(new_qualified)} channels...")

    for uc_id in new_qualified:
        meta = channel_meta.get(uc_id)
        if meta is None:
            skipped_filters["no_meta"].append(uc_id)
            continue

        # Filter: subscriber count > 100
        subs = meta["subs"] if meta else 0
        if subs <= 100:
            skipped_filters["subs≤100"].append(uc_id)
            continue

        # Filter: video count > 2
        vid_count = meta["videos"] if meta else 0
        if vid_count <= 2:
            skipped_filters["videos≤2"].append(uc_id)
            continue

        # Filter: most recent video within 3 months
        latest = rss_dates.get(uc_id)
        if latest is None:
            skipped_filters["no_meta"].append(uc_id)
            continue
        try:
            latest_dt = datetime.fromisoformat(latest.replace("Z", "+00:00"))
            if latest_dt < cutoff:
                skipped_filters["stale>3mo"].append(uc_id)
                continue
        except ValueError:
            pass

        passed_filters.append(uc_id)

    print(f"[source] Filters applied:")
    print(f"  passed: {len(passed_filters)}")
    for reason, cids in skipped_filters.items():
        print(f"  skipped ({reason}): {len(cids)}")

    if not passed_filters:
        print("[source] No channels passed all filters.")
        sys.exit(0)

    print(f"[source] Step 4: Adding {len(passed_filters)} channels (no full enumeration — sync will handle lazily)...")

    added = 0
    failed = 0

    for uc_id in passed_filters:
        channel_url = f"https://www.youtube.com/channel/{uc_id}"
        if is_channel_blocked(channel_url):
            print(f"  [skip blocked] {channel_url}")
            continue

        meta = channel_meta.get(uc_id)
        if not meta:
            failed += 1
            continue

        uploads_playlist_id = meta["playlist_id"]
        if not uploads_playlist_id or len(uploads_playlist_id) != 24:
            failed += 1
            continue

        # Skip full enumerate_full() — let sync handle it lazily
        # last_full_enumeration=None forces sync to enumerate on next run
        now = datetime.now(timezone.utc).isoformat()
        set_channel_metadata(
            channel_url,
            playlist_id=uploads_playlist_id,
            last_checked=now,
            last_full_enumeration=None,  # sync will enumerate lazily
            video_count_estimate=meta["videos"],
            channel_title=meta["title"] or None,
            thumbnail_url=None,
            subscriber_count=meta["subs"] or None,
            view_count=None,
        )
        hist_count = channel_history_counts.get(uc_id, 0)
        print(f"  OK: {meta['title'] or uc_id} ({meta['videos']} videos total, {hist_count} from history)")
        added += 1

    print()
    print(f"[source] Done: {added} added, {failed} failed out of {len(passed_filters)}")
    print(f"[source] Full video enumeration will happen on next sync — {added} channels will be processed then.")
    for reason, cids in skipped_filters.items():
        if cids:
            print(f"[source] Skipped ({reason}): {len(cids)}")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="YouTube source management CLI — Phase 2."
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # add command
    add_parser = subparsers.add_parser("add", help="Add a new channel or playlist source")
    add_parser.add_argument("url", help="Channel URL or playlist URL")

    # list command
    subparsers.add_parser("list", help="List all tracked sources")

    # check command
    check_parser = subparsers.add_parser("check", help="Daily check for a source")
    check_parser.add_argument("source", help="Source ID (channel URL or bare channel ID)")

    # check-all command
    check_all_parser = subparsers.add_parser("check-all", help="Check all tracked channels for new videos")
    check_all_parser.add_argument("--verbose", "-v", action="store_true", help="Show detailed output")

    # sync command
    sync_parser = subparsers.add_parser("sync", help="Process pending videos for a source")
    sync_parser.add_argument("source", help="Source ID (channel URL or bare channel ID)")

    # quota command
    subparsers.add_parser("quota", help="Show per-key quota state and recommended workers")

    # fetch command (escalation batch process)
    fetch_parser = subparsers.add_parser("fetch", help="Fetch transcripts using escalation chain (yt-dlp → Selenium)")
    fetch_parser.add_argument("--source", help="Process only this channel URL")
    fetch_parser.add_argument("--dry-run", action="store_true", help="Show what would be fetched without fetching")
    fetch_parser.add_argument("--workers", type=int, default=1, help="Number of parallel workers (default: 1)")

    # block command
    block_parser = subparsers.add_parser("block", help="Add a channel to the blocklist")
    block_parser.add_argument("url", help="Channel URL or @handle")

    # unblock command
    unblock_parser = subparsers.add_parser("unblock", help="Remove a channel from the blocklist")
    unblock_parser.add_argument("url", help="Channel URL or @handle")

    # remove command
    remove_parser = subparsers.add_parser("remove", help="Remove a channel and all its videos from the database")
    remove_parser.add_argument("url", help="Channel URL or @handle")

    # list-blocked command
    subparsers.add_parser("list-blocked", help="List all blocked channels")

    # history command
    history_parser = subparsers.add_parser(
        "history",
        help="Extract channels from YouTube watch history and add new ones",
    )
    history_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview channels without adding them",
    )
    history_parser.add_argument(
        "--min-history-videos",
        type=int,
        default=2,
        help="Minimum videos watched from a channel to qualify (default: 2)",
    )

    args = parser.parse_args()

    if args.command == "add":
        cmd_add(args.url)
    elif args.command == "list":
        cmd_list()
    elif args.command == "check":
        cmd_check(args.source)
    elif args.command == "check-all":
        cmd_check_all(verbose=args.verbose)
    elif args.command == "sync":
        cmd_sync(args.source)
    elif args.command == "quota":
        cmd_quota()
    elif args.command == "fetch":
        cmd_fetch(source_filter=args.source, dry_run=args.dry_run, workers=args.workers)
    elif args.command == "block":
        cmd_block(args.url)
    elif args.command == "unblock":
        cmd_unblock(args.url)
    elif args.command == "remove":
        cmd_remove(args.url)
    elif args.command == "list-blocked":
        cmd_list_blocked()
    elif args.command == "history":
        cmd_history(min_history_videos=args.min_history_videos, dry_run=args.dry_run)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
