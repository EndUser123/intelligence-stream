    def _build_worker_source_profile_totals_payload() -> dict[str, object]:
        return {
            "total": industrial_source_profile_totals["total"],
            "matched": industrial_source_profile_totals["matched"],
            "missing": industrial_source_profile_totals["missing"],
            "source_class_counts": dict(industrial_source_profile_totals["source_class_counts"]),
            "status_counts": dict(industrial_source_profile_totals["status_counts"]),
            "privacy_status_counts": dict(industrial_source_profile_totals["privacy_status_counts"]),
            "upload_status_counts": dict(industrial_source_profile_totals["upload_status_counts"]),
            "unavailable_reason_counts": dict(industrial_source_profile_totals["unavailable_reason_counts"]),
            "failure_reason_counts": dict(industrial_source_profile_totals["failure_reason_counts"]),
        }

    def _take_industrial_dispatch_groups(
        batch_queue: list[list[str]],
        worker_slots: int,
        batches_per_worker: int,
    ) -> list[list[list[str]]]:
        if worker_slots < 1:
            raise ValueError("worker_slots must be >= 1")
        if batches_per_worker < 1:
            raise ValueError("batches_per_worker must be >= 1")
        if not batch_queue:
            return []
        dispatch_count = min(worker_slots, len(batch_queue))
        groups: list[list[list[str]]] = [[] for _ in range(dispatch_count)]
        while batch_queue and any(len(group) < batches_per_worker for group in groups):
            for group in groups:
                if not batch_queue:
                    break
                if len(group) >= batches_per_worker:
                    continue
                group.append(batch_queue.pop(0))
        return [group for group in groups if group]

    def _run_industrial_worker(worker_id: int, worker_batches: list[list[str]]) -> tuple[int, dict[str, object], str, str]:
        launch = _build_industrial_worker_launch(
            worker_id=worker_id,
            worker_batches=worker_batches,
        )
        state_path = Path(str(launch["state_path"]))
        notebook_title = str(launch["notebook_title"])
        notebooklm_profile = str(launch["notebooklm_profile"])
        worker_label = str(launch["worker_label"])
        worker_env = launch["env"]
        with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False, encoding="utf-8") as tmp:
            json.dump(worker_batches, tmp)
            batch_file = Path(tmp.name)
        with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False, encoding="utf-8") as tmp:
            result_path = Path(tmp.name)
        started_at = time.monotonic()
        log_action(
            "fetch_worker_started",
            {
                "worker_id": worker_label,
                "batch_count": len(worker_batches),
                "video_count": sum(len(batch) for batch in worker_batches),
                "state_path": str(state_path),
                "notebook_title": notebook_title,
                "notebooklm_profile": notebooklm_profile,
            },
        )
        cmd = [
            sys.executable,
            "-m",
            "dev.worker_pool.worker_main",
            "--input",
            str(batch_file),
            "--state-path",
            str(state_path),
            "--notebook-title",
            notebook_title,
            "--notebooklm-profile",
            notebooklm_profile,
            "--worker-id",
            worker_label,
            "--result-path",
            str(result_path),
        ]
        try:
            proc = subprocess.run(cmd, capture_output=True, text=True, env=worker_env)
        finally:
            try:
                batch_file.unlink()
            except Exception:
                pass
        elapsed_s = round(time.monotonic() - started_at, 3)
        stdout_text = proc.stdout or ""
        summary = _load_worker_summary(result_path, stdout_text)
        if stdout_text:
            stdout_text = stdout_text.rstrip()
            if stdout_text:
                print(stdout_text)
        if proc.stderr:
            stderr_text = proc.stderr.rstrip()
            if stderr_text:
                print(stderr_text, file=sys.stderr)
        try:
            result_path.unlink()
        except Exception:
            pass
        log_action(
            "fetch_worker_finished",
            {
                "worker_id": worker_label,
                "batch_count": len(worker_batches),
                "video_count": sum(len(batch) for batch in worker_batches),
                "returncode": proc.returncode,
                "elapsed_s": elapsed_s,
                "summary": summary,
            },
        )
        return (worker_id, summary, proc.stdout or "", proc.stderr or "")

    def _service_industrial_workers(wait_for_completion: bool = False) -> None:
        nonlocal industrial_batch_queue, industrial_worker_executor, industrial_worker_futures
        nonlocal industrial_worker_slots_in_use, industrial_batches_processed, success_count, fail_count
        nonlocal industrial_first_worker_finished_at, industrial_last_worker_finished_at
        nonlocal industrial_completion_stall_alert_logged, industrial_oversized_dispatch_alert_logged

        if wait_for_completion and industrial_worker_futures:
            done, _ = wait(industrial_worker_futures, return_when=FIRST_COMPLETED)
        else:
            done, _ = wait(industrial_worker_futures, timeout=0, return_when=FIRST_COMPLETED)

        for future in done:
            industrial_worker_futures.remove(future)
            worker_id, summary, _stdout, _stderr = future.result()
            slot_id = industrial_worker_slots_in_use.pop(future, worker_id)
            batch_count = int(summary.get("batch_count", 0) or 0)
            video_count = int(summary.get("video_count", 0) or 0)
            succeeded = int(summary.get("succeeded", 0) or 0)
            failed = int(summary.get("failed", 0) or 0)
            industrial_batches_processed += batch_count
            success_count += succeeded
            fail_count += failed
            if industrial_first_worker_finished_at is None:
                industrial_first_worker_finished_at = time.monotonic() - fetch_started_at
            industrial_last_worker_finished_at = time.monotonic() - fetch_started_at
            industrial_completion_stall_alert_logged = False
            _add_worker_stage_totals(summary)
            if not industrial_oversized_dispatch_alert_logged and (
                batch_count > industrial_batches_per_worker
                or video_count > batch_size * industrial_batches_per_worker
            ):
                industrial_oversized_dispatch_alert_logged = True
                _log_worker_health_warning(
                    "oversized_worker_dispatch",
                    worker_id=f"worker-{slot_id:02d}",
                    batch_count=batch_count,
                    video_count=video_count,
                    batch_size=batch_size,
                    batches_per_worker=industrial_batches_per_worker,
                )
            log_action(
                "fetch_worker_dispatch_finished",
                {
                    "worker_id": f"worker-{slot_id:02d}",
                    "batch_count": batch_count,
                    "video_count": video_count,
                    "succeeded": succeeded,
                    "failed": failed,
                },
            )

        available_slots = max(0, workers - len(industrial_worker_futures))
        free_slots = [
            slot_id
            for slot_id in range(1, workers + 1)
            if slot_id not in industrial_worker_slots_in_use.values()
        ]
        log_action(
            "fetch_worker_dispatch_state",
            {
                "workers_requested": workers,
                "active_workers": len(industrial_worker_futures),
                "free_slots": len(free_slots),
                "queued_batches": len(industrial_batch_queue),
                "available_slots": available_slots,
                "first_worker_finished_at": industrial_first_worker_finished_at,
                "last_worker_finished_at": industrial_last_worker_finished_at,
                "wait_for_completion": wait_for_completion,
            },
        )
        if (
            not industrial_completion_stall_alert_logged
            and (industrial_worker_futures or industrial_batch_queue)
            and time.monotonic() - fetch_started_at >= 900
        ):
            if industrial_last_worker_finished_at is None:
                industrial_completion_stall_alert_logged = True
                _log_worker_health_warning("no_worker_completion_after_15m")
            else:
                stalled_for_s = time.monotonic() - fetch_started_at - industrial_last_worker_finished_at
                if stalled_for_s >= 900:
                    industrial_completion_stall_alert_logged = True
                    _log_worker_health_warning(
                        "no_worker_completion_after_15m_since_last_completion",
                    )
        if available_slots <= 0 or not industrial_batch_queue:
            return

        worker_groups = _take_industrial_dispatch_groups(
            industrial_batch_queue,
            available_slots,
            industrial_batches_per_worker,
        )
        if not worker_groups:
            return

        if industrial_worker_executor is None:
            industrial_worker_executor = ThreadPoolExecutor(max_workers=workers)

        total_batches = sum(len(group) for group in worker_groups)
        print(
            f"[source] Parallel industrial dispatch: {total_batches} batches "
            f"across {len(worker_groups)} workers..."
        )
        log_action(
            "fetch_worker_dispatch_started",
            {
                "workers": len(worker_groups),
                "batch_count": total_batches,
                "video_count": sum(len(batch) for batch in industrial_batch_queue),
                "industrial_batches_per_worker": industrial_batches_per_worker,
                "state_root": os.getenv(
                    "YTIS_INDUSTRIAL_WORKER_STATE_ROOT",
                    "P:/.data/yt-is/industrial-worker-states",
                ),
                "streaming": True,
            },
        )

        for slot_id, worker_batches in zip(free_slots, worker_groups):
            future = industrial_worker_executor.submit(
                _run_industrial_worker,
                slot_id,
                worker_batches,
            )
            industrial_worker_futures.add(future)
            industrial_worker_slots_in_use[future] = slot_id

    def _process_industrial_batch(batch_items: list[tuple[str, str]]) -> None:
        nonlocal industrial_batches_processed, success_count, fail_count, transcript_fallback_queue, transcript_fallback_processed_count
        if not batch_items:
            return
        industrial_batches_processed += 1
        batch = [vid for vid, _ in batch_items]
        source_map = {vid: source_url for vid, source_url in batch_items}
        print(
            f"[source] Processing batch {industrial_batches_processed} "
            f"({len(batch)} videos) via NotebookLM CLI batch..."
        )
        _log_first_download_started(
            "industrial_cli_batch",
            batch_index=industrial_batches_processed,
            batch_size=len(batch),
            first_video_id=batch[0],
        )
        results = process_industrial_batch_reusable(batch)
        for vid, (success, transcript, error) in results.items():
                if success and transcript:
                    set_cached_transcript(
                        vid,
                        "en",
                        "notebooklm",
                        transcript,
                        metadata={
                            "pipeline": "csf-source",
                            "route": "industrial_cli_batch",
                            "source_url": source_map.get(vid, ""),
                            "batch_index": industrial_batches_processed,
                            "batch_size": len(batch),
                        },
                    )
                    mark_complete(vid, last_stage="notebooklm")
                    success_count += 1
                    print(f"  ✓ {vid} (notebooklm)")
                else:
                    fail_count += 1
                    print(f"  ✗ {vid}: {error[:80]}")
                    source_url = source_map.get(vid, "")
                    if source_url and transcript_fallback_workers > 0:
                        log_action(
                            "transcript_fallback_queued",
                            {
                                "video_id": vid,
                                "source_url": source_url,
                                "reason": error[:120],
                                "queue_depth": len(transcript_fallback_queue) + 1,
                            },
                        )
                        transcript_fallback_processed_count += 1
                        transcript_fallback_queue.append((vid, source_url, True))
                    elif source_url:
                        log_action(
                            "transcript_fallback_disabled",
                            {
                                "video_id": vid,
                                "source_url": source_url,
                                "reason": error[:120],
                                "transcript_fallback_workers": transcript_fallback_workers,
                            },
                        )

    def _process_transcript_fallback(
        video_id: str,
        source_url: str,
        skip_notebooklm: bool,
    ) -> tuple[str, bool, str, str, str]:
        """Process a fallback video via the transcript chain."""
        if has_cached_transcript(video_id):
            return (video_id, True, "cache", "", "")
        nonlocal transcript_fallback_last_start_at
        with transcript_fallback_start_lock:
            now = time.monotonic()
            elapsed = now - transcript_fallback_last_start_at
            if elapsed < transcript_fallback_min_start_interval_s:
                time.sleep(transcript_fallback_min_start_interval_s - elapsed)
            transcript_fallback_last_start_at = time.monotonic()
        log_action(
            "transcript_fallback_started",
            {
                "video_id": video_id,
                "source_url": source_url,
                "queue_depth": len(transcript_fallback_queue),
                "transcript_fallback_workers": transcript_fallback_workers,
                "min_start_interval_s": transcript_fallback_min_start_interval_s,
                "skip_notebooklm": skip_notebooklm,
            },
        )
        _log_first_download_started(
            "transcript_fallback",
            video_id=video_id,
            source_url=source_url,
        )
        admission_metadata = None
        try:
            for entry in get_entries_for_source_details(source_url):
                if str(entry.get("video_id")) == video_id:
                    admission_metadata = {
                        "title": entry.get("title"),
                        "description": entry.get("description"),
                        "duration": entry.get("duration"),
                        "privacy_status": entry.get("privacy_status"),
                        "upload_status": entry.get("upload_status"),
                        "is_live_content": entry.get("is_live_content"),
                        "unavailable_reason": entry.get("unavailable_reason"),
                    }
                    break
        except Exception:
            admission_metadata = None
        config = LanguageConfig(prefer_lang="en", allow_translation=False)
        result = fetch_transcript_chain(
            video_id,
            config,
            skip_notebooklm=skip_notebooklm,
            admission_metadata=admission_metadata,
        )
        if result.transcript:
            set_cached_transcript(
                video_id,
                result.lang or "en",
                result.source,
                result.transcript,
                metadata={
                    "pipeline": "csf-source",
                    "route": "transcript_fallback",
                    "source_url": source_url,
                    "skip_notebooklm": skip_notebooklm,
                },
            )
            qm = None
            if result.view_count:
                import json as _json
                qm = _json.dumps({
                    "view_count": result.view_count,
                    "like_count": result.like_count,
                    "comment_count": result.comment_count,
                    "duration": result.duration,
                    "title": result.video_title,
                    "description": (result.video_description or "")[:500] if result.video_description else None,
                    "like_rate": round(result.like_count / result.view_count, 6) if result.view_count and result.like_count else None,
                    "comment_rate": round(result.comment_count / result.view_count, 6) if result.view_count and result.comment_count else None,
                })
            mark_complete(video_id, last_stage=result.source or "transcript_fallback", quality_metrics=qm)
            log_action(
                "transcript_fallback_completed",
                {
                    "video_id": video_id,
                    "source_url": source_url,
                    "status": "success",
                    "source": result.source or "transcript_fallback",
                    "lang": result.lang or "en",
                    "chars": len(result.transcript),
                },
            )
            return (video_id, True, result.source or "transcript_fallback", result.transcript, "")
        failure_reason = result.failure_reason or "unknown"
        last_stage = result.last_stage or "unknown"
        error_text = result.error or "No transcript available"
        log_action(
            "transcript_fallback_completed",
            {
                "video_id": video_id,
                "source_url": source_url,
                "status": "failed",
                "failure_reason": failure_reason,
                "last_stage": result.last_stage,
                "error": error_text,
            },
        )
        return (video_id, False, "", "", f"[{failure_reason} @ {last_stage}] {error_text}")

    def _service_transcript_fallback_workers(wait_for_completion: bool = False) -> None:
        nonlocal transcript_fallback_queue, transcript_fallback_worker_executor, transcript_fallback_worker_futures
        nonlocal transcript_fallback_worker_seq, success_count, fail_count

        if transcript_fallback_workers <= 0:
            while transcript_fallback_queue:
                video_id, source_url, _skip_notebooklm = transcript_fallback_queue.popleft()
                fail_count += 1
                log_action(
                    "transcript_fallback_skipped_disabled",
                    {
                        "video_id": video_id,
                        "source_url": source_url,
                        "transcript_fallback_workers": transcript_fallback_workers,
                    },
                )
            return

        if wait_for_completion and transcript_fallback_worker_futures:
            done, _ = wait(transcript_fallback_worker_futures, return_when=FIRST_COMPLETED)
        else:
            done, _ = wait(transcript_fallback_worker_futures, timeout=0, return_when=FIRST_COMPLETED)

        for future in done:
            transcript_fallback_worker_futures.remove(future)
            video_id, success, source, transcript, error = future.result()
            if success and transcript:
                success_count += 1
                print(f"  ✓ {video_id} ({source})")
            else:
                fail_count += 1
                print(f"  ✗ {video_id}: {error[:80]}")

        available_slots = max(0, workers - len(transcript_fallback_worker_futures))
        if available_slots <= 0 or not transcript_fallback_queue:
            return

        if transcript_fallback_worker_executor is None:
            transcript_fallback_worker_executor = ThreadPoolExecutor(max_workers=transcript_fallback_workers)

        submit_count = min(
            max(0, transcript_fallback_workers - len(transcript_fallback_worker_futures)),
            len(transcript_fallback_queue),
        )
        for _ in range(submit_count):
            video_id, source_url, skip_notebooklm = transcript_fallback_queue.popleft()
            transcript_fallback_worker_seq += 1
            worker_label = f"transcript-fallback-{transcript_fallback_worker_seq:02d}"
            future = transcript_fallback_worker_executor.submit(
                _process_transcript_fallback,
                video_id,
                source_url,
                skip_notebooklm,
            )
            transcript_fallback_worker_futures.add(future)

    for channel_index, (channel_url, playlist_id) in enumerate(channels, start=1):
        pending_entries = get_entries_for_source_details(channel_url)
        for entry in pending_entries:
            video_id = str(entry["video_id"])
            status = str(entry["status"])
            if status != "pending":
                continue
            if has_cached_transcript(video_id):
                cached_count += 1
                if len(cached_sample) < 10:
                    cached_sample.append(
                        {
                            "video_id": video_id,
                            "source": channel_url,
                            "channel_index": channel_index,
                        }
                    )
                continue
            neg_cache = get_negative_cache(video_id)
            if neg_cache:
                negative_cache_count += 1
                reason = str(neg_cache.get("reason") or "unknown").lower()
                negative_cache_reason_counts[reason] += 1
                if len(negative_cache_sample) < 10:
                    negative_cache_sample.append(
                        {
                            "video_id": video_id,
                            "source": channel_url,
                            "channel_index": channel_index,
                            "reason": reason,
                            "last_stage": neg_cache.get("last_stage"),
                        }
                    )
                continue

            bucket, reason = _classify_pending_entry(entry)
            if bucket == "terminal":
                terminal_count += 1
                terminal_reason_counts[str(reason or "unavailable").lower()] += 1
                if len(terminal_sample) < 10:
                    terminal_sample.append(
                        {
                            "video_id": video_id,
                            "source": channel_url,
                            "reason": reason or "unavailable",
                            "privacy_status": entry.get("privacy_status"),
                            "upload_status": entry.get("upload_status"),
                            "unavailable_reason": entry.get("unavailable_reason"),
                        }
                    )
                terminal_entries.append(
                    BatchEntry(
                        video_id=video_id,
                        status="failed",
                        source=channel_url,
                        has_captions=entry.get("has_captions") if isinstance(entry.get("has_captions"), bool) else None,
                        duration=entry.get("duration") if isinstance(entry.get("duration"), int) else None,
                        privacy_status=entry.get("privacy_status") if isinstance(entry.get("privacy_status"), str) else None,
                        upload_status=entry.get("upload_status") if isinstance(entry.get("upload_status"), str) else None,
                        is_live_content=entry.get("is_live_content") if isinstance(entry.get("is_live_content"), bool) else None,
                        unavailable_reason=entry.get("unavailable_reason") if isinstance(entry.get("unavailable_reason"), str) else None,
                        failure_reason=f"terminal:{reason or 'unavailable'}",
                    )
                )
                continue
            pending_discovered_total += 1
            if bucket == "notebooklm":
                notebooklm_pending_count += 1
                pending_buffer.append((video_id, channel_url))
            else:
                transcript_fallback_queued_count += 1
                transcript_fallback_queue.append((video_id, channel_url, True))

            if notebooklm_pending_count >= backlog_threshold or transcript_fallback_queued_count >= backlog_threshold:
                industrial_selected = True

            if max_items is not None and pending_discovered_total >= max_items:
                max_items_reached = True
                break

            if not dry_run and industrial_selected and len(pending_buffer) >= batch_size:
                while len(pending_buffer) >= batch_size:
                    batch_items = [pending_buffer.popleft() for _ in range(batch_size)]
                    industrial_batch_queue.append([vid for vid, _src in batch_items])
                    if industrial_parallel_enabled:
                        _service_industrial_workers(wait_for_completion=False)
        if max_items_reached:
            print(f"[source] Pending item limit reached at {pending_discovered_total}; stopping scan early.")
            log_action(
                "fetch_scan_limit_reached",
                {
                    "source_filter": source_filter,
                    "max_items": max_items,
                    "pending_discovered_total": pending_discovered_total,
                    "notebooklm_pending_count": notebooklm_pending_count,
                    "transcript_fallback_queued_count": transcript_fallback_queued_count,
                },
            )
            break

        if transcript_fallback_queue:
            _service_transcript_fallback_workers(wait_for_completion=False)

        elapsed_since_status = time.monotonic() - scan_last_status_at
        if channel_index == channel_count:
            _emit_scan_status(channel_index, "final_channel")
        elif elapsed_since_status >= scan_status_interval_s:
            _emit_scan_status(channel_index, "elapsed_interval")
        elif channel_index == 1:
            _emit_scan_status(channel_index, "first_channel")
        elif channel_index % scan_progress_interval == 0:
            _emit_scan_status(channel_index, "channel_checkpoint")

    if terminal_entries and not dry_run:
        set_status_batch(terminal_entries)
        print(f"[source] Marked {len(terminal_entries)} terminal videos as failed/skipped")
        log_action(
            "fetch_terminal_marked",
            {
                "count": len(terminal_entries),
                "sample": terminal_sample,
            },
        )

    log_action(
        "fetch_triage_summary",
        {
            "source_filter": source_filter,
            "channels_active_total": channel_count,
            "pending_total": pending_discovered_total,
            "max_items": max_items,
            "max_items_reached": max_items_reached,
            "cached_total": cached_count,
            "cached_hit_rate": round(cached_count / (cached_count + pending_discovered_total + terminal_count), 4)
            if (cached_count + pending_discovered_total + terminal_count)
            else 0.0,
            "cached_sample": cached_sample,
            "negative_cache_count": negative_cache_count,
            "negative_cache_reason_counts": dict(negative_cache_reason_counts),
            "negative_cache_sample": negative_cache_sample,
            "terminal_count": terminal_count,
            "terminal_reason_counts": dict(terminal_reason_counts),
            "transcript_fallback_processed_count": transcript_fallback_processed_count,
            "transcript_fallback_queued_count": transcript_fallback_queued_count,
            "notebooklm_pending_count": notebooklm_pending_count,
            "industrial_batches_processed": industrial_batches_processed,
        },
    )

    total_pending = pending_discovered_total
    use_industrial = (
        industrial_selected
        or notebooklm_pending_count >= backlog_threshold
        or transcript_fallback_queued_count > 0
    )
    if notebooklm_pending_count > 0:
        strategy_name = "industrial_cli_batch" if use_industrial else "surgical_chain"
        backend_name = "notebooklm_cli_batch"
    elif transcript_fallback_queued_count > 0:
        strategy_name = "transcript_fallback_chain"
        backend_name = "yt_dlp_plus_selenium"
    else:
        strategy_name = "surgical_chain"
        backend_name = "yt_dlp_plus_selenium"
    deleted = 0
    failed = 0
    log_action(
        "fetch_scan_completed",
        {
            "source_filter": source_filter,
            "channels_tracked_total": tracked_count,
            "channels_blocked_total": blocked_count,
            "channels_active_total": channel_count,
            "pending_total": total_pending,
            "max_items": max_items,
            "max_items_reached": max_items_reached,
            "cached_total": cached_count,
            "cached_hit_rate": round(cached_count / (cached_count + total_pending + terminal_count), 4)
            if (cached_count + total_pending + terminal_count)
            else 0.0,
            "cached_sample": cached_sample,
            "negative_cache_count": negative_cache_count,
            "negative_cache_reason_counts": dict(negative_cache_reason_counts),
            "negative_cache_sample": negative_cache_sample,
            "terminal_count": terminal_count,
            "terminal_reason_counts": dict(terminal_reason_counts),
            "transcript_fallback_processed_count": transcript_fallback_processed_count,
            "transcript_fallback_queued_count": transcript_fallback_queued_count,
            "notebooklm_pending_count": notebooklm_pending_count,
            "elapsed_s": round(time.monotonic() - scan_started_at, 3),
        },
    )
    print(
        f"[source] Preflight scan complete: {channel_count} active channels, "
        f"{total_pending} pending, {cached_count} cached, "
        f"{negative_cache_count} neg-cache, {terminal_count} terminal, {notebooklm_pending_count} notebooklm, "
        f"{transcript_fallback_queued_count} transcript-fallback"
    )
    if cached_sample:
        cached_ids = ", ".join(item["video_id"] for item in cached_sample)
        print(f"[source] Cached sample: {cached_ids}")
    if negative_cache_sample:
        neg_ids = ", ".join(item["video_id"] for item in negative_cache_sample)
        print(f"[source] Negative-cache sample: {neg_ids}")
    if not dry_run and industrial_selected and pending_buffer:
        industrial_batch_queue.append([vid for vid, _src in pending_buffer])
        pending_buffer.clear()
    if industrial_parallel_enabled:
        _service_industrial_workers(wait_for_completion=False)
    print(f"[source] Escalation Batch Process")
    print(f"[source] Channels: {channel_count} active / {tracked_count} tracked")
    print(f"[source] Already cached: {cached_count}")
    if cached_sample:
        cached_ids = ", ".join(item["video_id"] for item in cached_sample)
        print(f"[source] Cached sample: {cached_ids}")
    print(f"[source] Negative-cache skips: {negative_cache_count}")
    if negative_cache_sample:
        neg_ids = ", ".join(item["video_id"] for item in negative_cache_sample)
        print(f"[source] Negative-cache sample: {neg_ids}")
    print(f"[source] Pending extraction: {total_pending}")
    if max_items is not None:
        print(f"[source] Run limit: {max_items} pending items")
    print(f"[source] Mode: {'DRY RUN' if dry_run else 'LIVE'}")
    if dry_run:
        print("[source] Dry run complete. Use without --dry-run to fetch transcripts.")
        _log_fetch_completed(
            source_filter=source_filter,
            strategy=strategy_name,
            backend=backend_name,
            backlog_threshold=backlog_threshold,
            batch_size=batch_size,
            max_items=max_items,
            workers=workers,
            channels_tracked_total=tracked_count,
            channels_blocked_total=blocked_count,
            channels_active_total=channel_count,
            pending_total=total_pending,
            cached_total=cached_count,
            cached_hit_rate=round(cached_count / (cached_count + total_pending + terminal_count), 4)
            if (cached_count + total_pending + terminal_count)
            else 0.0,
            cached_sample=cached_sample,
            negative_cache_count=negative_cache_count,
            negative_cache_reason_counts=dict(negative_cache_reason_counts),
            negative_cache_sample=negative_cache_sample,
            route_no_captions_to_fallback=route_no_captions_to_fallback,
            industrial_batches_processed=industrial_batches_processed,
            notebooklm_pending_count=notebooklm_pending_count,
            transcript_fallback_processed_count=transcript_fallback_processed_count,
            transcript_fallback_queued_count=transcript_fallback_queued_count,
            terminal_count=terminal_count,
            terminal_reason_counts=dict(terminal_reason_counts),
            worker_cleanup_deleted=deleted,
            worker_cleanup_failed=failed,
            success_count=success_count,
            fail_count=fail_count,
            skip_count=skip_count,
            elapsed_s=round(time.monotonic() - fetch_started_at, 3),
            status="dry_run",
            worker_source_profile_totals=_build_worker_source_profile_totals_payload(),
        )
        return
    use_industrial = (
        industrial_selected
        or notebooklm_pending_count >= backlog_threshold
        or transcript_fallback_queued_count > 0
    )
    if notebooklm_pending_count > 0:
        strategy_name = "industrial_cli_batch" if use_industrial else "surgical_chain"
        backend_name = "notebooklm_cli_batch"
    elif transcript_fallback_queued_count > 0:
        strategy_name = "transcript_fallback_chain"
        backend_name = "yt_dlp_plus_selenium"
    else:
        strategy_name = "surgical_chain"
        backend_name = "yt_dlp_plus_selenium"
    log_action(
        "fetch_strategy_selected",
        {
            "source_filter": source_filter,
            "strategy": strategy_name,
            "backend": backend_name,
            "backlog_threshold": backlog_threshold,
            "batch_size": batch_size,
            "workers": workers,
            "channels_tracked_total": tracked_count,
            "channels_blocked_total": blocked_count,
            "channels_active_total": channel_count,
            "pending_total": total_pending,
            "cached_total": cached_count,
            "cached_hit_rate": round(cached_count / (cached_count + total_pending + terminal_count), 4)
            if (cached_count + total_pending + terminal_count)
            else 0.0,
            "cached_sample": cached_sample,
            "negative_cache_count": negative_cache_count,
            "negative_cache_reason_counts": dict(negative_cache_reason_counts),
            "negative_cache_sample": negative_cache_sample,
            "terminal_count": terminal_count,
            "terminal_reason_counts": dict(terminal_reason_counts),
            "industrial_selected": industrial_selected,
            "use_industrial": use_industrial,
            "notebooklm_pending_count": notebooklm_pending_count,
            "transcript_fallback_queued_count": transcript_fallback_queued_count,
        },
    )
    deleted = 0
    failed = 0
    if total_pending == 0:
        print("[source] All transcripts already cached. Nothing to do.")
        _log_fetch_completed(
            source_filter=source_filter,
            strategy=strategy_name,
            backend=backend_name,
            backlog_threshold=backlog_threshold,
            batch_size=batch_size,
            max_items=max_items,
            workers=workers,
            channels_tracked_total=tracked_count,
            channels_blocked_total=blocked_count,
            channels_active_total=channel_count,
            pending_total=total_pending,
            cached_total=cached_count,
            cached_hit_rate=round(cached_count / (cached_count + total_pending + terminal_count), 4)
            if (cached_count + total_pending + terminal_count)
            else 0.0,
            cached_sample=cached_sample,
            negative_cache_count=negative_cache_count,
            negative_cache_reason_counts=dict(negative_cache_reason_counts),
            negative_cache_sample=negative_cache_sample,
            route_no_captions_to_fallback=route_no_captions_to_fallback,
            industrial_batches_processed=industrial_batches_processed,
            notebooklm_pending_count=notebooklm_pending_count,
            transcript_fallback_processed_count=transcript_fallback_processed_count,
            transcript_fallback_queued_count=transcript_fallback_queued_count,
            terminal_count=terminal_count,
            terminal_reason_counts=dict(terminal_reason_counts),
            worker_cleanup_deleted=deleted,
            worker_cleanup_failed=failed,
            success_count=success_count,
            fail_count=fail_count,
            skip_count=skip_count,
            elapsed_s=round(time.monotonic() - fetch_started_at, 3),
            status="no_pending",
            worker_source_profile_totals=_build_worker_source_profile_totals_payload(),
        )
        return
    if notebooklm_pending_count > 0 and use_industrial:
        print("[source] Strategy: Industrial (Batch NLM)")
        print("[source] Method: NotebookLM CLI batch for captioned/no-captions items; live items use transcript fallback")
    elif notebooklm_pending_count > 0:
        print("[source] Strategy: Surgical (Chain)")
        print("[source] Method: captioned/no-captions items use NotebookLM chain; live items use transcript fallback")
    elif transcript_fallback_queued_count > 0:
        print("[source] Strategy: Transcript Fallback")
        print("[source] Method: transcript fallback chain")
    else:
        print(
            f"[source] Strategy: {'Industrial (Batch NLM)' if use_industrial else 'Surgical (Chain)'}"
        )
        print("[source] Method: yt-dlp → cookies → Selenium escalation chain")
    print(f"[source] Workers: {workers}")
    print()

    # Ensure NLM is authenticated before any live fetch run.
    login_check = subprocess.run(
        ["nlm", "login", "--check"],
        capture_output=True,
        text=True,
        timeout=30,
    )
    if login_check.returncode != 0:
        print("[source] NLM auth expired, re-authenticating...", file=sys.stderr)
        login_res = subprocess.run(["nlm", "login"], capture_output=True, text=True, timeout=120)
        if login_res.returncode != 0:
            print(f"[source] FATAL: NLM login failed: {login_res.stderr}", file=sys.stderr)
            sys.exit(1)
        print("[source] NLM re-authenticated.", file=sys.stderr)

    industrial_run_id = uuid.uuid4().hex
    os.environ["YTIS_INDUSTRIAL_RUN_ID"] = industrial_run_id

    if workers > 1:
        deleted, failed = cleanup_stale_worker_notebooks(delete=True)
        print(
            f"[source] Pre-flight worker notebook cleanup: {deleted} worker notebooks deleted, {failed} failed"
        )
        log_action(
            "fetch_worker_prewarm_summary",
            {
                "workers_requested": workers,
                "workers_active": workers,
                "batches": 0,
                "worker_slots": workers,
                "prewarm_expected": workers,
                "cleanup_deleted": deleted,
                "cleanup_failed": failed,
                "run_id": industrial_run_id,
                "state_root": os.getenv(
                    "YTIS_INDUSTRIAL_WORKER_STATE_ROOT",
                    "P:/.data/yt-is/industrial-worker-states",
                ),
                "streaming": True,
                "status": "planned",
            },
        )
    else:
        deleted = 0
        failed = 0

    def _industrial_parallel_enabled() -> bool:
        disable_flag = os.getenv("YTIS_DISABLE_INDUSTRIAL_PARALLEL", "").strip().lower()
        return workers > 1 and disable_flag not in {"1", "true", "yes", "on"}

    def _split_batches_for_workers(batch_queue: list[list[str]], worker_count: int) -> list[list[list[str]]]:
        if worker_count < 1:
            raise ValueError("worker_count must be >= 1")
        if not batch_queue:
            return []
        effective_worker_count = min(worker_count, len(batch_queue))
        groups: list[list[list[str]]] = [[] for _ in range(effective_worker_count)]
        for idx, batch in enumerate(batch_queue):
            groups[idx % effective_worker_count].append(batch)
        return groups

    if use_industrial:
        # --- INDUSTRIAL PATH: NotebookLM CLI batch content fetch ---
        # Group the backlog into batches and run them through isolated workers.
        try:
            if transcript_fallback_queue:
                _service_transcript_fallback_workers(wait_for_completion=False)
            if dry_run:
                pass
            elif industrial_parallel_enabled:
                while industrial_batch_queue or industrial_worker_futures or transcript_fallback_queue or transcript_fallback_worker_futures:
                    _service_industrial_workers(wait_for_completion=True)
                    _service_transcript_fallback_workers(wait_for_completion=True)
            else:
                while industrial_batch_queue:
                    batch = industrial_batch_queue.pop(0)
                    _process_industrial_batch([(vid, "") for vid in batch])
                while transcript_fallback_queue or transcript_fallback_worker_futures:
                    _service_transcript_fallback_workers(wait_for_completion=True)
        finally:
            if industrial_worker_executor is not None:
                industrial_worker_executor.shutdown(wait=True, cancel_futures=False)
            if transcript_fallback_worker_executor is not None:
                transcript_fallback_worker_executor.shutdown(wait=True, cancel_futures=False)
            close_reusable_ingestor()

    else:
        # --- SURGICAL PATH: Sequential Escalation Chain ---
        all_pending = [(vid, src, False) for vid, src in pending_buffer]
        all_pending.extend(transcript_fallback_queue)
        transcript_fallback_queue.clear()
        def _process_video(video_id: str, source_url: str, skip_notebooklm: bool) -> tuple[str, bool, str, str]:
            """Process a single video using the escalation chain."""
            if has_cached_transcript(video_id):
                return (video_id, True, "cache", "")

            _log_first_download_started(
                "surgical",
                video_id=video_id,
                source_url=source_url,
            )
            config = LanguageConfig(prefer_lang="en", allow_translation=False)
            result = fetch_transcript_chain(video_id, config, skip_notebooklm=skip_notebooklm)

            if result.transcript:
                set_cached_transcript(
                    video_id,
                    result.lang or "en",
                    result.source,
                    result.transcript,
                    metadata=build_transcript_cache_metadata(
                        result,
                        extra={
                            "pipeline": "csf-source",
                            "route": "surgical",
                            "source_url": source_url,
                            "skip_notebooklm": skip_notebooklm,
                        },
                    ),
                )
                # Build quality metrics JSON from engagement fields captured during fetch
                qm = None
                if result.view_count:
                    import json as _json
                    qm = _json.dumps({
                        "view_count": result.view_count,
                        "like_count": result.like_count,
                        "comment_count": result.comment_count,
                        "duration": result.duration,
                        "title": result.video_title,
                        "description": (result.video_description or "")[:500] if result.video_description else None,
                        "like_rate": round(result.like_count / result.view_count, 6) if result.view_count and result.like_count else None,
                        "comment_rate": round(result.comment_count / result.view_count, 6) if result.view_count and result.comment_count else None,
                    })
                mark_complete(video_id, last_stage=result.source, quality_metrics=qm)
                return (video_id, True, result.source, "")
            else:
                set_status(video_id, "failed")
                return (video_id, False, "", result.error or "No transcript available")

        print(f"[source] Starting Surgical Ingest (Sequential Escalation)...")
        with ThreadPoolExecutor(max_workers=workers) as executor:
            futures = {
                executor.submit(_process_video, vid, src, skip_notebooklm): (idx, vid)
                for idx, (vid, src, skip_notebooklm) in enumerate(all_pending, 1)
            }
            for future in as_completed(futures):
                idx, video_id = futures[future]
                try:
                    video_id, success, source_used, error = future.result()
                    if success:
                        if source_used == "cache":
                            skip_count += 1
                        else:
                            success_count += 1
                            print(f"[{idx}/{total_pending}] ✓ {video_id} ({source_used})")
                    else:
                        fail_count += 1
                        print(f"[{idx}/{total_pending}] ✗ {video_id}: {error[:80]}")
                except Exception as e:
                    fail_count += 1
                    print(f"[{idx}/{total_pending}] ✗ Error: {e}")

    # Summary
    stage_totals = _build_worker_stage_totals_payload()
    print()
    print("[source] === Escalation Batch Complete ===")
    print(f"[source] Successfully extracted: {success_count}")
    print(f"[source] Failed: {fail_count}")
    print(f"[source] Skipped (cached): {skip_count}")
    print(f"[source] Skipped (negative cache): {negative_cache_count}")
    print(f"[source] Skipped (terminal): {terminal_count}")
    print(f"[source] NotebookLM-eligible: {notebooklm_pending_count}")
    print(f"[source] Routed to transcript fallback: {transcript_fallback_processed_count}")
    if terminal_reason_counts:
        top_terminal_reasons = ", ".join(
            f"{name}={count}" for name, count in terminal_reason_counts.most_common(5)
        )
        print(f"[source] Terminal reasons: {top_terminal_reasons}")
    if negative_cache_reason_counts:
        top_negative_reasons = ", ".join(
            f"{name}={count}" for name, count in negative_cache_reason_counts.most_common(5)
        )
        print(f"[source] Negative-cache reasons: {top_negative_reasons}")
    if workers > 1:
        print(f"[source] Worker notebook cleanup: {deleted} deleted, {failed} failed")
    if stage_totals["batch_elapsed_s_total"] > 0:
        print(
            "[source] Stage totals: "
            f"startup={stage_totals['startup_prepare_total_elapsed_s_total']:.1f}s, "
            f"setup={stage_totals['setup_elapsed_s_total']:.1f}s, "
            f"add={stage_totals['add_sources_elapsed_s_total']:.1f}s, "
            f"extract={stage_totals['extract_elapsed_s_total']:.1f}s, "
            f"cleanup={stage_totals['cleanup_elapsed_s_total']:.1f}s, "
            f"batch={stage_totals['batch_elapsed_s_total']:.1f}s"
        )
    worker_source_profile_totals = _build_worker_source_profile_totals_payload()
    if worker_source_profile_totals["total"] > 0:
        top_classes = sorted(
            worker_source_profile_totals["source_class_counts"].items(),
            key=lambda item: (-item[1], item[0]),
        )[:6]
        if top_classes:
            class_summary = ", ".join(f"{name}={count}" for name, count in top_classes)
            print(f"[source] Worker source profile: {class_summary}")
    elapsed_s = round(time.monotonic() - fetch_started_at, 3)
    processed_count = success_count + fail_count + skip_count
    print(f"[source] Total discovered: {total_pending}")
    print(f"[source] Total processed outcomes: {processed_count}")
    _log_fetch_completed(
        source_filter=source_filter,
        strategy=strategy_name,
        backend=backend_name,
        backlog_threshold=backlog_threshold,
        batch_size=batch_size,
        max_items=max_items,
        workers=workers,
        channels_tracked_total=tracked_count,
        channels_blocked_total=blocked_count,
        channels_active_total=channel_count,
        pending_total=total_pending,
        cached_total=cached_count,
        cached_hit_rate=round(cached_count / (cached_count + total_pending + terminal_count), 4)
        if (cached_count + total_pending + terminal_count)
        else 0.0,
        cached_sample=cached_sample,
        negative_cache_count=negative_cache_count,
        negative_cache_reason_counts=dict(negative_cache_reason_counts),
        negative_cache_sample=negative_cache_sample,
        route_no_captions_to_fallback=route_no_captions_to_fallback,
        industrial_batches_processed=industrial_batches_processed,
        notebooklm_pending_count=notebooklm_pending_count,
        transcript_fallback_processed_count=transcript_fallback_processed_count,
        transcript_fallback_queued_count=transcript_fallback_queued_count,
        terminal_count=terminal_count,
        terminal_reason_counts=dict(terminal_reason_counts),
        worker_cleanup_deleted=deleted,
        worker_cleanup_failed=failed,
        worker_stage_totals=stage_totals,
        worker_source_profile_totals=worker_source_profile_totals,
        success_count=success_count,
        fail_count=fail_count,
        skip_count=skip_count,
        elapsed_s=elapsed_s,
        status="completed",
    )


def cmd_quota() -> None:
    """Print current per-key quota state and recommend workers."""
    quota = get_quota_status()
    if not quota:
        print("[source] No API keys configured.")
        return

    keys = _get_api_keys()
    print(f"API Keys: {len(keys)}")
    print(f"{'Key':<8} {'Calls':>6} {'Units':>8} {'Exhausted':>10} {'Since':<30}")
    print("-" * 70)
    for idx in sorted(quota.keys()):
        state = quota[idx]
        exhausted = "YES" if state["exhausted"] else "no"
        since = state.get("exhausted_at", "-")
        print(f"Key {idx:<3} {state['calls_made']:>6} {state['units_consumed']:>8} {exhausted:>10} {since or '-'}")

    total_exhausted = sum(1 for v in quota.values() if v.get("exhausted", False))
    total_units = sum(v["units_consumed"] for v in quota.values())
    remaining_per_key = 10000 - total_units // max(len(keys), 1)
    available = sum(10000 - v["units_consumed"] for v in quota.values() if not v.get("exhausted", False))

    # Recommend workers based on remaining non-exhausted keys
    non_exhausted = len(keys) - total_exhausted
    if total_exhausted >= len(keys):
        recommended_workers = 0
    elif non_exhausted == 1:
        recommended_workers = 1  # only one key alive, serial to avoid contention
    else:
        recommended_workers = min(non_exhausted, 8)

    print()
    print(f"Total consumed: ~{total_units} units across {len(keys)} keys")
    print(f"Non-exhausted keys: {non_exhausted}")
    print(f"Recommended max workers: {recommended_workers}")
    print(f"[source] Can proceed for ~{available // 5} more channel additions")


def cmd_block(url: str) -> None:
    """Add a channel to the blocklist."""
    # Normalize the URL
    channel_id = parse_channel_url(url)
    if channel_id:
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"
    else:
        canonical_url = url

    block_channel(canonical_url)
    print(f"[source] Blocked: {canonical_url}")


def cmd_unblock(url: str) -> None:
    """Remove a channel from the blocklist."""
    channel_id = parse_channel_url(url)
    if channel_id:
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"
    else:
        canonical_url = url

    was_blocked = unblock_channel(canonical_url)
    if was_blocked:
        print(f"[source] Unblocked: {canonical_url}")
    else:
        print(f"[source] Not on blocklist: {canonical_url}")


def cmd_list_blocked() -> None:
    """List all blocked channels."""
    blocked = get_all_blocked_channels()
    if not blocked:
        print("[source] No blocked channels.")
        return
    print("[source] Blocked channels:")
    for channel_url, blocked_at in blocked:
        print(f"  {channel_url}  (blocked {blocked_at[:19].replace('T', ' ')})")


def cmd_remove(url: str) -> None:
    """Remove a channel and all its video entries from the database."""
    channel_id = parse_channel_url(url)
    if channel_id:
        if channel_id.startswith("@"):
            canonical_url = f"https://www.youtube.com/{channel_id}"
        else:
            canonical_url = f"https://www.youtube.com/channel/{channel_id}"
    else:
        canonical_url = url

    deleted = delete_channel(canonical_url)
    if deleted:
        print(f"[source] Removed: {canonical_url}")
    else:
        print(f"[source] Not found in database: {canonical_url}")


def _cmd_playlist_import(
    playlist_kind: str,
    playlist_url: str,
    min_playlist_videos: int,
    dry_run: bool = False,
) -> None:
    """Extract channels from a YouTube playlist and add new ones.

    Three filters applied:
    - subscriber_count > 100  (skip tiny/brand-new channels)
    - video_count > 2        (skip barely-active channels)
    - most recent video within 3 months (skip dormant/abandoned channels)

    Requires: YOUTUBE_API_KEY
    """
    import os
    from datetime import datetime, timezone, timedelta
    from urllib.request import urlopen
    from xml.etree import ElementTree as ET

    playlist_label = "watch later" if playlist_kind == "watchlater" else "history"

    print(f"[source] Step 1: Fetching {playlist_label} video IDs (yt-dlp Python API, no API quota)...")

    # Find cookies file: prefer exported file, fall back to browser extraction
    cookie_file = os.path.expanduser("~/youtube_cookies.txt")
    if not os.path.exists(cookie_file):
        # Fall back to browser cookies
        cookie_file = None

    try:
        import yt_dlp
        ydl_opts = {
            "quiet": True,
            "cookiefile": cookie_file,
            "extract_flat": "in_playlist",
            "skip_download": True,
            "socket_timeout": 60,
        }
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            result = ydl.extract_info(playlist_url, download=False)
            entries = result.get("entries", []) or []
    except Exception as e:
        print(f"[source] Error fetching {playlist_label}: {e}", file=sys.stderr)
        sys.exit(1)

    playlist_entries = [e for e in entries if e and e.get("id")]
    video_ids = [str(e["id"]) for e in playlist_entries]
    print(f"[source] Found {len(video_ids)} video IDs in {playlist_label}")

    if not video_ids:
        print(f"[source] No videos found in {playlist_label}.", file=sys.stderr)
        sys.exit(1)

    run_id = record_playlist_import_run(
        playlist_kind=playlist_kind,
        playlist_url=playlist_url,
        command=f"csf-source {playlist_kind}",
        cookie_source=cookie_file or "browser",
        total_items=len(video_ids),
        notes={
            "playlist_label": playlist_label,
            "dry_run": dry_run,
            "min_playlist_videos": min_playlist_videos,
        },
    )
    for idx, entry in enumerate(playlist_entries, start=1):
        video_id = str(entry.get("id") or "")
        record_playlist_import_item(
            run_id=run_id,
            item_id=f"{playlist_kind}:{idx}:{video_id}",
            playlist_kind=playlist_kind,
            playlist_url=playlist_url,
            playlist_position=idx,
            video_id=video_id or None,
            video_url=f"https://www.youtube.com/watch?v={video_id}" if video_id else None,
            video_title=entry.get("title"),
            channel_id=None,
            channel_url=None,
            channel_title=None,
            published_at=entry.get("timestamp") or entry.get("upload_date"),
            duration_seconds=entry.get("duration"),
            availability=entry.get("availability"),
            is_live=entry.get("is_live"),
            raw_json=entry,
            resolved_channel_json={},
            classification="fetched",
        )

    print(f"[source] Step 2: Resolving {len(video_ids)} video IDs → channel IDs (API, ~{len(video_ids)} units)...")

    from csf.source_enumerator import _api_request

    channel_video_map: dict[str, list[str]] = {}
    video_to_channel: dict[str, str] = {}
    for i in range(0, len(video_ids), 50):
        batch = video_ids[i : i + 50]
        params = {"part": "snippet", "id": ",".join(batch)}
        resp = _api_request("videos", params, unit_cost=1)
        if resp is None:
            continue

        for item in resp.get("items", []):
            vid = item.get("id")
            snippet = item.get("snippet", {})
            ch_id = snippet.get("channelId", "")
            if vid and ch_id:
                channel_video_map.setdefault(ch_id, []).append(vid)
                video_to_channel[vid] = ch_id

        if (i + 50) % 500 == 0 or i + 50 >= len(video_ids):
            print(f"  ... resolved {min(i + 50, len(video_ids))}/{len(video_ids)}")

    channel_history_counts = {cid: len(vids) for cid, vids in channel_video_map.items()}
    qualified = {cid: vids for cid, vids in channel_video_map.items() if len(vids) >= min_playlist_videos}
    print(f"[source] Channels with ≥{min_playlist_videos} {playlist_label} videos: {len(qualified)}/{len(channel_video_map)}")

    if not qualified:
        print(f"[source] No channels passed the {playlist_label}-video threshold.")
        sys.exit(1)

    # Get already-tracked UC IDs
    existing_uc_ids: set[str] = set()
    storage = _get_batch_status_storage()
    storage._ensure_channel_metadata()
    conn = storage._get_conn()
    for row in conn.execute("SELECT channel_url FROM channel_metadata").fetchall():
        cu = row[0]
        m = re.search(r"/channel/(UC[a-zA-Z0-9_-]+)", cu)
        if m:
            existing_uc_ids.add(m.group(1))
        elif cu.startswith("UC"):
            existing_uc_ids.add(cu)

    new_qualified = [cid for cid in qualified if cid not in existing_uc_ids]
    print(f"[source] Already tracked: {len(qualified) - len(new_qualified)}")
    print(f"[source] New to add (before filters): {len(new_qualified)}")

    if dry_run:
        finish_playlist_import_run(
            run_id,
            status="dry_run",
            total_items=len(video_ids),
            resolved_items=len(video_to_channel),
            new_channels=len(new_qualified),
            already_tracked_channels=len(qualified) - len(new_qualified),
            blocked_channels=0,
            failed_items=len(video_ids) - len(video_to_channel),
        )
        print(f"\n[source] DRY RUN — would add {len(new_qualified)} channels (filters not yet applied):")
        for cid in sorted(new_qualified)[:50]:
            print(f"  [{channel_history_counts[cid]} videos] https://www.youtube.com/channel/{cid}")
        if len(new_qualified) > 50:
            print(f"  ... and {len(new_qualified) - 50} more")
        print(f"\n[source] Filters (applied on real run):")
        print(f"  subscriber_count > 100")
        print(f"  video_count > 2")
        print(f"  most recent video within 3 months")
        print(f"\n[source] Run without --dry-run to apply filters and add.")
        return

    if not new_qualified:
        finish_playlist_import_run(
            run_id,
            status="completed",
            total_items=len(video_ids),
            resolved_items=len(video_to_channel),
            new_channels=0,
            already_tracked_channels=len(qualified),
            blocked_channels=0,
            failed_items=len(video_ids) - len(video_to_channel),
        )
        print("[source] All qualified history channels already tracked.")
        return

    # Step 3: Apply filters and add
    print(f"[source] Step 3: Applying filters to {len(new_qualified)} channels...")
    print(f"[source] Filters: subscriber_count>100, video_count>2, newest_video≤3mo")

    # Batch-fetch channel metadata: 50 channels per channels.list call (5 units each)
    # vs per-channel get_upload_playlist_id which makes 2 calls each (1+5 units)
    # For 699 channels: ~14 batch calls (70 units) vs ~1398 individual calls (4194 units)
    print(f"[source] Fetching channel metadata in batch (~{len(new_qualified)//50 + 1} API calls, ~5 units/call)...")
    channel_meta: dict[str, dict] = {}
    for i in range(0, len(new_qualified), 50):
        batch = new_qualified[i:i + 50]
        params = {"id": ",".join(batch), "part": "contentDetails,statistics,snippet"}
        resp = _api_request("channels", params, unit_cost=5)
        if not resp or "items" not in resp:
            for uc_id in batch:
                channel_meta[uc_id] = None
            continue

        for item in resp["items"]:
            cid = item.get("id", "")
            if not cid:
                continue
            snippet = item.get("snippet", {})
            content_details = item.get("contentDetails", {})
            statistics = item.get("statistics", {})
            uploads_playlist = content_details.get("relatedPlaylists", {}).get("uploads", "")

            channel_meta[cid] = {
                "title": snippet.get("title", ""),
                "subs": int(statistics.get("subscriberCount", 0) or 0),
                "videos": int(statistics.get("videoCount", 0) or 0),
                "playlist_id": uploads_playlist,
            }
        fetched = min(i + 50, len(new_qualified))
        if (i + 50) % 500 == 0 or fetched >= len(new_qualified):
            print(f"  ... fetched {fetched}/{len(new_qualified)}")

    # Check recency via RSS (free, no quota) for each channel
    cutoff = datetime.now(timezone.utc) - timedelta(days=90)
    three_months_ago = cutoff.strftime("%Y-%m-%d")

    print(f"[source] Checking recency via RSS feed (free, no quota)...")

    def get_latest_video_date(uc_id: str) -> str | None:
        """Fetch most recent video date via RSS. Returns ISO date or None."""
        ATOM_NS = "http://www.w3.org/2005/Atom"
        try:
            rss_url = f"https://www.youtube.com/feeds/videos.xml?channel_id={uc_id}"
            with urlopen(rss_url, timeout=10) as resp:
                tree = ET.parse(resp)
                root = tree.getroot()
                entries = root.findall(f"{{{ATOM_NS}}}entry")
                if not entries:
                    return None
                pub = entries[0].find(f"{{{ATOM_NS}}}published")
                if pub is None:
                    pub = entries[0].find("published")
                return pub.text if pub is not None else None
        except Exception:
            return None

    passed_filters = []
    skipped_filters: dict[str, list[str]] = {
        "subs≤100": [],
        "videos≤2": [],
        "stale>3mo": [],
        "no_meta": [],
    }

    # Pre-fetch RSS recency for all channels in parallel (20 workers)
    # Each RSS call is ~1-3s; 726 channels sequentially = ~30 min; in parallel ~= ~2 min
    print(f"[source] Checking recency via RSS feed ({len(new_qualified)} channels, 20 workers)...")
    from concurrent.futures import ThreadPoolExecutor, as_completed
    rss_dates: dict[str, str | None] = {}
    with ThreadPoolExecutor(max_workers=20) as executor:
        futures = {executor.submit(get_latest_video_date, cid): cid for cid in new_qualified}
        done = 0
        for future in as_completed(futures):
            cid = futures[future]
            rss_dates[cid] = future.result()
            done += 1
            if done % 100 == 0 or done == len(new_qualified):
                print(f"  ... RSS checked {done}/{len(new_qualified)}")

    print(f"[source] Applying filters to {len(new_qualified)} channels...")

    for uc_id in new_qualified:
        meta = channel_meta.get(uc_id)
        if meta is None:
            skipped_filters["no_meta"].append(uc_id)
            continue

        # Filter: subscriber count > 100
        subs = meta["subs"] if meta else 0
        if subs <= 100:
            skipped_filters["subs≤100"].append(uc_id)
            continue

        # Filter: video count > 2
        vid_count = meta["videos"] if meta else 0
        if vid_count <= 2:
            skipped_filters["videos≤2"].append(uc_id)
            continue

        # Filter: most recent video within 3 months
        latest = rss_dates.get(uc_id)
        if latest is None:
            skipped_filters["no_meta"].append(uc_id)
            continue
        try:
            latest_dt = datetime.fromisoformat(latest.replace("Z", "+00:00"))
            if latest_dt < cutoff:
                skipped_filters["stale>3mo"].append(uc_id)
                continue
        except ValueError:
            pass

        passed_filters.append(uc_id)

    print(f"[source] Filters applied:")
    print(f"  passed: {len(passed_filters)}")
    for reason, cids in skipped_filters.items():
        print(f"  skipped ({reason}): {len(cids)}")

    if not passed_filters:
        print("[source] No channels passed all filters.")
        sys.exit(0)

    print(f"[source] Step 4: Adding {len(passed_filters)} channels (no full enumeration — sync will handle lazily)...")

    added = 0
    failed = 0
    blocked = 0

    for uc_id in passed_filters:
        channel_url = f"https://www.youtube.com/channel/{uc_id}"
        if is_channel_blocked(channel_url):
            print(f"  [skip blocked] {channel_url}")
            blocked += 1
            for video_id in channel_video_map.get(uc_id, []):
                record_playlist_import_item(
                    run_id=run_id,
                    item_id=f"{playlist_kind}:{video_id}:blocked",
                    playlist_kind=playlist_kind,
                    playlist_url=playlist_url,
                    playlist_position=None,
                    video_id=video_id,
                    video_url=f"https://www.youtube.com/watch?v={video_id}",
                    video_title=None,
                    channel_id=uc_id,
                    channel_url=channel_url,
                    channel_title=None,
                    published_at=None,
                    duration_seconds=None,
                    availability="blocked",
                    is_live=None,
                    raw_json={},
                    resolved_channel_json={"status": "blocked"},
                    classification="blocked",
                )
            continue

        meta = channel_meta.get(uc_id)
        if not meta:
            failed += 1
            for video_id in channel_video_map.get(uc_id, []):
                record_playlist_import_item(
                    run_id=run_id,
                    item_id=f"{playlist_kind}:{video_id}:failed",
                    playlist_kind=playlist_kind,
                    playlist_url=playlist_url,
                    playlist_position=None,
                    video_id=video_id,
                    video_url=f"https://www.youtube.com/watch?v={video_id}",
                    video_title=None,
                    channel_id=uc_id,
                    channel_url=channel_url,
                    channel_title=None,
                    published_at=None,
                    duration_seconds=None,
                    availability="missing_meta",
                    is_live=None,
                    raw_json={},
                    resolved_channel_json={"status": "missing_meta"},
                    classification="failed",
                )
            continue

        uploads_playlist_id = meta["playlist_id"]
        if not uploads_playlist_id or len(uploads_playlist_id) != 24:
            failed += 1
            for video_id in channel_video_map.get(uc_id, []):
                record_playlist_import_item(
                    run_id=run_id,
                    item_id=f"{playlist_kind}:{video_id}:failed",
                    playlist_kind=playlist_kind,
                    playlist_url=playlist_url,
                    playlist_position=None,
                    video_id=video_id,
                    video_url=f"https://www.youtube.com/watch?v={video_id}",
                    video_title=None,
                    channel_id=uc_id,
                    channel_url=channel_url,
                    channel_title=meta["title"] or None,
                    published_at=None,
                    duration_seconds=None,
                    availability="missing_uploads",
                    is_live=None,
                    raw_json={},
                    resolved_channel_json={"status": "missing_uploads"},
                    classification="failed",
                )
            continue

        # Skip full enumerate_full() — let sync handle it lazily
        # last_full_enumeration=None forces sync to enumerate on next run
        now = datetime.now(timezone.utc).isoformat()
        set_channel_metadata(
            channel_url,
            playlist_id=uploads_playlist_id,
            last_checked=now,
            last_full_enumeration=None,  # sync will enumerate lazily
            video_count_estimate=meta["videos"],
            channel_title=meta["title"] or None,
            thumbnail_url=None,
            subscriber_count=meta["subs"] or None,
            view_count=None,
        )
        hist_count = channel_history_counts.get(uc_id, 0)
        print(f"  OK: {meta['title'] or uc_id} ({meta['videos']} videos total, {hist_count} from history)")
        added += 1
        for video_id in channel_video_map.get(uc_id, []):
            record_playlist_import_item(
                run_id=run_id,
                item_id=f"{playlist_kind}:{video_id}:accepted",
                playlist_kind=playlist_kind,
                playlist_url=playlist_url,
                playlist_position=None,
                video_id=video_id,
                video_url=f"https://www.youtube.com/watch?v={video_id}",
                video_title=None,
                channel_id=uc_id,
                channel_url=channel_url,
                channel_title=meta["title"] or None,
                published_at=None,
                duration_seconds=None,
                availability="accepted",
                is_live=None,
                raw_json={},
                resolved_channel_json={
                    "channel_id": uc_id,
                    "channel_url": channel_url,
                    "channel_title": meta["title"] or None,
                    "status": "accepted",
                },
                classification="accepted",
            )

    print()
    print(f"[source] Done: {added} added, {failed} failed out of {len(passed_filters)}")
    print(f"[source] Full video enumeration will happen on next sync — {added} channels will be processed then.")
    for reason, cids in skipped_filters.items():
        if cids:
            print(f"[source] Skipped ({reason}): {len(cids)}")
    finish_playlist_import_run(
        run_id,
        status="completed",
        total_items=len(video_ids),
        resolved_items=len(video_to_channel),
        new_channels=added,
        already_tracked_channels=len(qualified) - len(new_qualified),
        blocked_channels=blocked,
        failed_items=failed + (len(video_ids) - len(video_to_channel)),
    )


def cmd_history(min_history_videos: int = 2, dry_run: bool = False) -> None:
    """Import channels from watch history."""
    _cmd_playlist_import(
        playlist_kind="history",
        playlist_url="https://www.youtube.com/feed/history",
        min_playlist_videos=min_history_videos,
        dry_run=dry_run,
    )


def cmd_watchlater(min_watchlater_videos: int = 2, dry_run: bool = False) -> None:
    """Import channels from Watch Later."""
    _cmd_playlist_import(
        playlist_kind="watchlater",
        playlist_url="https://www.youtube.com/playlist?list=WL",
        min_playlist_videos=min_watchlater_videos,
        dry_run=dry_run,
    )


def main() -> None:
    parser = argparse.ArgumentParser(
        description="YouTube source management CLI — Phase 2."
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # add command
    add_parser = subparsers.add_parser("add", help="Add a new channel or playlist source")
    add_parser.add_argument("url", help="Channel URL or playlist URL")

    # list command
    subparsers.add_parser("list", help="List all tracked sources")

    # check command
    check_parser = subparsers.add_parser("check", help="Daily check for a source")
    check_parser.add_argument("source", help="Source ID (channel URL or bare channel ID)")

    # check-all command
    check_all_parser = subparsers.add_parser("check-all", help="Check all tracked channels for new videos")
    check_all_parser.add_argument("--verbose", "-v", action="store_true", help="Show detailed output")

    # categorize command
    categorize_parser = subparsers.add_parser("categorize", help="LLM-categorize all channels (idempotent, skips categorized)")
    categorize_parser.add_argument("--workers", type=int, default=1, help="Number of parallel workers (default: 1)")

    # sync command
    sync_parser = subparsers.add_parser("sync", help="Process pending videos for a source")
    sync_parser.add_argument("source", help="Source ID (channel URL or bare channel ID)")

    # quota command
    subparsers.add_parser("quota", help="Show per-key quota state and recommended workers")

    # fetch command (escalation batch process)
    fetch_parser = subparsers.add_parser("fetch", help="Fetch transcripts using escalation chain (yt-dlp → Selenium)")
    fetch_parser.add_argument("--source", help="Process only this channel URL")
    fetch_parser.add_argument("--dry-run", action="store_true", help="Show what would be fetched without fetching")
    fetch_parser.add_argument("--workers", type=int, default=1, help="Number of parallel workers (default: 1)")
    fetch_parser.add_argument("--limit", type=int, help="Stop after this many pending items have been queued for fetching")

    # block command
    block_parser = subparsers.add_parser("block", help="Add a channel to the blocklist")
    block_parser.add_argument("url", help="Channel URL or @handle")

    # unblock command
    unblock_parser = subparsers.add_parser("unblock", help="Remove a channel from the blocklist")
    unblock_parser.add_argument("url", help="Channel URL or @handle")

    # remove command
    remove_parser = subparsers.add_parser("remove", help="Remove a channel and all its videos from the database")
    remove_parser.add_argument("url", help="Channel URL or @handle")

    # list-blocked command
    subparsers.add_parser("list-blocked", help="List all blocked channels")

    # history command
    history_parser = subparsers.add_parser(
        "history",
        help="Extract channels from YouTube watch history and add new ones",
    )
    history_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview channels without adding them",
    )
    history_parser.add_argument(
        "--min-history-videos",
        type=int,
        default=2,
        help="Minimum videos watched from a channel to qualify (default: 2)",
    )

    # watchlater command
    watchlater_parser = subparsers.add_parser(
        "watchlater",
        help="Extract channels from YouTube Watch Later and add new ones",
    )
    watchlater_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview channels without adding them",
    )
    watchlater_parser.add_argument(
        "--min-watchlater-videos",
        type=int,
        default=2,
        help="Minimum videos in Watch Later from a channel to qualify (default: 2)",
    )

    args = parser.parse_args()

    if args.command == "add":
        cmd_add(args.url)
    elif args.command == "list":
        cmd_list()
    elif args.command == "check":
        cmd_check(args.source)
    elif args.command == "check-all":
        cmd_check_all(verbose=args.verbose)
    elif args.command == "categorize":
        cmd_categorize(workers=args.workers)
    elif args.command == "sync":
        cmd_sync(args.source)
    elif args.command == "quota":
        cmd_quota()
    elif args.command == "fetch":
        cmd_fetch(
            source_filter=args.source,
            dry_run=args.dry_run,
            workers=args.workers,
            max_items=args.limit,
        )
    elif args.command == "block":
        cmd_block(args.url)
    elif args.command == "unblock":
        cmd_unblock(args.url)
    elif args.command == "remove":
        cmd_remove(args.url)
    elif args.command == "list-blocked":
        cmd_list_blocked()
    elif args.command == "history":
        cmd_history(min_history_videos=args.min_history_videos, dry_run=args.dry_run)
    elif args.command == "watchlater":
        cmd_watchlater(
            min_watchlater_videos=args.min_watchlater_videos,
            dry_run=args.dry_run,
        )
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
